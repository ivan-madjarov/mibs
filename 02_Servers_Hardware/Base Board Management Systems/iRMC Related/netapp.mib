        ::= 424

	-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -
	-- CIFS domain controller-related traps
	-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -

	domainControllerDisconnect      TRAP-TYPE
	ENTERPRISE        netapp
	VARIABLES                         {productTrapData, productSerialNum}
	DESCRIPTION
		"A CIFS domain controller connection to the filer has failed."
	--#SEVERITY	MINOR
	--#ARGUMENTS	{0}
	--#TYPE		"A CIFS domain controller connection to the filer has failed."
 	--#SUMMARY      "%s"
        ::= 435
        
        dcPasswdChangeFailed            TRAP-TYPE
	ENTERPRISE        netapp
        VARIABLES                         {productTrapData, productSerialNum}
        DESCRIPTION
                "An attempt to change the filer's password with the domain
                controller has failed."
	--#SEVERITY	MINOR
	--#ARGUMENTS	{0}
	--#TYPE		"An attempt to change the filer's password with the domain controller has failed."
 	--#SUMMARY      "%s"
        ::= 436

	domainControllerConnected       TRAP-TYPE
	ENTERPRISE        netapp
	VARIABLES                         {productTrapData, productSerialNum}
	DESCRIPTION
		"A CIFS domain controller connection to the filer has been
		established."
	--#SEVERITY	INFORMATIONAL
	--#ARGUMENTS	{0}
	--#TYPE		"A CIFS domain controller connection to the filer has been established."
 	--#SUMMARY      "%s"
        ::= 437

	-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -
	--  This section contains traps related to plex state 
	-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -

	plexFailed                      TRAP-TYPE
	ENTERPRISE        netapp
	VARIABLES                         {productTrapData, productSerialNum}
	DESCRIPTION 
		"This trap is issued when one plex of a mirrored 
		traditional volume or aggregate is failed. The string 
		sent with this trap specifies name of affected plex or
		mirrored traditional volume or aggregate."
	--#SEVERITY	MAJOR
	--#ARGUMENTS	{0}
	--#TYPE		"This trap is issued when one plex of a mirrored traditional volume or aggregate is failed."
 	--#SUMMARY      "%s"
        ::= 444

	plexOffline                     TRAP-TYPE
	ENTERPRISE        netapp
	VARIABLES                         {productTrapData, productSerialNum}
	DESCRIPTION 
		"This trap is issued when a plex becomes offline. 
		The string sent with this trap specifies name of 
		affected plex or mirrored traditional volume or aggregate."
	--#SEVERITY	MAJOR
	--#ARGUMENTS	{0}
	--#TYPE		"This trap is issued when a plex becomes offline."
 	--#SUMMARY      "%s"
        ::= 454

	-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -
	--  This section contains traps related to shelf Electronics Elements
	--  and intelligent fibre channel interface modules such as LRC,
	--  ESH, AT-FC, and AT-FCX.
	-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -

	shelfSESElectronicsFailed       TRAP-TYPE
	ENTERPRISE        netapp
	VARIABLES                         {productTrapData, productSerialNum}
	DESCRIPTION 
		"One or more of the enclosure services devices in a
		disk shelf has failed.  Some shelf designs combine
		the enclosure monitoring hardware function into the
		module that provides  the storage interface to
		the shelf.  A failure in the enclosure monitoring
		section of these combined modules does not necessarily
		indicate a failure in disk or loop or bus operation,
		which may be able to continue."
	--#SEVERITY	MAJOR
	--#ARGUMENTS	{0}
	--#TYPE		"One or more of the enclosure services devices in a disk shelf has failed."
 	--#SUMMARY      "%s"
        ::= 464

	shelfSESElectronicsInfo         TRAP-TYPE
	ENTERPRISE        netapp
	VARIABLES                         {productTrapData, productSerialNum}
	DESCRIPTION 
		"A previously reported failure of an enclosure
		services device in a disk shelf has been corrected,
		or the device has reported information that does not
		necessarily require customer action."
	--#SEVERITY	INFORMATIONAL
	--#ARGUMENTS	{0}
	--#TYPE		"A previously reported failure of an enclosure services device in a disk shelf has been corrected, or the device has reported information that does not necessarily require customer action."
 	--#SUMMARY      "%s"
        ::= 467

	shelfIFModuleFailed             TRAP-TYPE
	ENTERPRISE        netapp
	VARIABLES                         {productTrapData, productSerialNum}
	DESCRIPTION 
		"One or more of the storage interface modules in a
		disk shelf has failed.  Some shelf designs combine the
		enclosure monitoring hardware function into the module
		that operates the fibre channel loop or SCSI in the
		shelf.  This failure is of the storage interface
		itself, not a failure of the enclosure monitoring,
		which may be able to continue.  This failure may make
		one or more disks in the shelf or in the loop or bus
		unavailable."
	--#SEVERITY	MAJOR
	--#ARGUMENTS	{0}
	--#TYPE		"One or more of the storage interface modules in a disk shelf has failed."
 	--#SUMMARY      "%s"
        ::= 473

 	shelfIFModuleWarning            TRAP-TYPE
	ENTERPRISE        netapp
	VARIABLES                         {productTrapData, productSerialNum}
	DESCRIPTION
		"One or more of the storage interface modules in a
		disk shelf has a warning condition.  Some shelf designs combine the
		enclosure monitoring hardware function into the module
		that operates the fibre channel loop or SCSI in the
		shelf.  This warning condition is of the storage interface
		itself, not a failure of the enclosure monitoring,
		which may be able to continue."
	--#SEVERITY	MINOR
	--#ARGUMENTS	{0}
	--#TYPE		"One or more of the storage interface modules in a disk shelf has a warning condition."
 	--#SUMMARY      "%s"
        ::= 475

 	shelfIFModuleInfo               TRAP-TYPE
	ENTERPRISE        netapp
	VARIABLES                         {productTrapData, productSerialNum}
	DESCRIPTION
		"A previously reported failure of a disk shelf
		interface module has been corrected, or the module has
		reported information that does not necessarily require
		customer action."
	--#SEVERITY	INFORMATIONAL
	--#ARGUMENTS	{0}
	--#TYPE		"A previously reported failure of a disk shelf interface module has been corrected, or the module has reported information that does not necessarily require customer action."
 	--#SUMMARY      "%s"
        ::= 477

	-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -
	--  This section contains traps related to maxdirsize.
	-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -

 	maxDirSizeAlert                 TRAP-TYPE
	ENTERPRISE        netapp
	VARIABLES                         {productTrapData, productSerialNum}
	DESCRIPTION
		"A directory has reached it's maxdirsize limit. Either 
		increase the maxdirsize or clean up the directory."
	--#SEVERITY	CRITICAL
	--#ARGUMENTS	{0}
	--#TYPE		"A directory has reached it's maxdirsize limit."
 	--#SUMMARY      "%s"
        ::= 482

 	maxDirSizeWarning               TRAP-TYPE
	ENTERPRISE        netapp
	VARIABLES                         {productTrapData, productSerialNum}
	DESCRIPTION
		"A directory is getting close to it's maxdirsize limit. Either
		increase the maxdirsize or clean up the directory."
	--#SEVERITY	MINOR
	--#ARGUMENTS	{0}
	--#TYPE		"A directory is getting close to it's maxdirsize limit."
 	--#SUMMARY      "%s"
        ::= 485
        
