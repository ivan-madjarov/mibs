snTrapChassisFanSpeedHigh TRAP-TYPE	 
 	ENTERPRISE foundry
   VARIABLES { snAgGblTrapMessage }
   DESCRIPTION
	   "The SNMP trap that is generated when all chassis fans change to high speed."
	--#TYPE "Foundry Trap: Chassis Fans Speed High"
	--#SUMMARY "%s."
	--#ARGUMENTS { 0 }
	--#SEVERITY INFORMATIONAL
	--#STATE OPERATIONAL
::= 1203

snTrapFIPSModeEnable TRAP-TYPE	 
 	ENTERPRISE foundry
   VARIABLES { snAgGblTrapMessage }   
   DESCRIPTION
                   "The SNMP trap that is generated when FIPS mode is enabled."
   --#TYPE "Foundry Trap: FIPS mode enabled by <username> from console" 
   --#SUMMARY "%s."
   --#ARGUMENTS { 0 }
   --#SEVERITY INFORMATIONAL
   --#STATE OPERATIONAL
   ::= 1207

snTrapFIPSModeDisable TRAP-TYPE	 
 	ENTERPRISE foundry
   VARIABLES { snAgGblTrapMessage }
   DESCRIPTION
                   "The SNMP trap that is generated when FIPS mode is disabled.The zeroization of host keys and shared secret keys is done after this trap is sent."
   --#TYPE "Foundry Trap: FIPS mode disabled by <username> from console"
