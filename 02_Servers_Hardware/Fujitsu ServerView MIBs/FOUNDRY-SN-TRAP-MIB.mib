	   "The SNMP trap that is generated when an existing license is removed from the system."
				--#TYPE "Foundry Trap: License removed"
				--#SUMMARY "%s."
				--#ARGUMENTS { 0 }
				--#SEVERITY INFORMATIONAL
				--#STATE OPERATIONAL
   ::= 188

snTrapLicenseExpires TRAP-TYPE	 
 	ENTERPRISE foundry
   VARIABLES { snAgGblTrapMessage }
   DESCRIPTION
	   "The SNMP trap that is generated when a trial license is about to expire. This trap is generated
		daily for last 3 days and every 2 hours on the last day of expire."
				--#TYPE "Foundry Trap: License is about to expire"
				--#SUMMARY "%s."
				--#ARGUMENTS { 0 }
				--#SEVERITY MINOR
				--#STATE OPERATIONAL
