   --#ARGUMENTS { 0 }
   --#SEVERITY INFORMATIONAL
   --#STATE OPERATIONAL
   ::= 1208


snTrapFIPSHostZeroized TRAP-TYPE	 
 	ENTERPRISE foundry
   VARIABLES { snAgGblTrapMessage }
   DESCRIPTION
                   "The SNMP trap that is generated when host keys are zeroized in FIPS mode"
