   --#SEVERITY INFORMATIONAL
   --#STATE OPERATIONAL
   ::= 1210


snTrapFIPSPOSTStatus TRAP-TYPE	 
 	ENTERPRISE foundry
   VARIABLES { snAgGblTrapMessage }
   DESCRIPTION
                   "The SNMP trap that is generated after POST."
   --#TYPE "Foundry Trap: FIPS POST status =< SUCCESS | FAIL>"
   --#SUMMARY "%s."
   --#ARGUMENTS { 0 }
   --#SEVERITY INFORMATIONAL
   --#STATE OPERATIONAL
   ::=  1211

snTrapFIPSCryptoModuleFailure TRAP-TYPE	 
 	ENTERPRISE foundry
   VARIABLES { snAgGblTrapMessage }
   DESCRIPTION
                   "The SNMP trap that is generated on cryptographic  module failure."
   --#TYPE "Foundry Trap: FIPS Cryptographic Module Failure"
   --#SUMMARY "%s."
