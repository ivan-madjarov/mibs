wgPnPTable OBJECT-TYPE	 
-- 1.3.6.1.4.1.1991.1.1.3.23.4
-- iso(1). org(3). dod(6). internet(1). private(4). enterprises(1). foundry(1991). products(1). switch(1). snSwitch(3). snWireless(23). wgPnPTable(4)
 	SYNTAX 	SEQUENCE OF WgPnPEntry	 
 	ACCESS 	not-accessible 	 
	STATUS	mandatory
 	DESCRIPTION   	 	 
 	"AP Plug and Play Table."
::= { snWireless 4  }	 

wgPnPEntry OBJECT-TYPE	 
-- 1.3.6.1.4.1.1991.1.1.3.23.4.1
-- iso(1). org(3). dod(6). internet(1). private(4). enterprises(1). foundry(1991). products(1). switch(1). snSwitch(3). snWireless(23). wgPnPTable(4). wgPnPEntry(1)
 	SYNTAX 	WgPnPEntry 	 
 	ACCESS 	not-accessible 	 
    STATUS       mandatory
 	DESCRIPTION   	 	 
 	"An entry of the AP Plug and Play Table."
 	INDEX { wgPnPIfIndex, wgPnPMacAddress }	 
::= { wgPnPTable 1  }	 

WgPnPEntry ::= SEQUENCE { 	 
 	
	wgPnPIfIndex	
		INTEGER ,	 
	wgPnPMacAddress	
		MacAddress,	 
	wgPnPStatus	
		INTEGER	 
}

wgPnPIfIndex OBJECT-TYPE	 
-- 1.3.6.1.4.1.1991.1.1.3.23.4.1.1
-- iso(1). org(3). dod(6). internet(1). private(4). enterprises(1). foundry(1991). products(1). switch(1). snSwitch(3). snWireless(23). wgPnPTable(4). wgPnPEntry(1). wgPnPIfIndex(1)
 	SYNTAX 	INTEGER 	 
 	ACCESS 	read-only 	 
    STATUS       mandatory
 	DESCRIPTION   	 	 
 	"ifIndex value of the switch interface."
::= { wgPnPEntry 1  }


wgPnPMacAddress OBJECT-TYPE	 
-- 1.3.6.1.4.1.1991.1.1.3.23.4.1.2
-- iso(1). org(3). dod(6). internet(1). private(4). enterprises(1). foundry(1991). products(1). switch(1). snSwitch(3). snWireless(23). wgPnPTable(4). wgPnPEntry(1). wgPnPMacAddress(2)
 	SYNTAX 	MacAddress	 
 	ACCESS 	read-only 	 
    STATUS       mandatory
 	DESCRIPTION   	 	 
 	"MAC address of the attached AP."
::= { wgPnPEntry 2  }

wgPnPStatus OBJECT-TYPE	 
-- 1.3.6.1.4.1.1991.1.1.3.23.4.1.6
-- iso(1). org(3). dod(6). internet(1). private(4). enterprises(1). foundry(1991). products(1). switch(1). snSwitch(3). snWireless(23). wgPnPTable(4). wgPnPEntry(1). wgPnPStatus(6)
 	SYNTAX 	INTEGER  { 	 
 	
 		other 	(1),	 
 		discovered 	(2),	 
 		configured 	(3),	 
 		operational 	(4)	 
 	}
 	ACCESS 	read-only 	 
    STATUS       mandatory
 	DESCRIPTION   	 	 
 	"AP device status. If the switch diecovered a new AP which
had not been configured, the 'discovered' state will return.
If the AP's IP address, subnet mask and default gateway were
configured to the switch port but the AP with the matching
MAC address had not attached to the switch port, 'configured'
state will return. If the AP's IP address, subnet mask and
default gateway were configured to the switch port and the
AP with the matching MAC address had attached to the switch
port and was operating, 'operational' state will return."
::= { wgPnPEntry 6  }

