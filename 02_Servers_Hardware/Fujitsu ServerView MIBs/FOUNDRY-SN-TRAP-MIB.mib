snTrapChassisFanSpeedMedHigh TRAP-TYPE	 
 	ENTERPRISE foundry
   VARIABLES { snAgGblTrapMessage }
   DESCRIPTION
	   "The SNMP trap that is generated when all chassis fans change to medium high speed."
	--#TYPE "Foundry Trap: Chassis Fans Speed Medium High"
	--#SUMMARY "%s."
	--#ARGUMENTS { 0 }
	--#SEVERITY INFORMATIONAL
