--*********************************************************************
-- SIP Endpoint Statistics Table - FRN2192
--*********************************************************************

usSrxSipEPStatsTable OBJECT-TYPE
        SYNTAX SEQUENCE OF UsSrxSipEPStatsTableEntry
        MAX-ACCESS not-accessible
        STATUS  current
        DESCRIPTION "
         The SIP Endpoint statiscs table.
         A table containing a array of SIP Endpoints with their respective name,
         IP Address, ResetTimestamp and usage counters."
        ::= { usSrxSipEP 1 }

usSrxSipEPStatsTableEntry OBJECT-TYPE
        SYNTAX UsSrxSipEPStatsTableEntry
        MAX-ACCESS not-accessible
        STATUS  current
        DESCRIPTION "
          An entry in the usSrxSipEPStatsTable."
        INDEX  { usSrxSipEPStatsId }
        ::= { usSrxSipEPStatsTable 1 }

UsSrxSipEPStatsTableEntry ::=
	SEQUENCE {
        usSrxSipEPStatsId               Integer32,
        usSrxSipEPStatsName             DisplayString,
        usSrxSipEPStatsIpAddress        IpAddress,
        usSrxSipEPStatsResetTimestamp   DisplayString,
        usSrxSipEPPrfInviteMsSbC        Integer32,
        usSrxSipEPPrf100TryingMsgRbC    Integer32,
        usSrxSipEPPrf180RingingMsgRbC   Integer32,
        usSrxSipEPPrf200OKForInvtMsgRbC Integer32,
        usSrxSipEPPrf301MsgRbC          Integer32,
        usSrxSipEPPrf302MsgRbC          Integer32,
        usSrxSipEPPrfAckForInvtMsgSbC   Integer32,
        usSrxSipEPPrfAckForErrorMsgSbC  Integer32,
        usSrxSipEPPrfErrorMsgRbC        Integer32,
        usSrxSipEPPrfByeMsgSbC          Integer32,
        usSrxSipEPPrf200OKForByeMsgRbC  Integer32,
        usSrxSipEPPrfCancelMsgSbC       Integer32,
        usSrxSipEPPrf200OKforCancMsgRbC Integer32,
        usSrxSipEPPrf487MsgRbC          Integer32,
        usSrxSipEPPrfAckForCancMsgSbC   Integer32,
        usSrxSipEPPrf200OKfRgstrMsgSbS  Integer32,
        usSrxSipEPPrfRegisterMsgRbS     Integer32,
