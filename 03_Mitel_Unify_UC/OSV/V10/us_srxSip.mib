IMPORTS
    MODULE-IDENTITY, OBJECT-TYPE, Integer32
        FROM SNMPv2-SMI
    DisplayString, RowStatus
        FROM SNMPv2-TC
    Boolean, TimeStampSeconds 
        FROM FTS-RTP-MIB
    InetAddressType, InetAddress
        FROM INET-ADDRESS-MIB		
    surpassRtp
	FROM SURPASS-RTP-MIB
    hiq8000Admin
        FROM SURPASS-RTP-ADMIN-MIB
    SrxRowCountType
        FROM HIQ-ADMIN-MIB;

-- ########################################################


-- ########################################################

usSrxSip MODULE-IDENTITY
    LAST-UPDATED "201509141224Z"
    ORGANIZATION "Unify Software and Solutions GmbH & Co. KG"
    CONTACT-INFO "http://www.unify.com/us/Home/Internet/web/us/Home/contact-us.aspx"
    DESCRIPTION
        "SRX SIP MIB module which manages the SIP Signal Manager"
        
    REVISION "201310221220Z"    
    DESCRIPTION
            "Updated the MIB with the new Brand Name"

    ::= { hiq8000Admin 2 }

-- ########################################################

-- usSrxSipTable. This table is used for configuring the SIP Signalling Manager.
-- ########################################################


usSrxSipObjects               OBJECT IDENTIFIER     ::= { usSrxSip 1 }

usSrxSipConfigStatisticsData  OBJECT IDENTIFIER     ::= { usSrxSipObjects 1 }

usSrxSipReasonMgmt            OBJECT IDENTIFIER     ::= { usSrxSipObjects 2 } 

usSrxSipEP                    OBJECT IDENTIFIER     ::= { usSrxSipObjects 3 }

