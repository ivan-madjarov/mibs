hiQAudFileSystemBelowMin1Trap NOTIFICATION-TYPE
            OBJECTS { rtpEvtSequenceNumberIndex,
                      rtpEvtCurrId,
                      rtpEvtSet ,                     --102
                      rtpEvtNum ,                     --211
                      rtpEvtSeverity,
                      rtpEvtEventTime,
                      rtpEvtReportingObject,
                      rtpEvtFaultyObject,
                      rtpEvtEndkey,
                      rtpEvtFormatText,
                      rtpEvtParameters,
                      rtpEvtAlarmType,
                      rtpEvtShortText,
                      rtpEvtFilterLastTransId,
                      rtpClusterName
            }
            STATUS current
            DESCRIPTION  "File system (disk partition) or database space has changed but it is still below
                        the configured minimum level. The partitions can be: /, /dev,
                        /cdr,/enterprise,/global,/home,/log,/opt,/software,/tmp,/tpa,/unisphere,/var." 
            ::= { hiQAudFaultMgt 211 }

hiQAudFileSystemBelowMin2Trap NOTIFICATION-TYPE
            OBJECTS { rtpEvtSequenceNumberIndex,
                      rtpEvtCurrId,
                      rtpEvtSet ,                     --102
                      rtpEvtNum ,                     --212
                      rtpEvtSeverity,
                      rtpEvtEventTime,
                      rtpEvtReportingObject,
                      rtpEvtFaultyObject,
                      rtpEvtEndkey,
                      rtpEvtFormatText,
                      rtpEvtParameters,
                      rtpEvtAlarmType,
                      rtpEvtShortText,
                      rtpEvtFilterLastTransId,
                      rtpClusterName
            }
            STATUS current
            DESCRIPTION  "File system (disk partition) or database space has changed but it is still below
                        the configured minimum level. File system or database space error messages with a
                        lower severity level than critical concerning the given data space will be
                        automatically cleared with this abatement so that only the new critical alarm is left
                        open. The partitions can be: /, /dev, cdr, /enterprise, /global, /home, /log, /opt,
                        /software, /tmp, /tpa, /unisphere, /var." 
            ::= { hiQAudFaultMgt 212 }

