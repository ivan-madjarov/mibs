            }
            STATUS current
            DESCRIPTION  "The number of assigned licenses is now within the limit allowed by the number of
                        licenses." 
            ::= { hiQLicensingFaultMgt 2 }

hiQLicenseCountMismatchTrap NOTIFICATION-TYPE
            OBJECTS { rtpEvtSequenceNumberIndex,
                      rtpEvtCurrId,
                      rtpEvtSet ,                     --220
                      rtpEvtNum ,                     --3
                      rtpEvtSeverity,
                      rtpEvtEventTime,
                      rtpEvtReportingObject,
                      rtpEvtFaultyObject,
                      rtpEvtEndkey,
                      rtpEvtFormatText,
                      rtpEvtParameters,
                      rtpEvtAlarmType,
                      rtpEvtShortText,
                      rtpEvtFilterLastTransId,
                      rtpClusterName
            }
            STATUS current
            DESCRIPTION  "The license count is different between the two nodes of the hiQ cluster for the
                        type identified by FaultyObject. The system's behavior will change if the node that is
                        currently hosting the primary license manager process fails or if the process itself
                        is shut down and the secondary becomes the primary. This happens during rolling
                        upgrade, for example. All license functionality uses the values in the primary license
                        manager, the secondary is only used to take over if the primary is shut down. If there
                        is a license count mismatch then license violations may be detected in error during
                        upgrades or if a node failure occurs. This in turn may cause licensing restrictions
                        to be activated in error." 
            ::= { hiQLicensingFaultMgt 3 }

