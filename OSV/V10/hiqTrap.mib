US-HIQ-TRAP-MIB    DEFINITIONS ::= BEGIN

IMPORTS
   MODULE-IDENTITY, OBJECT-TYPE, Integer32
      FROM SNMPv2-SMI
   DisplayString, RowStatus
        FROM SNMPv2-TC
   InetAddressType, InetAddress
        FROM INET-ADDRESS-MIB 
   hiq8000Admin
        FROM HIQ-ADMIN-MIB
   rtpEvtSequenceNumberIndex,
   rtpEvtCurrId, rtpEvtSet, rtpEvtNum,
   rtpEvtSeverity, rtpEvtEventTime,
   rtpEvtReportingObject, rtpEvtFaultyObject,
   rtpEvtEndkey, rtpEvtFormatText,
   rtpEvtParameters,  rtpEvtAlarmType, rtpEvtShortText,
   rtpEvtFilterLastTransId , rtpClusterName 
   
   FROM FTS-RTP-MIB-EVENT-MGMT;

-- =================================================================
--      rtpEvtSeverity:  level 1-7, 1 is critical, 
--                                  2 major
--                                  3 minor
--                                  4 warning
--                                  5 informational (NOT reported by OSV)
--                                  6 cleared
--                                  7 unknown (NOT reported by OSV)
--      rtpEvtAlarmType: types 0-99, 0 is undeterminate,
--                                   1 is communication alarm
--                                   2 is service alarm
--                                   3 is processing alarm
--                                   4 is equipement alarm
--                                   5 is environment alarm (NOT reported by OSV)
--                                   6 is db alarm
--                                   7 is mib alarm
--                                   8 is the first user defineable alarm
--                                   32 is security alarm
--                                   34 is indication event
--
--
-- OSV Version:                      V9
-- OSV Patch Set:                    
-- ==================================================================

hiqTraps   MODULE-IDENTITY
    LAST-UPDATED "202107121520Z"
           ORGANIZATION "Unify Software and Solutions GmbH & Co. KG"
           CONTACT-INFO "Gerasimos Kouris" 
           DESCRIPTION
           "This MIB describes the Unify GmbH & Co. KG Netword traps of the OSV cluster.
           The definition of the event is taken from
           RtpAdmEventMgmt.mib. For the description
           of these objects:  rtpEvtSequenceNumberIndex,
                              rtpEvtCurrId,
                              rtpEvtSet,
                              rtpEvtNum,
                              rtpEvtSeverity,
                              rtpEvtEventTime,
                              rtpEvtReportingObject,
                              rtpEvtFaultyObject,
                              rtpEvtEndkey,
                              rtpEvtFormatText,
                              rtpEvtParameters,
                              rtpEvtAlarmType,
                              rtpEvtShortText,
                              rtpEvtFilterLastTransId,
		                      rtpClusterName"
        ::= { hiq8000Admin 47 }

