-- ************************************************************************
-- The two Survival Authority traps below are not
-- alarms and not alarm clearance traps.
-- They are informational traps exclusively sent from the OSV cluster nodes
-- to the Survival Authority to test the communication link or
-- to report a broken or repaired partner node communication link
-- ***************************************************************************

hiQSurvivalAuthorityObjects OBJECT IDENTIFIER ::= { hiqTraps 222 }

-- Trap type
hiQSurvivalTrapType OBJECT-TYPE
    SYNTAX INTEGER { takeover(1), requestcommtest(2) }
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "An enumerated value indicating the trap type."
    ::= { hiQSurvivalAuthorityObjects 1 }
 
-- Node name
hiQSurvivalNodeName OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (0..63))
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "Name of node reporting to survival authority."
    ::= { hiQSurvivalAuthorityObjects 2 }
 
-- Cluster name
hiQSurvivalClusterName OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (0..63))
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "Name of cluster reporting to survival authority."
    ::= { hiQSurvivalAuthorityObjects 3 }
 
-- IP Address
hiQSurvivalNodeIPAddress OBJECT-TYPE
    SYNTAX IpAddress
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "IP address of node reporting to survival authority."
    ::= { hiQSurvivalAuthorityObjects 4 }

--  Community String 
hiQSurvivalCommunityString OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (0..15))
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "Temporary community string to be used by the SET command 
    		 acknowledging the hiQPartnerNodeLeftCLusterTrap."
    ::= { hiQSurvivalAuthorityObjects 5 }

--  AddressType
hiQInetAddressType OBJECT-TYPE
    SYNTAX InetAddressType
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "IP address type of node reporting to survival authority. IPv4 or IPv6"
    ::= { hiQSurvivalAuthorityObjects 6 }

--  IP Address
hiQInetAddress OBJECT-TYPE
    SYNTAX InetAddress
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "IP address of node reporting to survival authority.
              If this is an IPv6 address the hiQSurvivalNodeIPAddress parameter may in addition 
			  show an IPv4 address in case of dual stack"
::= { hiQSurvivalAuthorityObjects 7 }


hiQSurvivalAuthorityTraps OBJECT-IDENTITY
                STATUS current
                DESCRIPTION
                "Events for Survival Authority processing"
                ::= { hiqTraps 223 }
 
hiQPartnerNodeLeftClusterTrap NOTIFICATION-TYPE
            OBJECTS {
                hiQSurvivalTrapType,
                hiQSurvivalNodeName,
                hiQSurvivalClusterName,
                hiQSurvivalNodeIPAddress,
                hiQSurvivalCommunityString,
                hiQInetAddressType,
                hiQInetAddress
            }
            STATUS current
            DESCRIPTION  "Sent to the 'Survival Authority' to request
                          a communication test or when a node cannot
                          communicate with its partner, the 'Survival
                          Authority' is requested to respond with an
                          SNMP set command."
            ::= { hiQSurvivalAuthorityTraps 1 }

hiQResetSurvivalModeTrap NOTIFICATION-TYPE
            OBJECTS {
                hiQSurvivalTrapType,
                hiQSurvivalNodeName,
                hiQSurvivalClusterName,
                hiQSurvivalNodeIPAddress,
                hiQInetAddressType,
                hiQInetAddress
            }
            STATUS current
            DESCRIPTION  
                          "Sent to the 'Survival Authority' to reset
                           the current Survival Authority status to
                           'no longer in survival mode'."
            ::= { hiQSurvivalAuthorityTraps 2 }


-- ***************************************************************************************************
-- Start of OSV alarm and alarm clearance traps
-- ***************************************************************************************************


hiQProcessExitedTrap NOTIFICATION-TYPE
            OBJECTS { rtpEvtSequenceNumberIndex,
                      rtpEvtCurrId,
                      rtpEvtSet ,                     --100
                      rtpEvtNum ,                     --2
                      rtpEvtSeverity,
                      rtpEvtEventTime,
                      rtpEvtReportingObject,
                      rtpEvtFaultyObject,
                      rtpEvtEndkey,
                      rtpEvtFormatText,
                      rtpEvtParameters,
                      rtpEvtAlarmType,
                      rtpEvtShortText,
                      rtpEvtFilterLastTransId,
                      rtpClusterName
            }
            STATUS current
            DESCRIPTION  "The process terminated normally because of either a request by RTP to shut down
                        a configured process or the normal termination of a dynamic, non-configured process." 
            ::= { hiQEvtFaultMgt 2 }

hiQAuditStartingTrap NOTIFICATION-TYPE
            OBJECTS { rtpEvtSequenceNumberIndex,
                      rtpEvtCurrId,
                      rtpEvtSet ,                     --102
                      rtpEvtNum ,                     --1
                      rtpEvtSeverity,
                      rtpEvtEventTime,
                      rtpEvtReportingObject,
                      rtpEvtFaultyObject,
                      rtpEvtEndkey,
                      rtpEvtFormatText,
                      rtpEvtParameters,
                      rtpEvtAlarmType,
                      rtpEvtShortText,
                      rtpEvtFilterLastTransId,
                      rtpClusterName
            }
            STATUS current
            DESCRIPTION  "The Audit Manager process is starting." 
            ::= { hiQAudFaultMgt 1 }

hiQAudAvailDiskSpBelowCritThld NOTIFICATION-TYPE
            OBJECTS { rtpEvtSequenceNumberIndex,
                      rtpEvtCurrId,
                      rtpEvtSet ,                     --102
                      rtpEvtNum ,                     --201
                      rtpEvtSeverity,
                      rtpEvtEventTime,
                      rtpEvtReportingObject,
                      rtpEvtFaultyObject,
                      rtpEvtEndkey,
                      rtpEvtFormatText,
                      rtpEvtParameters,
                      rtpEvtAlarmType,
                      rtpEvtShortText,
                      rtpEvtFilterLastTransId,
                      rtpClusterName
            }
            STATUS current
            DESCRIPTION  "The available space in a file system / disk partition is the space usable by
                        non-superuser. The rest of the space is either used or reserved for superuser. Refer
                        to man page df(1). The available space in a database depends on the type of database.
                        The partitions can be: /, /dev,
                        /cdr,/enterprise,/global,/home,/log,/opt,/software,/tmp,/tpa,/unisphere,/var." 
            ::= { hiQAudFaultMgt 201 }

