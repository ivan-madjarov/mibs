           applicationVersion          DisplayString,
           applicationContact          DisplayString,
           applicationStatus           DisplayString,
           applicationMgmtURL          DisplayString,
           applicationDocURL           DisplayString,
           applicationIconURL          DisplayString
        }


    applicationGuid OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
            "The unique identifier of the application."
        ::= { applicationTableEntry 1 }
    
    applicationDisplayName OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
            "The display name of the application."
        ::= { applicationTableEntry 2 }

    applicationDescription OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
