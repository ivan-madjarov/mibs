        ::= { applicationGroup 3 }


    applicationTableEntry  OBJECT-TYPE
        SYNTAX      ApplicationTableEntry
        MAX-ACCESS  not-accessible
        STATUS      current
        DESCRIPTION
                    "The application table entries."
        INDEX { applicationGuid }
        ::= { applicationTable 1 }


    ApplicationTableEntry ::= SEQUENCE {
