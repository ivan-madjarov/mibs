        ::= { containerTable 1 }


    ContainerTableEntry ::= SEQUENCE {
           containerGuid             DisplayString,
           containerNodeGuid         DisplayString,
           containerDisplayName      DisplayString,
           containerStatus           DisplayString,
           containerVersion          DisplayString,
           containerMgmtURL          DisplayString,
           containerDocURL           DisplayString,
           containerIconURL          DisplayString                 
        }


    containerGuid OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
            "The unique identifier of the container."
