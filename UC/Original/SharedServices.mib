    containerAssocServiceDisplayName OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
            "The display name of the associated service."
        ::= { containerServiceTableEntry 3 }
        
                
    --*******************************************--
    --************** service Group **************--
    --*******************************************--

    numberOfServiceEntries  OBJECT-TYPE
        SYNTAX      INTEGER (1..2147483187)
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
                    "The number of entries in the service table."
        ::= { serviceGroup 1 }

    numberOfServiceTraps  OBJECT-TYPE
        SYNTAX      INTEGER (1..2147483187)
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
                    "The number of traps which were sent to signal 
                    status changes of the services."
        ::= { serviceGroup 2 }

    serviceTable  OBJECT-TYPE
        SYNTAX      SEQUENCE OF ServiceTableEntry
        MAX-ACCESS  accessible-for-notify
        STATUS      current
        DESCRIPTION
                    "This table shows the contents of a service entry. 
                    Services are deployed to containers which are installed 
                    on nodes. Services are used by applications.
                    Service-faults can initiate alarm traps which could be 
                    send to external faultmanagement systems. "
        ::= { serviceGroup 3 }


    serviceTableEntry  OBJECT-TYPE
        SYNTAX      ServiceTableEntry
        MAX-ACCESS  not-accessible
        STATUS      current
        DESCRIPTION
                    "The service table entries."
        INDEX { serviceGuid }
        ::= { serviceTable 1 }


    ServiceTableEntry ::= SEQUENCE {
           serviceGuid               DisplayString,
           serviceContainerGuid      DisplayString,
           serviceNodeGuid           DisplayString,
           serviceDisplayName        DisplayString,
           serviceStatus             DisplayString,
           serviceMgmtURL            DisplayString,
           serviceDocURL             DisplayString,
           serviceIconURL            DisplayString         
        }


    serviceGuid OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
            "The unique identifier of the service."
        ::= { serviceTableEntry 1 }    

    
    serviceContainerGuid OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
            "The unique identifier of the associated container."
        ::= { serviceTableEntry 2 }

    serviceNodeGuid OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
           "The unique identifier of the associated node."
        ::= { serviceTableEntry 3 }
    
    serviceDisplayName OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
            "The display name of the service."
        ::= { serviceTableEntry 4 }

    serviceStatus OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
           "The status of the service. 
           Possible values are: normal, warning, critical."
        ::= { serviceTableEntry 5 }     

    serviceMgmtURL OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
            "Points to an page with gives access to the 
            configuration manager of the component if available."
        ::= { serviceTableEntry 6 }
    
    serviceDocURL OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
            "Points to the documentation."
        ::= { serviceTableEntry 7 }

    serviceIconURL OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
            "Points to a file, which describes the location of the 
            shape and the pixmaps for the icons to be used to display 
            the service on the desktop map."
        ::= { serviceTableEntry 8 }


    --********* Associated alarms ***********--

    numberOfServiceAlarmEntries  OBJECT-TYPE
        SYNTAX      INTEGER (1..2147483187)
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
                    "The number of alarm traps which were 
                    initiated by specified service-faults."
        ::= { serviceGroup 4 }

    serviceAlarmTable  OBJECT-TYPE
        SYNTAX      SEQUENCE OF ServiceAlarmTableEntry
        MAX-ACCESS  accessible-for-notify
        STATUS      current
        DESCRIPTION
                    "This table shows the alarm traps which were generated 
                    due to specified faults which appeared in the services."
        ::= { serviceGroup 5 }


     serviceAlarmTableEntry  OBJECT-TYPE
        SYNTAX      ServiceAlarmTableEntry
        MAX-ACCESS  not-accessible
        STATUS      current
        DESCRIPTION
                    "The associated alarms."
        INDEX { serviceAssocAlarmState,
                serviceAssocServiceGuid,   
                serviceAssocAlarmIndex }
        ::= { serviceAlarmTable 1 }


    ServiceAlarmTableEntry ::= SEQUENCE {
          serviceAssocAlarmState           Boolean,
          serviceAssocServiceGuid          DisplayString,
          serviceAssocAlarmIndex           INTEGER,
          serviceAssocAlarmDescription     DisplayString
          }


   serviceAssocAlarmState  OBJECT-TYPE
       SYNTAX      Boolean
       MAX-ACCESS  read-only
       STATUS      current
       DESCRIPTION
                   "Status of the associated alarm: 
                   alarm status on, alarm status off."
       ::= { serviceAlarmTableEntry 1 }

    serviceAssocServiceGuid OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
            "The unique identifier of the service 
            which has initiated the alarm trap."
        ::= { serviceAlarmTableEntry 2 }
        
    serviceAssocAlarmIndex OBJECT-TYPE
        SYNTAX                  INTEGER (1..2147483187)
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
            "The alarm table index of the associated alarm, 
            which is defined in the alarm group."
        ::= { serviceAlarmTableEntry 3 }
            
    serviceAssocAlarmDescription OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
            "A description of the associated alarm."
        ::= { serviceAlarmTableEntry 4 }

     
    --*******************************************--
    --************** alarm Group ****************--
    --*******************************************--

   numberOfAlarmEntries  OBJECT-TYPE
       SYNTAX      INTEGER (1..2147483187)
       MAX-ACCESS  read-only
       STATUS      current
       DESCRIPTION
                   "The number of entries in the alarm-trap table."
       ::= { alarmGroup 1 }

   numberOfAlarmTraps  OBJECT-TYPE
       SYNTAX      INTEGER (1..2147483187)
       MAX-ACCESS  read-only
       STATUS      current
       DESCRIPTION
                   "The number of alarm-traps which were 
                   initiated by specified faults."
       ::= { alarmGroup 2 }

   alarmTrapTable  OBJECT-TYPE
       SYNTAX      SEQUENCE OF AlarmTrapTableEntry
       MAX-ACCESS  accessible-for-notify
       STATUS      current
       DESCRIPTION
                   "This table shows the contents of an alarm trap.
                   Alarm traps are generated if specified faults 
                   appear in the services. Objects definitions alarmTimestampOff 
                   and alarmTimestampReceived have become obsolete."
       ::= { alarmGroup 3 }


   alarmTrapTableEntry  OBJECT-TYPE
       SYNTAX      AlarmTrapTableEntry
       MAX-ACCESS  not-accessible
       STATUS      current
       DESCRIPTION
                   "The alarm trap table entries."
       INDEX { alarmTableIndex }
       ::= { alarmTrapTable 1 }


   AlarmTrapTableEntry ::= SEQUENCE {
          alarmTableIndex             INTEGER,
          alarmId                     INTEGER,
          alarmServiceGuid            DisplayString,
          alarmContainerGuid          DisplayString,
          alarmNodeGuid               DisplayString,
          alarmTitle                  DisplayString,
          alarmState                  Boolean,
          alarmSourceGuid             DisplayString,
          alarmSourceName             DisplayString,
          alarmSourceClass            DisplayString,
          alarmTimestampOn            DisplayString,
          alarmTimestampOff           DisplayString,
          alarmTimestampReceived      DisplayString,
          alarmPriority               Severity,
          alarmCategory               DisplayString,
          alarmDescription            DisplayString
       }


   alarmTableIndex  OBJECT-TYPE
       SYNTAX      INTEGER (1..2147483187)
       MAX-ACCESS  read-only
       STATUS      current
       DESCRIPTION
                   "A consecutive number of the alarm-traps."
       ::= { alarmTrapTableEntry 1 }

   alarmId  OBJECT-TYPE
       SYNTAX      INTEGER (1..2147483187)
       MAX-ACCESS  read-only
       STATUS      current
       DESCRIPTION
                   "The unique identifier of the alarm."
       ::= { alarmTrapTableEntry 2 }

   alarmServiceGuid  OBJECT-TYPE
       SYNTAX      DisplayString
       MAX-ACCESS  read-only
       STATUS      current
       DESCRIPTION
                   "The GUID of the service which
                    raises the alarm."
       ::= { alarmTrapTableEntry 3 }

   alarmContainerGuid  OBJECT-TYPE
       SYNTAX      DisplayString
       MAX-ACCESS  read-only
       STATUS      current
       DESCRIPTION
                   "The GUID of the container 
                   the alarm source is running on."
       ::= { alarmTrapTableEntry 4 }

   alarmNodeGuid  OBJECT-TYPE
       SYNTAX      DisplayString
       MAX-ACCESS  read-only
       STATUS      current
       DESCRIPTION
                   "The configured (fixed) node id of the 
                    node the alarm source is running on."
       ::= { alarmTrapTableEntry 5 }

   alarmTitle  OBJECT-TYPE
       SYNTAX      DisplayString
       MAX-ACCESS  read-only
       STATUS      current
       DESCRIPTION
                   "The title of the alarm. Possible are 
                    any free configurable strings."
       ::= { alarmTrapTableEntry 6 }

   alarmState  OBJECT-TYPE
       SYNTAX      Boolean
       MAX-ACCESS  read-only
       STATUS      current
       DESCRIPTION
                   "Status of the alarm: alarm status on, alarm status off. 
                   The alarm is still visible if the status changes to 'off'."
       ::= { alarmTrapTableEntry 7 }

   alarmSourceGuid  OBJECT-TYPE
       SYNTAX      DisplayString
       MAX-ACCESS  read-only
       STATUS      current
       DESCRIPTION
                   "The GUID of the alarm source. 
                    Possible values are the configured (fixed) 
                    GUIDs of the FaultHandler instance 
                    or HP8k trapReceiver instance."
       ::= { alarmTrapTableEntry 8 }

   alarmSourceName  OBJECT-TYPE
       SYNTAX      DisplayString
       MAX-ACCESS  read-only
       STATUS      current
       DESCRIPTION
                   "The name of the alarm source. 
                    Possible values are the configured (changeable) 
                    display names of the Fault Handler instance 
                    or HP8k trapReceiver instance."
       ::= { alarmTrapTableEntry 9 }
 
   alarmSourceClass  OBJECT-TYPE
       SYNTAX      DisplayString
       MAX-ACCESS  read-only
       STATUS      current
       DESCRIPTION
                   "The ClassName of the alarm source. 
                    Possible values are the configured (fixed) 
                    implementation class names of Fault Handler 
                    instance or HP8k trapReceiver instance."
       ::= { alarmTrapTableEntry 10 }

   alarmTimestampOn  OBJECT-TYPE
       SYNTAX      DisplayString
       MAX-ACCESS  read-only
       STATUS      current
       DESCRIPTION
           "Date and time of the alarm event generation. 
            See above for a description on the semantics."
       ::= { alarmTrapTableEntry 11 } 

   alarmTimestampOff  OBJECT-TYPE
       SYNTAX      DisplayString
       MAX-ACCESS  read-only
       STATUS      obsolete
       DESCRIPTION
           "Date and time of the alarm event reset. 
            See above for a description on the semantics."
       ::= { alarmTrapTableEntry 12 } 

   alarmTimestampReceived  OBJECT-TYPE
       SYNTAX      DisplayString
       MAX-ACCESS  read-only
       STATUS      obsolete
       DESCRIPTION
           "Date and time when the alarm event was received 
           by the FaultHandler.
            See above for a description on the semantics."
       ::= { alarmTrapTableEntry 13 } 

   alarmPriority   OBJECT-TYPE
       SYNTAX      Severity
       MAX-ACCESS  read-only
       STATUS      current
       DESCRIPTION
                   "The priority of the alarm. 
                    Possible values are: 
                       (0) normal, 
                       (1) information, 
                       (2) warning, 
                       (3) minor, 
                       (4) major, 
                       (5) critical, 
                       (6) unknown."
       ::= { alarmTrapTableEntry 14 }

   alarmCategory  OBJECT-TYPE
       SYNTAX      DisplayString
       MAX-ACCESS  read-only
       STATUS      current
       DESCRIPTION
                   "The category of the alarm. Possible are 
                    any free configurable strings."
       ::= { alarmTrapTableEntry 15 }

   alarmDescription  OBJECT-TYPE
       SYNTAX      DisplayString
       MAX-ACCESS  read-only
       STATUS      current
       DESCRIPTION
                   "The description of the alarm. Possible 
                    are any free configurable strings."
       ::= { alarmTrapTableEntry 16 }


--************************************************************************-- 
--******                 Non Accessible Elements                    ******--
--************************************************************************-- 

    --*******************************************--
    --************** trap Group *****************--
    --*******************************************--
   nodeStatusChange  NOTIFICATION-TYPE
       OBJECTS {
          nodeGuid,
          nodeStatus
          }
       STATUS      current
       DESCRIPTION
                   "If the status of an node changes, 
                    a trap will be send to the management station 
                    containing the application identifier 
                    and the node status."
       ::= { trapGroup 1 }

   applicationStatusChange  NOTIFICATION-TYPE
       OBJECTS {
          applicationGuid,
          applicationStatus
          }
       STATUS      current
       DESCRIPTION
                   "If the status of an application changes, 
                    a trap will be send to the management station 
                    containing the application identifier 
                    and the application status."
       ::= { trapGroup 2 }

   containerStatusChange  NOTIFICATION-TYPE
       OBJECTS {
          containerGuid,
          containerStatus
          }
       STATUS      current
       DESCRIPTION
                   "If the status of a container changes, 
                    a trap will be send to the management station 
                    containing the container identifier 
                    and the container status."
       ::= { trapGroup 3 }

   serviceStatusChange  NOTIFICATION-TYPE
       OBJECTS {
          serviceGuid,
          serviceStatus,
          serviceDisplayName
          }
       STATUS      current
       DESCRIPTION
                   "If the status of a service changes, 
                    a trap will be send to the management station 
                    containing the service identifier 
                    and the service status. 
                    Components are treated like services."
       ::= { trapGroup 4 }

   alarmTrap  NOTIFICATION-TYPE
       OBJECTS {
          alarmTableIndex,
          alarmId,
          alarmServiceGuid,
          alarmContainerGuid,
          alarmNodeGuid,
          alarmTitle,
          alarmState,
          alarmSourceGuid,
          alarmSourceName,
          alarmSourceClass,
          alarmTimestampOn,
          alarmTimestampOff,
          alarmTimestampReceived,
          alarmPriority,
          alarmCategory,
          alarmDescription
          }
       STATUS      current
       DESCRIPTION
                   "If an error occurs, there will be checked 
                    if the errorClass is configured to trigger 
                    an immediate signalling. 
                    If so, a trap will be send to the 
                    management station containing 
                    the information shown above."
       ::= { trapGroup 5 }

   resetAlarmTrap  NOTIFICATION-TYPE
       OBJECTS {
          alarmId,
          alarmTableIndex,
          alarmServiceGuid,
          alarmContainerGuid,
          alarmNodeGuid
          }
       STATUS      current
       DESCRIPTION
                   "The described alarm to be reset. 
                   The alarm has to be deleted."
       ::= { trapGroup 6 }
       
   heartBeatTrap NOTIFICATION-TYPE
       STATUS      current
       DESCRIPTION
                   "Heartbeat trap, fired at periodic intervals."
       ::= { trapGroup 7 }                       
        
--************************************************************************-- 
--******                       compliance Group                     ******--
--************************************************************************--    

    compliance MODULE-COMPLIANCE
        STATUS                  current
        DESCRIPTION
            "The compliance statement."
        MODULE -- this module
        MANDATORY-GROUPS { 
          nodeGroupCompliance,  
          applicationGroupCompliance,           
          containerGroupCompliance,
          serviceGroupCompliance,
          alarmGroupCompliance,
          trapGroupCompliance 
          }
        ::= { complianceModules 1 }


    nodeGroupCompliance OBJECT-GROUP
        OBJECTS { 
          numberOfNodeEntries,
          numberOfNodeTraps,
          nodeTable,
          nodeGuid,
          nodeDisplayName,
          nodeIpAddress,
          nodeDescription,
          nodeContact,
          nodeLocation,
          nodeStatus,
          nodeArchitecture,
          nodeOsName,
          nodeOsVersion,
          nodeSnmpAgentVersion,
          nodeMibVersion,
          nodeMgmtURL,
          nodeDocURL,
          nodeIconURL,
          numberOfNodeContainerEntries,
          nodeContainerTable,
          nodeAssocNodeGuid,
          nodeAssocContainerGuid,
          nodeAssocContainerDisplayName
          }
        STATUS                  current
        DESCRIPTION
            "The node group compliance."
        ::= { complianceGroup 1 }

    applicationGroupCompliance OBJECT-GROUP
        OBJECTS { 
          numberOfApplicationEntries,
          numberOfApplicationTraps,
          applicationTable,
          applicationGuid,
          applicationDisplayName,
          applicationDescription,
          applicationVersion,
          applicationContact,          
          applicationStatus,
          applicationMgmtURL,
          applicationDocURL,
          applicationIconURL,
          numberOfApplicationServiceEntries,
          applicationServiceTable,
          applicationAssocApplicationGuid,
          applicationAssocServiceGuid,
          applicationAssocServiceDisplayName
          }
        STATUS                  current
        DESCRIPTION
            "The application group compliance."
        ::= { complianceGroup 2 }

    containerGroupCompliance OBJECT-GROUP
        OBJECTS { 
          numberOfContainerEntries,
          numberOfContainerTraps,
          containerServiceTable,
          containerTable,
          containerGuid,
          containerNodeGuid,
          containerDisplayName,
          containerStatus,
          containerVersion,
          containerMgmtURL,
          containerDocURL,
          containerIconURL,
          numberOfContainerServiceEntries,
          containerAssocContainerGuid,
          containerAssocServiceGuid,
          containerAssocServiceDisplayName
          }
        STATUS                  current
        DESCRIPTION
            "The container group compliance."
        ::= { complianceGroup 3 }
                  
    serviceGroupCompliance OBJECT-GROUP
        OBJECTS { 
          numberOfServiceEntries,
          numberOfServiceTraps, 
          serviceTable,
          serviceGuid,
          serviceContainerGuid,
          serviceNodeGuid,
          serviceDisplayName,
          serviceStatus,
          serviceMgmtURL,
          serviceDocURL,
          serviceIconURL,
          numberOfServiceAlarmEntries,
          serviceAlarmTable,
          serviceAssocServiceGuid,
          serviceAssocAlarmState,
          serviceAssocAlarmIndex,
          serviceAssocAlarmDescription
          }
        STATUS                  current
        DESCRIPTION 
            "The service group compliance."
        ::= { complianceGroup 4 }

    alarmGroupCompliance OBJECT-GROUP
        OBJECTS { 
          numberOfAlarmEntries,
          numberOfAlarmTraps,
          alarmTrapTable,
          alarmTableIndex,
          alarmId,
          alarmServiceGuid,
          alarmContainerGuid,
          alarmNodeGuid,
          alarmTitle,
          alarmState,
          alarmSourceGuid,
          alarmSourceName,
          alarmSourceClass,
          alarmTimestampOn,
          alarmTimestampOff,
          alarmTimestampReceived,
          alarmPriority,
          alarmCategory,
          alarmDescription
          }
        STATUS                  current
        DESCRIPTION
            "The alarm group compliance."
        ::= { complianceGroup 5 }
    
    trapGroupCompliance NOTIFICATION-GROUP
        NOTIFICATIONS {
          nodeStatusChange, 
          applicationStatusChange,
          containerStatusChange, 
          serviceStatusChange,
          alarmTrap, 
          resetAlarmTrap,
          heartBeatTrap 
          }
        STATUS                  current
        DESCRIPTION
            "The trap group compliance."
        ::= {complianceGroup 6 }
        
        
    --*******************************************--
    --******************* END *******************--
    --*******************************************--


END
