--* 01 |030806| new version for SharedServices V1.1.1        |rri |  N   *--
--* 02 |120906| new naming without "svc"       V1.1.2        |rri |  N   *--
--* 03 |240107| comments revised               V1.1.3        |rri |  N   *--
--* 04 |141108| delete DateAndTime             V1.1.4        |ltr |  N   *--
--* 05 |031111| add heartBeatTrap              V1.1.5        |nla |  N   *--
--* 06 |031013| append serviceDisplayName to                 
--*             serviceStatusChange trap       V1.1.6        |nla |  N   *--
--* 07 |160114| change elements definition to                
--*             obsolete for alarmTimestampOff               
--*             and alarmTimestampReceived,                  
--*             enhance description of alarmTrapTable           
--*             element                        V1.1.7        |nla |  N   *--
--* 08 |180314| Modify informational attributes V1.1.8       |nla |  N   *--
--************************************************************************--

   SharedServices-MIB DEFINITIONS ::= BEGIN
 
   IMPORTS
        MODULE-IDENTITY, OBJECT-TYPE, NOTIFICATION-TYPE, Integer32, 
        Counter32 
       FROM SNMPv2-SMI
        TEXTUAL-CONVENTION 
       FROM SNMPv2-TC
        enterprises
       FROM RFC1155-SMI
        OBJECT-GROUP, NOTIFICATION-GROUP, MODULE-COMPLIANCE 
       FROM SNMPv2-CONF ;


-- Some MIB compilers require that the following lines
-- which define the path to this MIB are added.

-- tree              OBJECT IDENTIFIER ::= { iso(1) org(3) dod(6) internet(1) }
-- private           OBJECT IDENTIFIER ::= { tree 4 }
-- enterprises       OBJECT IDENTIFIER ::= { private 1 }
-- siemens           OBJECT IDENTIFIER ::= { enterprises 4329 }
-- com               OBJECT IDENTIFIER ::= { siemens 2 }

   sharedServices        MODULE-IDENTITY
       LAST-UPDATED  "1403180000Z" -- March 18, 2014
       ORGANIZATION  "PH APPS DEVELOPMENT"
       CONTACT-INFO  "Georgios Litsioulis, 
                      Email: georgios.litsioulis@unify.com"
       DESCRIPTION   "SNMP MIB Unify Shared services"
       ::= { com 45 }

   siemens           OBJECT IDENTIFIER ::= { enterprises 4329 }
   com               OBJECT IDENTIFIER ::= { siemens 2 }


   nodeGroup                 OBJECT IDENTIFIER ::= {sharedServices 1}
   applicationGroup          OBJECT IDENTIFIER ::= {sharedServices 2}
   containerGroup            OBJECT IDENTIFIER ::= {sharedServices 3}
   serviceGroup              OBJECT IDENTIFIER ::= {sharedServices 4}
   alarmGroup                OBJECT IDENTIFIER ::= {sharedServices 5}
   trapGroup                 OBJECT IDENTIFIER ::= {sharedServices 90}
   complianceGroup           OBJECT IDENTIFIER ::= {sharedServices 98}
   complianceModules         OBJECT IDENTIFIER ::= {sharedServices 99}

   
--************************************************************************-- 
--******                     textual conventions                    ******--
--************************************************************************-- 

   DisplayString ::= OCTET STRING
       -- This data type is used to model textual information taken
       -- from the NVT ASCII character set.  By convention, objects
       -- with this syntax are declared as having SIZE (0..255)


   Boolean ::=  INTEGER { true(1), false(0) }
       -- encoding for alarm status:
       -- 1 = alarm on
       -- 0 = alarm off


   Severity ::= INTEGER {
                      normal(0),
                      information(1),
                      warning(2),
                      minor(3),
                      major(4),
                      critical(5),
                      unknown(6)
                    }

       -- States for node- /application- /container- and service- groups:
       --                           DisplayString: 
       -- started / executing    =  normal
       -- started / configuring  =  warning
       -- stopped                =  critical

          

--************************************************************************-- 
--******                     Accessible Elements                    ******--
--************************************************************************-- 
 
    --*******************************************--
    --************** Node Group *****************--
    --*******************************************--

    numberOfNodeEntries  OBJECT-TYPE
        SYNTAX      INTEGER (1..2147483187)
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
                    "The number of entries in the node table."
        ::= { nodeGroup 1 }

    numberOfNodeTraps  OBJECT-TYPE
        SYNTAX      INTEGER (1..2147483187)
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
                    "The number of traps which were sent to signal 
                    status changes of the nodes."
        ::= { nodeGroup 2 }

    nodeTable  OBJECT-TYPE
        SYNTAX      SEQUENCE OF NodeTableEntry
        MAX-ACCESS  accessible-for-notify
        STATUS      current
        DESCRIPTION
                    "This table shows the contents of node entries. 
                    A node is a physical machine hosting 
                    one or more containers."
        ::= { nodeGroup 3 }


    nodeTableEntry  OBJECT-TYPE
        SYNTAX      NodeTableEntry
        MAX-ACCESS  not-accessible
        STATUS      current
        DESCRIPTION
                    "The node table entries."
        INDEX { nodeGuid }
        ::= { nodeTable 1 }


    NodeTableEntry ::= SEQUENCE {
           nodeGuid              DisplayString,
           nodeDisplayName       DisplayString,
           nodeIpAddress         DisplayString,
           nodeDescription       DisplayString,
           nodeContact           DisplayString,
           nodeLocation          DisplayString,
           nodeStatus            DisplayString,
           nodeArchitecture      DisplayString,
           nodeOsName            DisplayString,
           nodeOsVersion         DisplayString,
           nodeSnmpAgentVersion  DisplayString,
           nodeMibVersion        DisplayString,
           nodeMgmtURL           DisplayString,
           nodeDocURL            DisplayString,
           nodeIconURL           DisplayString
        }


    nodeGuid OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
            "The unique identifier of the node."
        ::= { nodeTableEntry 1 }

    nodeDisplayName OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
            "The nodename." 
        ::= { nodeTableEntry 2 }
    
    nodeIpAddress OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
            "The ip address of the node." 
        ::= { nodeTableEntry 3 }

    nodeDescription OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
            "A description of the node."
        ::= { nodeTableEntry 4 }
    
    nodeContact OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
            "The responsible administrator."
        ::= { nodeTableEntry 5 }

    nodeLocation OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
           "The location of the node."
        ::= { nodeTableEntry 6 }

    nodeStatus OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
           "The status of the node. 
           Possible values are: normal, warning, critical."
        ::= { nodeTableEntry 7 }

    nodeArchitecture OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
            "The architecture of the node, 
            e.g. x86, sunUltra, ..."
        ::= { nodeTableEntry 8 }
    
    nodeOsName OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
            "The name of the operating system, 
            e.g. Windows, Linux, ..."
        ::= { nodeTableEntry 9 }
    
    nodeOsVersion OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
            "The version of the operating system."
        ::= { nodeTableEntry 10 }

    nodeSnmpAgentVersion OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
            "The version of the SNMP agent."
        ::= { nodeTableEntry 11 }
        
    nodeMibVersion OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
            "The version of the Management Information Base." 
        ::= { nodeTableEntry 12 }
    
    nodeMgmtURL OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
            "Points to a page with gives access to the 
            configuration manager of the node if available."
        ::= { nodeTableEntry 13 }
    
    nodeDocURL OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
            "Points to the documentation."
        ::= { nodeTableEntry 14 }

    nodeIconURL OBJECT-TYPE
        SYNTAX                  DisplayString
        MAX-ACCESS              read-only
        STATUS                  current
        DESCRIPTION
            "Points to a file, which describes the location of the 
            shape and the pixmaps for the icons to be used to display 
            the node on the desktop map."
        ::= { nodeTableEntry 15 }
        

    --********* Associated container ***********--

    numberOfNodeContainerEntries  OBJECT-TYPE
        SYNTAX      INTEGER (1..2147483187)
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
                    "The number of containers which 
                    are hosted by the nodes."
        ::= { nodeGroup 4 }

    nodeContainerTable  OBJECT-TYPE
        SYNTAX      SEQUENCE OF NodeContainerTableEntry
        MAX-ACCESS  accessible-for-notify
        STATUS      current
        DESCRIPTION
