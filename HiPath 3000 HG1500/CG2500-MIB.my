--------------------------
--  H323 Stack Parameters
--------------------------




-- ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
--                                                                        |
--        The HXG3 SNMP Traps                                             |
--                                                                        |
-- ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

	gwTrapGroup       OBJECT IDENTIFIER ::= { gwApplications 8 }


		--
		-- Trap objects
		--

-- This is the "classic" RG2500 trap
	tisTrap NOTIFICATION-TYPE
		OBJECTS  { trapNum,trapText,trapType,gwtrapSeverity }
		STATUS	current
		DESCRIPTION
			"Indicates a problem with the RG2500 software. Sent when the Admin
			server detects a trapable event in the event log."
		::= {gwTrapGroup 1}

	gwStartup NOTIFICATION-TYPE
		OBJECTS  { trapNum,trapText,trapType,gwtrapSeverity }
		STATUS	current
		DESCRIPTION
			"Indicates the startup of HG1500."
		::= {gwTrapGroup 3}

	gwReboot NOTIFICATION-TYPE
		OBJECTS  { trapNum,trapText,trapType,gwtrapSeverity }
		STATUS	current
		DESCRIPTION
			"Indicates the reboot of HG1500."
		::= {gwTrapGroup 4}

	gwThreshold NOTIFICATION-TYPE
		OBJECTS  { trapNum,trapText,trapType,gwtrapSeverity }
		STATUS	current
		DESCRIPTION
			"Indicates that a threshold has reached in HG1500."
		::= {gwTrapGroup 5}

	gwWanLinkUp NOTIFICATION-TYPE
		OBJECTS  { trapNum,trapText,trapType,gwtrapSeverity }
		STATUS	current
		DESCRIPTION
			"Indicates a WAN Linkup of HG1500."
		::= {gwTrapGroup 6}

	gwWanLinkDown NOTIFICATION-TYPE
		OBJECTS  { trapNum,trapText,trapType,gwtrapSeverity }
		STATUS	current
		DESCRIPTION
			"Indicates a WAN Linkdown of HG1500."
		::= {gwTrapGroup 7}

	gwIpLinkUp NOTIFICATION-TYPE
		OBJECTS  { trapNum,trapText,trapType,gwtrapSeverity }
		STATUS	current
		DESCRIPTION
			"Indicates an IP Link up of HG1500."
		::= {gwTrapGroup 8}

	gwIpLinkDown NOTIFICATION-TYPE
		OBJECTS  { trapNum,trapText,trapType,gwtrapSeverity }
		STATUS	current
		DESCRIPTION
			"Indicates an IP Linkdown of HG1500."
		::= {gwTrapGroup 9}

	gwAuxTrap NOTIFICATION-TYPE
		OBJECTS  { trapNum,trapText,trapType,gwtrapSeverity }
		STATUS	current
		DESCRIPTION
			"Indicates an auxiliary trap of HG1500."
		::= {gwTrapGroup 10}

--
--
	trapNum OBJECT-TYPE
		SYNTAX  DisplayString
		MAX-ACCESS  read-only
		STATUS      current
		DESCRIPTION
			"Used for traps - defines a software error number - use with
			type of trap and info like software component ID or board/port
			to isolate exact error."
		::= { gwApplications 9 }

	trapText OBJECT-TYPE
		SYNTAX DisplayString
		MAX-ACCESS  read-only
		STATUS      current
		DESCRIPTION
			"Used for traps - defines text to be sent up with the trap."
		::= { gwApplications 10 }

	trapType OBJECT-TYPE
		SYNTAX INTEGER { software(1), 
		                 hardware(2),
		                 startup(3),
		                 reboot(4),
		                 threshold(5),
		                 wanLinkUp(6),
		                 wanLinkDown(7),
		                 ipLinkUp(8),
		                 ipLinkDown(9),
		                 auxTrap(10) }
		MAX-ACCESS read-only
		STATUS	   current
		DESCRIPTION
			"Used for traps - the type of error occurred."
		::= { gwApplications 11 }

	gwtrapSeverity OBJECT-TYPE
		SYNTAX  DisplayString
		MAX-ACCESS  read-only
		STATUS      current
		DESCRIPTION
			"Used for traps - defines the severity of the trap."
		::= { gwApplications 12 }




END
