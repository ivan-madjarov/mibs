          gwApplications        OBJECT IDENTIFIER ::= { gwMSCandApplications 2 }

	 --  This is the TIS-2.0 Gateway data.  

		-- Section 2.1 - Board Configuration

         	deviceConfiguration        OBJECT IDENTIFIER ::= { gwApplications 1 }

		--
		-- ** 2.1.1 Table Definitions for the Board Data
		-- 
--------------------------
-- SCND device table:
--------------------------

--------------------------
-- LAN device table:
--------------------------

--------------------------
-- SCNA device table:
--------------------------

         	deviceResourceStatistics        OBJECT IDENTIFIER ::= { gwApplications 2 }
--                     merge of scnResMgmt and lanfaxResMgmt
--	scnResMgmt		OBJECT IDENTIFIER ::= {msc 5}
--	lanfaxResMgmt		OBJECT IDENTIFIER ::= {msc 6}

	deviceResourceMgmtTable OBJECT-TYPE
		SYNTAX  SEQUENCE OF DeviceResourceMgmtEntry
		MAX-ACCESS  not-accessible
		STATUS  current
		DESCRIPTION
			"Device resource management statistics table "
	::= { deviceResourceStatistics 1 }

	deviceResourceMgmtEntry OBJECT-TYPE
		SYNTAX DeviceResourceMgmtEntry
		MAX-ACCESS not-accessible
		STATUS current
		DESCRIPTION
			" "
		INDEX {deviceId}
	::= {deviceResourceMgmtTable 1}

	DeviceResourceMgmtEntry ::= SEQUENCE
	{
		deviceId  		        INTEGER,
		devMaxChannels		        Integer32,
		devSeizedChannels	        Integer32
	}

	deviceId OBJECT-TYPE
		SYNTAX INTEGER { devIdISDNSubs(0), 
		                 devIdISDNTrunk(1),
		                 devIdHFA(2),
		                 devIdPayload(3),
		                 devIdMoH(4),
--
		                 devHXG3RTP(5),
		                 devHXG3Fax(6),
		                 devHXG3PPP(7),
		                 devHXG3Vcapi(8),
--
		                 devIdWAML(10),
		                 devIdISDNTrunk1(11),
		                 devIdISDNTrunk2(12),
		                 devIdISDNTrunk3(13),
		                 devIdISDNTrunk4(14),
		                 devIdDMC(15),
		                 devIdRTP(100),
		                 devIdFax(101),
		                 devIdPPP(102),
		                 devIdVcapi(103),
		                 devIdNu(104),
		                 devIdLegk(105),
		                 devIdUnused(106) }
		MAX-ACCESS read-only
		STATUS current
		DESCRIPTION
			"unique id of a device."
		::= { deviceResourceMgmtEntry 1 }

	devMaxChannels OBJECT-TYPE
		SYNTAX Integer32
		MAX-ACCESS read-only
		STATUS current
		DESCRIPTION
			"Effective max. number of useable channels."
		::= { deviceResourceMgmtEntry 2 }

	devSeizedChannels OBJECT-TYPE
		SYNTAX Integer32
		MAX-ACCESS read-only
		STATUS current
		DESCRIPTION
			"Number of channels currently in use."
		::= { deviceResourceMgmtEntry 3 }


--------------------------
--  Gateway Parameters
--------------------------

	gwParameters        OBJECT IDENTIFIER ::= { gwApplications 3 }


		--
		-- Trace objects
		--


	gwGlobalTrace OBJECT IDENTIFIER ::= { gwParameters 2 }

		
	gwGlobalTraceID OBJECT-TYPE
		SYNTAX Integer32
		MAX-ACCESS	read-write
		STATUS	current
		DESCRIPTION
			" "
		::= { gwGlobalTrace 1 }
		
	gwConsoleTraceOnOff OBJECT-TYPE
		SYNTAX BooleanValue
		MAX-ACCESS	read-write
		STATUS	current
		DESCRIPTION
			"Switch whole console tracing on or off."
		::= { gwGlobalTrace 2 }
		
	gwFileTraceOnOff OBJECT-TYPE
		SYNTAX BooleanValue
		MAX-ACCESS	read-write
		STATUS	current
		DESCRIPTION
			"Switch whole file tracing on or off."
		::= { gwGlobalTrace 3 }
		
	gwTraceMaxFileSize OBJECT-TYPE
		SYNTAX Integer32
		MAX-ACCESS	read-only
		STATUS	current
		DESCRIPTION
			"Maximum size of trace file. "
		::= { gwGlobalTrace 4 }
		
	gwTraceTimerValue OBJECT-TYPE
		SYNTAX Integer32
		MAX-ACCESS	read-only
		STATUS	current
		DESCRIPTION
			"Timer for tracing. "
		::= { gwGlobalTrace 5 }
		
	gwTraceMaxBuffSize OBJECT-TYPE
		SYNTAX Integer32
		MAX-ACCESS	read-only
		STATUS	current
		DESCRIPTION
			"Maximum buffer size for tracing. "
		::= { gwGlobalTrace 6 }
		


	gwEventLog OBJECT IDENTIFIER ::= { gwParameters 4 }

	gwTrapGenerationTbl OBJECT-TYPE
		SYNTAX SEQUENCE OF GwTrapGenerationEntry
		MAX-ACCESS not-accessible
		STATUS current
		DESCRIPTION
			"The trap generation table indicates for which events traps
			are generated and for which not."
		::= { gwEventLog 1 }

	gwTrapGenerationEntry OBJECT-TYPE
		SYNTAX GwTrapGenerationEntry
		MAX-ACCESS not-accessible
		STATUS current
		DESCRIPTION
			"An entry in the trap generation table for a particular event."
		INDEX { gwTrapEventID }
		::= { gwTrapGenerationTbl 1 }

	GwTrapGenerationEntry ::= SEQUENCE
	{
		gwTrapEventID	Integer32,
		gwTrapEventName OCTET STRING,
		gwTrapType	Integer32,
		gwTrapFlag	BooleanValue,
		gwRebootFlag	BooleanValue,
		gwRebootType	Integer32,
		gwTrapGenRowCmd RowCmd
	}

	gwTrapEventID OBJECT-TYPE
		SYNTAX Integer32
		MAX-ACCESS read-create
		STATUS current
		DESCRIPTION
			"This index of the trap generation table identifies a particular event."
		::= { gwTrapGenerationEntry 1 }

	gwTrapEventName OBJECT-TYPE
		SYNTAX OCTET STRING (SIZE (0..64))
		MAX-ACCESS read-create
		STATUS current
		DESCRIPTION
			" "
		::= { gwTrapGenerationEntry 2 }

	gwTrapType OBJECT-TYPE
		SYNTAX Integer32
		MAX-ACCESS read-create
		STATUS current
		DESCRIPTION
			"This determines whether a trap is generated for that event or not."
		::= { gwTrapGenerationEntry 3 }

	gwTrapFlag OBJECT-TYPE
		SYNTAX BooleanValue
		MAX-ACCESS read-create
		STATUS current
		DESCRIPTION
			" "
		::= { gwTrapGenerationEntry 4 }

	gwRebootFlag OBJECT-TYPE
		SYNTAX BooleanValue
		MAX-ACCESS read-create
		STATUS current
		DESCRIPTION
			" "
		::= { gwTrapGenerationEntry 5 }

	gwRebootType OBJECT-TYPE
		SYNTAX Integer32
		MAX-ACCESS read-create
		STATUS current
		DESCRIPTION
			"This determines whether a trap is generated for that event or not."
		::= { gwTrapGenerationEntry 6 }

	gwTrapGenRowCmd OBJECT-TYPE
		SYNTAX RowCmd
		MAX-ACCESS read-create
		STATUS current
		DESCRIPTION
			"Setting this to destroy will delete this entry."
		::= { gwTrapGenerationEntry 7 }

