    srCacheTable OBJECT IDENTIFIER ::= { sanResourceEntry 18 }
    
    srCacheInfoEntry    OBJECT-TYPE
        SYNTAX  SRCacheInfo
        ACCESS  not-accessible
        STATUS  mandatory
        DESCRIPTION
            "Information about the configuration and usage of the cache resource."
