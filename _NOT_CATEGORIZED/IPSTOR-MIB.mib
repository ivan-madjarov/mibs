	replicaResources OBJECT IDENTIFIER ::= { logicalResources 6 }

	numOfReplica    OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The amount of replica resources created by the IPStor server."
	::= { replicaResources 1 }
	
	replicaResourceTable    OBJECT-TYPE
		SYNTAX  SEQUENCE OF ReplicaResourceList
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"A table containing the replica resources."
	::= { replicaResources 2 }

	replicaResourceEntry    OBJECT-TYPE
		SYNTAX	ReplicaResourceList
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"Information about the policy and configuration of the replication function."
		INDEX { rrIndex }
	::= { replicaResourceTable 1 }

	ReplicaResourceList ::= SEQUENCE {
		rrIndex                 	INTEGER,
		rrVirtualID             	INTEGER,
		rrVirtualName           	DisplayString,
		rrAllocationType       		DisplayString,
		rrSectors               	Counter32,
		rrTotalSize             	Counter32,
		rrConfigurationStatus   	DisplayString,
		rrGUID                  	DisplayString,
		rrPrimaryVirtualID      	DisplayString,
		rrReplicationStatus     	DisplayString,
		rrLastStartTime         	DisplayString,
		rrMirrorSyncStatus      	DisplayString,
		rrWriteCache			DisplayString,
		rrThinProvisionOption		DisplayString,
		rrThinProvisionCurrAllocSize		Counter32,
		rrThinProvisionUsageSize		Counter32,
		rrThinProvisionUsagePercentage		DisplayString,
		rrTotalSizeQuantity             	Counter32,
		rrTotalSizeUnit		             	INTEGER,
		rrThinProvisionCurrAllocSizeQuantity	Counter32,
		rrThinProvisionCurrAllocSizeUnit	INTEGER,
		rrThinProvisionUsageSizeQuantity	Counter32,
		rrThinProvisionUsageSizeUnit		INTEGER,
		rrSectors64               		Counter64,
		rrTotalSize64             		Counter64,
		rrThinProvisionCurrAllocSize64		Counter64,
		rrThinProvisionUsageSize64		Counter64,
		rrLastSuccessSyncTime			DisplayString,
		rrAverageThroughput			Counter32,
		rrAverageThroughputQuantity		Counter32,
		rrAverageThroughputUnit			INTEGER
	}

	rrIndex OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The sequential digit number as a index key of the replica resource table."
	::= { replicaResourceEntry 1 }
	
	rrVirtualID OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The resource ID assigned by the IPStor server."
	::= { replicaResourceEntry 2 }

	rrVirtualName   OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The resource name created by the user."
	::= { replicaResourceEntry 3 }

	rrAllocationType    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It represents the resource type when user allocating the resource."
	::= { replicaResourceEntry 4 }

	rrSectors   OBJECT-TYPE
		SYNTAX	Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of sectors allocated by the resource."
	::= { replicaResourceEntry 5 }

	rrTotalSize OBJECT-TYPE
		SYNTAX	Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of device size which is representing with megabyte unit of the resource."
	::= { replicaResourceEntry 6 }

	rrConfigurationStatus   OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It represents the attaching status of the resource."
	::= { replicaResourceEntry 7 }

	rrGUID  OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The GUID string of the replica resource."
	::= { replicaResourceEntry 8 }

	rrPrimaryVirtualID  OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It represents the source replication server and device as the format <hostname of source>:<virtual device id>,
			 if the replication option is enabled of the resource."
	::= { replicaResourceEntry 9 }

	rrReplicationStatus OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It represents the current status(Replication failed, New, Idle, and Merging) of the replication schedule."
	::= { replicaResourceEntry 10 }

	rrLastStartTime OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The latest timestamp of the replication."
	::= { replicaResourceEntry 11 }

	rrMirrorSyncStatus  OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It represents the mirror synchronization status of the resource."
	::= { replicaResourceEntry 12 }

	rrWriteCache  OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It represents the write cache option is enable or disable of the resource."
	::= { replicaResourceEntry 13 }

	rrThinProvisionOption  OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It represents the thin provisioning option is enable or disable of the resource."
	::= { replicaResourceEntry 14 }

	rrThinProvisionCurrAllocSize   OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The current Allocated Size of the resource which enables thin provisioning."
	::= { replicaResourceEntry 15 }

	rrThinProvisionUsageSize   OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The current usage size of the resource which enables thin provisioning."
	::= { replicaResourceEntry 16 }

	rrThinProvisionUsagePercentage   OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The current usage percentage of the resource which enables thin provisioning."
	::= { replicaResourceEntry 17 }

	rrTotalSizeQuantity OBJECT-TYPE
		SYNTAX	Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of device size quantity of the resource."
	::= { replicaResourceEntry 18 }

	rrTotalSizeUnit OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of device size unit of the resource.0
presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
	::= { replicaResourceEntry 19 }

	rrThinProvisionCurrAllocSizeQuantity   OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The current Allocated Size quantity of the resource which enables thin provisioning."
	::= { replicaResourceEntry 20 }

	rrThinProvisionCurrAllocSizeUnit   OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The current Allocated Size unit of the resource which enables thin provisioning. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
	::= { replicaResourceEntry 21 }

	rrThinProvisionUsageSizeQuantity   OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The current usage size quantity of the resource which enables thin provisioning."
	::= { replicaResourceEntry 22 }

	rrThinProvisionUsageSizeUnit   OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The current usage size unit of the resource which enables thin provisioning. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
	::= { replicaResourceEntry 23 }

	rrSectors64   OBJECT-TYPE
		SYNTAX	Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of sectors allocated by the resource."
	::= { replicaResourceEntry 24 }

	rrTotalSize64 OBJECT-TYPE
		SYNTAX	Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of device size which is representing with megabyte unit of the resource."
	::= { replicaResourceEntry 25 }

	rrThinProvisionCurrAllocSize64   OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The current Allocated Size of the resource which enables thin provisioning."
	::= { replicaResourceEntry 26 }

	rrThinProvisionUsageSize64   OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The current usage size of the resource which enables thin provisioning."
	::= { replicaResourceEntry 27 }

	rrLastSuccessSyncTime OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The last successful synchronize timestamp of the replication."
	::= { replicaResourceEntry 28 }
    
	rrAverageThroughput   OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The average throughput (MB/s) of the replication."
	::= { replicaResourceEntry 29 }

	rrAverageThroughputQuantity  OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The average throughput quantity of the replication."
	::= { replicaResourceEntry 30 }

	rrAverageThroughputUnit  OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The average throughput unit of the replication. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
	::= { replicaResourceEntry 31 }

	replicaPhyAllocLayoutTable  OBJECT-TYPE
		SYNTAX  SEQUENCE OF ReplicaPhyAllocLayout
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"A table containging the physical layout information for the replica resources."
	::= { replicaResources 3 }

	replicaPhyAllocLayoutEntry  OBJECT-TYPE
		SYNTAX  ReplicaPhyAllocLayout
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"Information about the physical devices which are reserved and created by replica resource."
		INDEX { rrpaIndex }
	::= { replicaPhyAllocLayoutTable 1 }

	ReplicaPhyAllocLayout ::= SEQUENCE {
		rrpaIndex		INTEGER,
		rrpaVirtualID		INTEGER,
		rrpaVirtualName		DisplayString,
		rrpaName		DisplayString,
		rrpaType		DisplayString,
		rrpaSCSIAddress		DisplayString,
		rrpaFirstSector		Counter32,
		rrpaLastSector		Counter32,
		rrpaSize		Counter32,
		rrpaSizeQuantity	Counter32,
		rrpaSizeUnit		INTEGER,
		rrpaFirstSector64	Counter64,
		rrpaLastSector64	Counter64,
		rrpaSize64		Counter64
	}

	rrpaIndex   OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The sequential digit number as a index key of the physical layout table."
	::= { replicaPhyAllocLayoutEntry 1 }

	rrpaVirtualID   OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The replica resource ID assigned by the IPStor server."
	::= { replicaPhyAllocLayoutEntry 2 }

	rrpaVirtualName OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The replica resource name created by the user."
	::= { replicaPhyAllocLayoutEntry 3 }

	rrpaName    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The physical device name."
	::= { replicaPhyAllocLayoutEntry 4 }
	
	rrpaType    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It represents the type(Primary, or Mirror) of the physical layout."
	::= { replicaPhyAllocLayoutEntry 5 }

	rrpaSCSIAddress OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI address with <Adapter:Channel:SCSI:LUN> format of the replica resource."
	::= { replicaPhyAllocLayoutEntry 6 }

	rrpaFirstSector OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The first sector of the physical device which is allocated by the replica resource."
	::= { replicaPhyAllocLayoutEntry 7 }

	rrpaLastSector  OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The last sector of the physical device which is allocated by the replica resource."
	::= { replicaPhyAllocLayoutEntry 8 }
		
	rrpaSize    OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of the allocated size which is representing with megabyte unit within a physical device."
	::= { replicaPhyAllocLayoutEntry 9 }
		
	rrpaSizeQuantity    OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of the allocated size quantity within a physical device."
	::= { replicaPhyAllocLayoutEntry 10 }
		
	rrpaSizeUnit    OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of the allocated size unit within a physical device. The size unit of the device. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
	::= { replicaPhyAllocLayoutEntry 11 }

	rrpaFirstSector64 OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The first sector of the physical device which is allocated by the replica resource."
	::= { replicaPhyAllocLayoutEntry 12 }

	rrpaLastSector64  OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The last sector of the physical device which is allocated by the replica resource."
	::= { replicaPhyAllocLayoutEntry 13 }
		
	rrpaSize64    OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of the allocated size which is representing with megabyte unit within a physical device."
	::= { replicaPhyAllocLayoutEntry 14 }

    snapshotgroupResources OBJECT IDENTIFIER ::= { logicalResources 7 }

    numOfGroup  OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The amount of snapshot groups created by the IPStor server."
    ::= { snapshotgroupResources 1 }
    
    snapshotgroupInfoTable  OBJECT-TYPE
        SYNTAX  SEQUENCE OF SSGResourcesInfo
        ACCESS  not-accessible
        STATUS  mandatory
        DESCRIPTION
            "A table containing the whole types of snapshot groups created by the IPStor server."
    ::= { snapshotgroupResources 2 }
    
    snapshotgroupResourcesInfoEntry OBJECT-TYPE
        SYNTAX  SSGResourcesInfo
        ACCESS  not-accessible
        STATUS  mandatory
        DESCRIPTION
            "Information about the snapshot groups include timemark, backup, and replication properties."
        INDEX { snapshotgroupIndex }
    ::= { snapshotgroupInfoTable 1 }

    SSGResourcesInfo ::= SEQUENCE {
        snapshotgroupIndex                  INTEGER,
        snapshotgroupName                   DisplayString,
        snapshotgroupType                   DisplayString,
--      snapshotgroupTimeMarkInfoTable      OBJECT IDENTIFIER,
--      snapshotgroupBackupInfoTable        OBJECT IDENTIFIER,
--      snapshotgroupReplicationInfoTable   OBJECT IDENTIFIER,
	snapshotgroupMembers		    Counter32,
	snapshotgroupAssignClients	    Counter32,
        snapshotgroupCacheOption            DisplayString,
        snapshotgroupReplicationOption	    DisplayString,
        snapshotgroupTimeMarkOption         DisplayString,
        snapshotgroupCDPOption              DisplayString,
        snapshotgroupBackupOption           DisplayString,
        snapshotgroupSnapShotOption         DisplayString
    }
    
    snapshotgroupIndex  OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The snapshot group resource ID assigned by the IPStor server."
    ::= { snapshotgroupResourcesInfoEntry 1 }

    snapshotgroupName   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The snapshot group resource name created by the user."
    ::= { snapshotgroupResourcesInfoEntry 2 }

    snapshotgroupType   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The property of the snapshot group, which it can be one of the following types.
             timemark, backup, replication, timemark + backup, timemark + replication, backup + replication, and timmemark + backup + replication."	
    ::= { snapshotgroupResourcesInfoEntry 3 }

    snapshotgroupTimeMarkInfoTable OBJECT-TYPE
        SYNTAX  SEQUENCE OF SSGTimeMarkInfo
        ACCESS  not-accessible
        STATUS  mandatory
        DESCRIPTION
            "A table containing the timemark properties of snapshot groups."
    ::= { snapshotgroupResourcesInfoEntry 4 }
    
    snapshotgroupTimeMarkInfoTableEntry OBJECT-TYPE
        SYNTAX  SSGTimeMarkInfo
        ACCESS  not-accessible
        STATUS  mandatory
        DESCRIPTION
            "Information about the policy and configuration of the timemark function."
        INDEX { snapshotgroupTimeMarkGroupID }
    ::= { snapshotgroupTimeMarkInfoTable 1 }
    
    SSGTimeMarkInfo ::= SEQUENCE {
        snapshotgroupTimeMarkGroupID			INTEGER,
        snapshotgroupTimeMarkInfoOption			DisplayString,
        snapshotgroupTimeMarkCounts			INTEGER,
        snapshotgroupTimeMarkSchedule			DisplayString,
        snapshotgroupTimeMarkSnapshotImage		DisplayString,
	snapshotgroupTimeMarkSnapshotNotificationOption	DisplayString,
	snapshotgroupTimeMarkReplicationOption		DisplayString
    }
    
    snapshotgroupTimeMarkGroupID    OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The snapshot group resource ID assigned by the IPStor server."
    ::= { snapshotgroupTimeMarkInfoTableEntry 1 }
    
    snapshotgroupTimeMarkInfoOption OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the timemark option is enable or disable of the snapshot group resource."
    ::= { snapshotgroupTimeMarkInfoTableEntry 2 }
    
    snapshotgroupTimeMarkCounts OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The maximum timemarks that is allowed to create of the snapshot group resource."
    ::= { snapshotgroupTimeMarkInfoTableEntry 3 }
    
    snapshotgroupTimeMarkSchedule   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The time interval creates one new timemark."
    ::= { snapshotgroupTimeMarkInfoTableEntry 4 }
    
    snapshotgroupTimeMarkSnapshotImage  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The time of each day creates snapshot-image automatically."
    ::= { snapshotgroupTimeMarkInfoTableEntry 5 }

    snapshotgroupTimeMarkSnapshotNotificationOption OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The option of triggering snapshot notification schedule."
    ::= { snapshotgroupTimeMarkInfoTableEntry 6 }

    snapshotgroupTimeMarkReplicationOption OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The replication option after the timemark is taken."
    ::= { snapshotgroupTimeMarkInfoTableEntry 7 }

    snapshotgroupBackupInfoTable OBJECT-TYPE
        SYNTAX  SEQUENCE OF SSGBackupInfo
        ACCESS  not-accessible
        STATUS  mandatory
        DESCRIPTION
            "A table containing the backup properties of snapshot groups."
    ::= { snapshotgroupResourcesInfoEntry 5 }
    
    snapshotgroupBackupInfoTableEntry    OBJECT-TYPE
        SYNTAX  SSGBackupInfo
        ACCESS  not-accessible
        STATUS  mandatory
        DESCRIPTION
            "Information about the policy and configuration of the backup function."
        INDEX { snapshotgroupBackupGroupID }
    ::= { snapshotgroupBackupInfoTable 1 }
    
    SSGBackupInfo ::= SEQUENCE {
        snapshotgroupBackupGroupID          INTEGER,
        snapshotgroupBackupInfoOption       DisplayString,
        snapshotgroupBackupWindow           DisplayString,
        snapshotgroupBackupSessionLen       DisplayString,
        snapshotgroupBackupRelativeTime     DisplayString,
        snapshotgroupBackupWaitTime         INTEGER,
        snapshotgroupBackupSelectCriteria   DisplayString
    }
    
    snapshotgroupBackupGroupID  OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The snapshot group resource ID assigned by the IPStor server."
    ::= { snapshotgroupBackupInfoTableEntry 1 }
    
    snapshotgroupBackupInfoOption   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the backup option is enable or disable of the snapshot group resource."
    ::= { snapshotgroupBackupInfoTableEntry 2 }
    
    snapshotgroupBackupWindow   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The daytime allows for opening one backup sesion."
    ::= { snapshotgroupBackupInfoTableEntry 3 }
    
    snapshotgroupBackupSessionLen   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The time interval allows for one backup session in each time."
    ::= { snapshotgroupBackupInfoTableEntry 4 }
    
    snapshotgroupBackupRelativeTime OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The time interval waits before closing the backup session which is in inactivity status."
    ::= { snapshotgroupBackupInfoTableEntry 5 }
    
    snapshotgroupBackupWaitTime OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The time interval which is represnting in minute unit waits before closing the backup session after completion."
    ::= { snapshotgroupBackupInfoTableEntry 6 }
    
    snapshotgroupBackupSelectCriteria   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The snapshot image selection criteria that could be new or latest for the backup session.
             New represents that it always creates new snapshot image for backup, and 
             Latest represents that it uses the last created snapshot image for backup."
    ::= { snapshotgroupBackupInfoTableEntry 7 }

    snapshotgroupReplicationInfoTable    OBJECT-TYPE
        SYNTAX  SEQUENCE OF SSGReplicationInfo
        ACCESS  not-accessible
        STATUS  mandatory
        DESCRIPTION
            "A table containing the replication properties of snapshot groups."
    ::= { snapshotgroupResourcesInfoEntry 6 }
    
    snapshotgroupReplicationInfoTableEntry OBJECT-TYPE
        SYNTAX  SSGReplicationInfo
        ACCESS  not-accessible
        STATUS  mandatory
        DESCRIPTION
            "Information about the policy and configuration of the replication function."
        INDEX { snapshotgroupReplicationGroupID }
    ::= { snapshotgroupReplicationInfoTable 1 }
    
    SSGReplicationInfo ::= SEQUENCE {
        snapshotgroupReplicationGroupID			INTEGER,
        snapshotgroupReplicationInfoOption		DisplayString,
        snapshotgroupReplicaServer			DisplayString,
        snapshotgroupReplicaGroupID			INTEGER,
        snapshotgroupReplicaWatermark			DisplayString,
        snapshotgroupReplicaTime			DisplayString,
        snapshotgroupReplicaInterval			DisplayString,
        snapshotgroupReplicaWatermarkRetry		INTEGER,
        snapshotgroupReplicaContinuousMode		DisplayString,
        snapshotgroupReplicaCreatePrimaryTimeMark	DisplayString,
        snapshotgroupReplicaSyncTimeMark		DisplayString,
        snapshotgroupReplicaProtocol			DisplayString,
        snapshotgroupReplicaCompression			DisplayString,
        snapshotgroupReplicaEncryption			DisplayString,
        snapshotgroupReplicaMicroscan			DisplayString,
        snapshotgroupReplicaSyncPriority		INTEGER,
        snapshotgroupReplicaMode			DisplayString,
        snapshotgroupReplicaUseExistTM			DisplayString,
        snapshotgroupReplicaPreserveTM			DisplayString
    }
    
    snapshotgroupReplicationGroupID OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The snapshot group resource ID assigned by the IPStor server."
    ::= { snapshotgroupReplicationInfoTableEntry 1 }
    
    snapshotgroupReplicationInfoOption  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the replication option is enable or disable of the snapshot group resource."
    ::= { snapshotgroupReplicationInfoTableEntry 2 }
    
    snapshotgroupReplicaServer  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The target replia server name."
    ::= { snapshotgroupReplicationInfoTableEntry 3 }
    
    snapshotgroupReplicaGroupID OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The target replica group ID."
    ::= { snapshotgroupReplicationInfoTableEntry 4 }
    
    snapshotgroupReplicaWatermark   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The watermark sets to generate one new replication automatically."
    ::= { snapshotgroupReplicationInfoTableEntry 5 }
    
    snapshotgroupReplicaTime    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The daytime of each day creates one new replication."
    ::= { snapshotgroupReplicationInfoTableEntry 6 }      
    
    snapshotgroupReplicaInterval    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The time interval creates one new replication."
    ::= { snapshotgroupReplicationInfoTableEntry 7 }      

    snapshotgroupReplicaWatermarkRetry OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The retry interval which is representing in minute unit if the replication failed."
    ::= { snapshotgroupReplicationInfoTableEntry 8 }

    snapshotgroupReplicaContinuousMode   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the Continuous Mode of Replication is enable or disable."
    ::= { snapshotgroupReplicationInfoTableEntry 9 }

    snapshotgroupReplicaCreatePrimaryTimeMark    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "This option allows to create the primary TimeMark when a replica TimeMark is created."
    ::= { snapshotgroupReplicationInfoTableEntry 10 }

    snapshotgroupReplicaSyncTimeMark    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "This option allows to synchronize the replica TimeMark when a primary TimeMark is created."
    ::= { snapshotgroupReplicationInfoTableEntry 11 }

    snapshotgroupReplicaProtocol    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "It states the Protocol which Replication uses."
    ::= { snapshotgroupReplicationInfoTableEntry 12 }

    snapshotgroupReplicaCompression    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the Compression option is enable or disable of Replication."
    ::= { snapshotgroupReplicationInfoTableEntry 13 }

    snapshotgroupReplicaEncryption    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the Encryption option is enable or disable of Replication."
    ::= { snapshotgroupReplicationInfoTableEntry 14 }

    snapshotgroupReplicaMicroscan    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the Microscan option is enable or disable of Replication."
    ::= { snapshotgroupReplicationInfoTableEntry 15 }

    snapshotgroupReplicaSyncPriority    OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The Priority setting when Replication Synchronize of the SAN resource."
    ::= { snapshotgroupReplicationInfoTableEntry 16 }

    snapshotgroupReplicaMode    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The Replication mode of the SAN resource."
    ::= { snapshotgroupReplicationInfoTableEntry 17 }

    snapshotgroupReplicaUseExistTM    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "When Continuous Mode is disabled, the option about using existing TimeMark of the replication."
    ::= { snapshotgroupReplicationInfoTableEntry 18 }

    snapshotgroupReplicaPreserveTM    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "When Continuous Mode is disabled, the option about perserving TimeMark of the replication."
    ::= { snapshotgroupReplicationInfoTableEntry 19 }

    snapshotgroupCDPInfoTable OBJECT IDENTIFIER ::= {snapshotgroupResourcesInfoEntry 7 }
    
    snapshotgroupCDPInfoTableEntry    OBJECT-TYPE
        SYNTAX  SSGCDPInfo
        ACCESS  not-accessible
        STATUS  mandatory
        DESCRIPTION
            "Information about the policy and configuration of the cdp function."
        INDEX { snapshotgroupCDPInfoGroupID }
    ::= { snapshotgroupCDPInfoTable 1 }
    
    SSGCDPInfo ::= SEQUENCE {
        snapshotgroupCDPInfoGroupID			INTEGER,
        snapshotgroupCDPInfoOption			DisplayString,
        snapshotgroupCDPInfoTotalSize			Counter32,
        snapshotgroupCDPInfoStatus			DisplayString,
        snapshotgroupCDPInfoPerformanceLevel		DisplayString,
        snapshotgroupCDPInfoAvailableTimerange		DisplayString,
	snapshotgroupCDPInfoUsageSize			Counter32,
	snapshotgroupCDPInfoUsagePercent		Counter32,
	snapshotgroupCDPInfoTotalSizeQuantity		Counter32,
	snapshotgroupCDPInfoTotalSizeUnit		INTEGER,
	snapshotgroupCDPInfoTotalSize64			Counter64,
	snapshotgroupCDPInfoUsageSizeQuantity		Counter32,
	snapshotgroupCDPInfoUsageSizeUnit		INTEGER,
	snapshotgroupCDPInfoUsageSize64			Counter64
    }
    
    snapshotgroupCDPInfoGroupID  OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The snapshot group resource ID assigned by the IPStor server."
    ::= { snapshotgroupCDPInfoTableEntry 1 }
    
    snapshotgroupCDPInfoOption  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the snapshot group CDP Journal option is enable or disable of the IPStor server."
    ::= { snapshotgroupCDPInfoTableEntry 2 }
    
    snapshotgroupCDPInfoTotalSize  OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The total size of snapshot group CDP Journal of the IPStor server."
    ::= { snapshotgroupCDPInfoTableEntry 3 }
    
    snapshotgroupCDPInfoStatus  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
