	sciscsiMutualCHAPSecret	OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The mutual CHAP secret option when authentication enabled of the iSCSI client."
	::= { scISCSIResourceEntry 10 }

	sciscsiInitiatorName	OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The Initiator name of the iSCSI client."
	::= { scISCSIResourceEntry 11 }

	sciscsiInitiatorAccessType	OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The Initiator access type of the iSCSI client."
	::= { scISCSIResourceEntry 12 }

	sciscsiTargetID   OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The target ID belongs to the iSCSI client."
	::= { scISCSIResourceEntry 13 }

	sciscsiTargetName	OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The target name belongs to the iSCSI client."
	::= { scISCSIResourceEntry 14 }

	sciscsiTargetIP		OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The target IP address of the iSCSI client."
