        GSCsanResourceAllocType		DisplayString,
        GSCsanResourceSize		Counter32,
        GSCsanResourceSizeQuantity	Counter32,
        GSCsanResourceSizeUnit		INTEGER,
        GSCsanResourceSize64		Counter64
    }
    
    GSCsanResourceName  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The SAN resource Name which enables the global safe cache."
    ::= { GSCsanResourceInfoEntry 1 }
    
    GSCsanResourceID  OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The SAN resource ID which enables the global safe cache."
    ::= { GSCsanResourceInfoEntry 2 }
    
    GSCsanResourceAllocType  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The SAN resource allocation type which enables the global safe cache."
    ::= { GSCsanResourceInfoEntry 3 }
    
    GSCsanResourceSize  OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The SAN resource size which is representing with megabyte unit enables the global safe cache."
    ::= { GSCsanResourceInfoEntry 4 }
    
    GSCsanResourceSizeQuantity  OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The SAN resource size quantity which enables the global safe cache."
    ::= { GSCsanResourceInfoEntry 5 }
    
    GSCsanResourceSizeUnit  OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The SAN resource size unit which enables the global safe cache. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
    ::= { GSCsanResourceInfoEntry 6 }
    
    GSCsanResourceSize64  OBJECT-TYPE
        SYNTAX  Counter64
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The SAN resource size which is representing with megabyte unit enables the global safe cache."
    ::= { GSCsanResourceInfoEntry 7 }

	GSCPhysicalTotalAllocLayoutTable  OBJECT-TYPE
		SYNTAX SEQUENCE OF GSCPhysicalTotalAllocLayout
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"A table containging the total physical layout information for the global safe cache resources."
	::= { GlobalSafeCache 2 }

	GSCPhysicalTotalAllocLayoutEntry    OBJECT-TYPE
		SYNTAX GSCPhysicalTotalAllocLayout
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"Information about the physical devices allocation layout of global safe cache."
		INDEX { GSCpaAllocSANResourceName }
	::= { GSCPhysicalTotalAllocLayoutTable 1 }

	GSCPhysicalTotalAllocLayout ::= SEQUENCE {
		GSCpaAllocSANResourceName		DisplayString,
		GSCpaAllocName			        DisplayString,
		GSCpaAllocType  		        DisplayString,
		GSCpaAllocAdapterNo		    	INTEGER,
		GSCpaAllocChannelNo		    	INTEGER,
		GSCpaAllocScsiID		        INTEGER,
		GSCpaAllocLun			        INTEGER,
		GSCpaAllocFirstSector		    	Counter32,
		GSCpaAllocLastSector			Counter32,
		GSCpaAllocFirstSector64			Counter64,
		GSCpaAllocLastSector64			Counter64,
		GSCpaAllocSize			        Counter32,
		GSCpaAllocSizeQuantity		        Counter32,
		GSCpaAllocSizeUnit			INTEGER,
		GSCpaAllocSize64			Counter64
	}

	GSCpaAllocSANResourceName    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SAN resource name created by the user which enables the global safe cache."
	::= { GSCPhysicalTotalAllocLayoutEntry 1 }

	GSCpaAllocName    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The physical device name."
	::= { GSCPhysicalTotalAllocLayoutEntry 2 }
	
	GSCpaAllocType OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It represents the type(Primary, or Mirror) of the physical layout."
	::= { GSCPhysicalTotalAllocLayoutEntry 3 }

	GSCpaAllocAdapterNo OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI adapter number of the physical device."
	::= { GSCPhysicalTotalAllocLayoutEntry 4 }

	GSCpaAllocChannelNo OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI channel number of the physical device."
	::= { GSCPhysicalTotalAllocLayoutEntry 5 }

	GSCpaAllocScsiID OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI ID of the physical device."
	::= { GSCPhysicalTotalAllocLayoutEntry 6 }

	GSCpaAllocLun OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI LUN number of the physical device."
	::= { GSCPhysicalTotalAllocLayoutEntry 7 }

	GSCpaAllocFirstSector OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The first sector of the physical device."
	::= { GSCPhysicalTotalAllocLayoutEntry 8 }

	GSCpaAllocLastSector  OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The last sector of the physical device."
	::= { GSCPhysicalTotalAllocLayoutEntry 9 }

	GSCpaAllocFirstSector64 OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The first sector of the physical device."
	::= { GSCPhysicalTotalAllocLayoutEntry 10 }

	GSCpaAllocLastSector64  OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The last sector of the physical device."
	::= { GSCPhysicalTotalAllocLayoutEntry 11 }
		
	GSCpaAllocSize    OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of the allocated size which is representing with megabyte unit within a physical device."
	::= { GSCPhysicalTotalAllocLayoutEntry 12 }
		
	GSCpaAllocSizeQuantity    OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of the allocated size quantity within a physical device."
	::= { GSCPhysicalTotalAllocLayoutEntry 13 }
		
	GSCpaAllocSizeUnit    OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of the allocated size unit within a physical device. The size unit of the device. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
	::= { GSCPhysicalTotalAllocLayoutEntry 14 }
		
	GSCpaAllocSize64    OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of the allocated size which is representing with megabyte unit within a physical device."
	::= { GSCPhysicalTotalAllocLayoutEntry 15 }

    GSCResourceID  OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The Resource ID of the global safe cache."
