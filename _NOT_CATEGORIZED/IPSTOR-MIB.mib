			"The SAN resource name created by the user."
	::= { srISCSIClientInfoEntry 4 }

	srISCSIAccessType    OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The resource access type of the iSCSI client."
	::= { srISCSIClientInfoEntry 5 }
   
	srISCSIConnectAccess OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"Identify the connecting and accessing status with a resource of the iSCSI client."
	::= { srISCSIClientInfoEntry 6 }

	srPhysicalTotalAllocLayoutTable OBJECT IDENTIFIER ::= { sanResourceEntry 29 }

	srPhysicalTotalAllocLayoutEntry OBJECT-TYPE
		SYNTAX  SRPhysicalTotalAllocLayout
		ACCESS  not-accessible
		STATUS  mandatory
		DESCRIPTION
			"Information about the physical devices which are reserved and created by logical SAN resource."
		INDEX { srpaAllocSANResourceName }
	::= { srPhysicalTotalAllocLayoutTable 1 }

	SRPhysicalTotalAllocLayout ::= SEQUENCE {
		srpaAllocSANResourceName		DisplayString,
		srpaAllocName			        DisplayString,
		srpaAllocType  			        DisplayString,
		srpaAllocAdapterNo		    	INTEGER,
		srpaAllocChannelNo		    	INTEGER,
		srpaAllocScsiID			        INTEGER,
		srpaAllocLun			        INTEGER,
		srpaAllocFirstSector		    	Counter32,
		srpaAllocLastSector			Counter32,
		srpaAllocFirstSector64			Counter64,
		srpaAllocLastSector64			Counter64,
		srpaAllocSize			        Counter32,
		srpaAllocSizeQuantity		        Counter32,
		srpaAllocSizeUnit			INTEGER,
		srpaAllocSize64				Counter64
	}

	srpaAllocSANResourceName    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SAN resource name created by the user."
	::= { srPhysicalTotalAllocLayoutEntry 1 }

	srpaAllocName    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The physical device name."
	::= { srPhysicalTotalAllocLayoutEntry 2 }
	
	srpaAllocType OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It represents the type(Primary, or Mirror) of the physical layout."
	::= { srPhysicalTotalAllocLayoutEntry 3 }

	srpaAllocAdapterNo OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI adapter number of the physical device."
	::= { srPhysicalTotalAllocLayoutEntry 4 }

	srpaAllocChannelNo OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI channel number of the physical device."
	::= { srPhysicalTotalAllocLayoutEntry 5 }

	srpaAllocScsiID OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI ID of the physical device."
	::= { srPhysicalTotalAllocLayoutEntry 6 }

	srpaAllocLun OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI LUN number of the physical device."
	::= { srPhysicalTotalAllocLayoutEntry 7 }

	srpaAllocFirstSector OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The first sector of the physical device which is allocated by the SAN resource."
	::= { srPhysicalTotalAllocLayoutEntry 8 }

	srpaAllocLastSector  OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The last sector of the physical device which is allocated by the SAN resource."
	::= { srPhysicalTotalAllocLayoutEntry 9 }

	srpaAllocFirstSector64 OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The first sector of the physical device which is allocated by the SAN resource."
	::= { srPhysicalTotalAllocLayoutEntry 10 }

	srpaAllocLastSector64  OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The last sector of the physical device which is allocated by the SAN resource."
	::= { srPhysicalTotalAllocLayoutEntry 11 }
		
	srpaAllocSize    OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of the allocated size which is representing with megabyte unit within a physical device."
	::= { srPhysicalTotalAllocLayoutEntry 12 }
		
	srpaAllocSizeQuantity    OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of the allocated size quantity within a physical device."
	::= { srPhysicalTotalAllocLayoutEntry 13 }
		
	srpaAllocSizeUnit    OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of the allocated size unit within a physical device. The size unit of the device. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
	::= { srPhysicalTotalAllocLayoutEntry 14 }
		
	srpaAllocSize64    OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of the allocated size which is representing with megabyte unit within a physical device."
	::= { srPhysicalTotalAllocLayoutEntry 15 }

	srHotZonePrefetchInfoTable OBJECT IDENTIFIER ::= { sanResourceEntry 30 }

	srHotZonePrefetchInfoEntry OBJECT-TYPE
		SYNTAX  SRHotZonePrefetchInfo
		ACCESS  not-accessible
		STATUS  mandatory
		DESCRIPTION
			"Information about the HotZone Prefetch if the SAN resources have enabled."
		INDEX { srHotZonePrefetchSANResourceID }
	::= { srHotZonePrefetchInfoTable 1 }

	SRHotZonePrefetchInfo ::= SEQUENCE {
		srHotZonePrefetchSANResourceID		INTEGER,
		srHotZonePrefetchMaximumChains		INTEGER,
		srHotZonePrefetchMaximumReadAhead	INTEGER,
		srHotZonePrefetchReadAhead		INTEGER,
		srHotZonePrefetchChainTimeout		DisplayString,
		srHotZonePrefetchSANResourceName	DisplayString
	}

	srHotZonePrefetchSANResourceID OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The SAN Resource ID that assigned by IPStor server."
	::= { srHotZonePrefetchInfoEntry 1 }

	srHotZonePrefetchMaximumChains OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The maximum number of sequential read chains to detect."
	::= { srHotZonePrefetchInfoEntry 2 }

	srHotZonePrefetchMaximumReadAhead OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The maximum size to read ahead representing with KB."
	::= { srHotZonePrefetchInfoEntry 3 }

	srHotZonePrefetchReadAhead OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The size of read the read command issued when reading ahead representing with KB."
	::= { srHotZonePrefetchInfoEntry 4 }

	srHotZonePrefetchChainTimeout OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The time before the chain is removed and the readahead buffers are freed."
	::= { srHotZonePrefetchInfoEntry 5 }

	srHotZonePrefetchSANResourceName OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The SAN Resource Name that assigned by IPStor server enables the HotZone Prefetch."
	::= { srHotZonePrefetchInfoEntry 6 }

	srHotZoneReadCacheInfoTable OBJECT IDENTIFIER ::= { sanResourceEntry 31 }

	srHotZoneReadCacheInfoEntry OBJECT-TYPE
		SYNTAX  SRHotZoneReadCacheInfo
		ACCESS  not-accessible
		STATUS  mandatory
		DESCRIPTION
			"Information about the HotZone Read Cache if the SAN resources have enabled."
		INDEX { srHotZoneReadCacheResourceID }
	::= { srHotZoneReadCacheInfoTable 1 }

	SRHotZoneReadCacheInfo ::= SEQUENCE {
		srHotZoneReadCacheResourceID		INTEGER,
		srHotZoneReadCacheSANResourceID		INTEGER,
		srHotZoneReadCacheTotalSize		Counter32,
		srHotZoneReadCacheStatus		DisplayString,
		srHotZoneReadCacheSuspended		DisplayString,
		srHotZoneReadCacheAccessType		DisplayString,
		srHotZoneReadCacheAccessIntensity	DisplayString,
		srHotZoneReadCacheMinimumStayTime	DisplayString,
		srHotZoneReadCacheEachZoneSize		DisplayString,
		srHotZoneReadCacheTotalZones		Counter32,
		srHotZoneReadCacheUsedZones		Counter32,
		srHotZoneReadCacheHitRatio		DisplayString,
		srHotZoneReadCacheTotalSizeQuantity	Counter32,
		srHotZoneReadCacheTotalSizeUnit		INTEGER,
		srHotZoneReadCacheTotalSize64		Counter64,
		srHotZoneReadCacheSANResourceID		DisplayString
	}

	srHotZoneReadCacheResourceID OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The Resource ID that assigned by IPStor server."
	::= { srHotZoneReadCacheInfoEntry 1 }

	srHotZoneReadCacheSANResourceID OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The SANResource ID that assigned by IPStor server."
	::= { srHotZoneReadCacheInfoEntry 2 }

	srHotZoneReadCacheTotalSize OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The amount of device size which is representing with megabyte unit of the HotZone read cache resource."
	::= { srHotZoneReadCacheInfoEntry 3 }

	srHotZoneReadCacheStatus OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The status represents current HotZone read cache of the SAN resource."
	::= { srHotZoneReadCacheInfoEntry 4 }

	srHotZoneReadCacheSuspended OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The Suspended status represents current HotZone read cache of the SAN resource."
	::= { srHotZoneReadCacheInfoEntry 5 }

	srHotZoneReadCacheAccessType OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The zone's access type policy of the SAN resource."
	::= { srHotZoneReadCacheInfoEntry 6 }

	srHotZoneReadCacheAccessIntensity OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The access intensity to determine how the zone is accessed."
	::= { srHotZoneReadCacheInfoEntry 7 }

	srHotZoneReadCacheMinimumStayTime OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The minimum time that how long a zone can stay at least in the HotZone before it is swapped out."
	::= { srHotZoneReadCacheInfoEntry 8 }

	srHotZoneReadCacheEachZoneSize OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The size of each zone setting."
	::= { srHotZoneReadCacheInfoEntry 9 }

	srHotZoneReadCacheTotalZones OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The total zones that is allocated of the SAN resource."
	::= { srHotZoneReadCacheInfoEntry 10 }

	srHotZoneReadCacheUsedZones OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The current used zones of the SAN resource."
	::= { srHotZoneReadCacheInfoEntry 11 }

	srHotZoneReadCacheHitRatio OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The hit ratio represents current HotZone read cache of the SAN resource."
	::= { srHotZoneReadCacheInfoEntry 12 }

	srHotZoneReadCacheTotalSizeQuantity OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The amount of device size quantity which is representing with megabyte unit of the HotZone read cache resource."
	::= { srHotZoneReadCacheInfoEntry 13 }

	srHotZoneReadCacheTotalSizeUnit OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The amount of device size unit of the HotZone read cache resource. The size unit of the device. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
	::= { srHotZoneReadCacheInfoEntry 14 }

	srHotZoneReadCacheTotalSize64 OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The amount of device size which is representing with megabyte unit of the HotZone read cache resource."
	::= { srHotZoneReadCacheInfoEntry 15 }

	srHotZoneReadCacheSANResourceName OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The SANResource Name that assigned by IPStor server enables the HotZone ReadCache."
	::= { srHotZoneReadCacheInfoEntry 16 }



            
	nasResources OBJECT IDENTIFIER ::= { logicalResources 4 }

	numOfNASResources   OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The amount of NAS resources are available by the IPStor server."
	::= { nasResources 1 }

	nasResourceTable    OBJECT-TYPE
		SYNTAX  SEQUENCE OF NASResource
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"A table containing the NAS resources information."
	::= { nasResources 2 }

	nasResourceEntry    OBJECT-TYPE
		SYNTAX	NASResource
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"Information about the configurations and properties of the logical NAS resources."
		INDEX { nasResourceID }
	::= { nasResourceTable 1 }

	NASResource ::= SEQUENCE {
		nasResourceID		        INTEGER,
	        nasResourceName 	        DisplayString,
		nrAllocationType	        DisplayString,
		nrTotalSectors			Counter32,
		nrTotalSize			Counter32,
--		nrCategory			DisplayString,
		nrConfigStatus			DisplayString,
		nrMountPath			DisplayString,
		nrStatus			DisplayString,
		nrMirrorSyncStatus		DisplayString,
		nrReplicaDevice			DisplayString,
		nrSnapshotCopyStatus		DisplayString,
--		nrPhysicalAllocLayoutTable	OBJECT IDENTIFIER,
--		nrShareInfoTable         	OBJECT IDENTIFIER,
--      nrSnapShotTable				OBJECT IDENTIFIER,
--      nrTimeMarkTable				OBJECT IDENTIFIER,
--      nrBackupTable				OBJECT IDENTIFIER,
--      nrReplicationTable			OBJECT IDENTIFIER,
--      nrCacheTable				OBJECT IDENTIFIER,
		nrWriteCacheProperty		DisplayString,
--                nrThinProvisionTable            OBJECT IDENTIFIER,
		nrTotalSizeQuantity		Counter32,
		nrTotalSizeUnit			INTEGER,
		nrTotalSectors64	        Counter64,
		nrTotalSize64                 	Counter64
	}

	nasResourceID   OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The NAS resource ID assigned by the IPStor server."
	::= { nasResourceEntry 1 }
	
	nasResourceName OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The NAS resource name created by the user."
	::= { nasResourceEntry 2 }    

	nrAllocationType    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It represents the resource type when user allocating the NAS device."
	::= { nasResourceEntry 3 }

	nrTotalSectors  OBJECT-TYPE
		SYNTAX	Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of sectors allocated by the NAS resource."
	::= { nasResourceEntry 4 }
	
	nrTotalSize OBJECT-TYPE
		SYNTAX	Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of device size which is representing with megabyte unit of the NAS resource."
	::= { nasResourceEntry 5 }

--	nrCategory  OBJECT-TYPE
--		SYNTAX	DisplayString
--		ACCESS	read-only
--		STATUS	mandatory
--		DESCRIPTION
--			"The category of NAS resource"
--	::= { nasResourceEntry 6 }

	nrConfigStatus  OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It represents the attaching status of the NAS resource."
	::= { nasResourceEntry 6 }
	
	nrMountPath OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The mounted path of the NAS resource."
	::= { nasResourceEntry 7 }

	nrStatus    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The status(attached and mounted) of the NAS resource."
	::= { nasResourceEntry 8 }
	
	nrMirrorSyncStatus  OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It represents the mirror synchronization status of the NAS resource."
	::= { nasResourceEntry 9 }

	nrReplicaDevice OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It represents the target replica server and device as the format <hostname of target>:<virtual device id>,
			 if the replication option is enabled of the NAS resource."
	::= { nasResourceEntry 10 }

	nrSnapshotCopyStatus    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The snapshot copy status of the NAS resource."
	::= { nasResourceEntry 11 }

	nrPhysicalAllocLayoutTable  OBJECT-TYPE
		SYNTAX  SEQUENCE OF NRPhysicalAllocLayout
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"A table containging the physical layout information for the NAS resources."
	::= { nasResourceEntry 12 }

	nrphysicalAllocLayoutEntry  OBJECT-TYPE
		SYNTAX  NRPhysicalAllocLayout
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"Information about the physical devices which are reserved and created by logical NAS resource."
		INDEX { nrpaNASResourceID }
	::= { nrPhysicalAllocLayoutTable 1 }

	NRPhysicalAllocLayout ::= SEQUENCE {
		nrpaNASResourceID   	INTEGER,
		nrpaNASResourceName	DisplayString,
		nrpaName		DisplayString,
		nrpaType 		DisplayString,
		nrpaAdapterNo		INTEGER,
		nrpaChannelNo		INTEGER,
		nrpaScsiID		INTEGER,
		nrpaLun			INTEGER,
		nrpaFirstSector		Counter32,
		nrpaLastSector		Counter32,
		nrpaSize		Counter32,
		nrpaSizeQuantity	Counter32,
		nrpaSizeUnit		INTEGER,
		nrpaFirstSector64	Counter64,
		nrpaLastSector64	Counter64,
		nrpaSize64		Counter64
	}

	nrpaNASResourceID   OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The NAS resource ID assigned by the IPStor server."
	::= { nrphysicalAllocLayoutEntry 1 }

	nrpaNASResourceName OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The NAS resource name created by the user."
	::= { nrphysicalAllocLayoutEntry 2 }

	nrpaName    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The physical device name."
	::= { nrphysicalAllocLayoutEntry 3 }
	
	nrpaType    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It represents the type(Primary, or Mirror) of the physical layout."
	::= { nrphysicalAllocLayoutEntry 4 }

	nrpaAdapterNo   OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI adapter number of the physical device."
	::= { nrphysicalAllocLayoutEntry 5 }

	nrpaChannelNo   OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI channel number of the physical device."
	::= { nrphysicalAllocLayoutEntry 6 }

	nrpaScsiID  OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI ID of the physical device."
	::= { nrphysicalAllocLayoutEntry 7 }

	nrpaLun OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI LUN number of the physical device."
	::= { nrphysicalAllocLayoutEntry 8 }

	nrpaFirstSector OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The first sector of the physical device which is allocated by the NAS resource."
	::= { nrphysicalAllocLayoutEntry 9 }

	nrpaLastSector  OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The last sector of the physical device which is allocated by the NAS resource."
	::= { nrphysicalAllocLayoutEntry 10 }
		
	nrpaSize    OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of the allocated size which is representing with megabyte unit within a physical device."
	::= { nrphysicalAllocLayoutEntry 11 }
		
	nrpaSizeQuantity    OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of the allocated size quantity within a physical device."
	::= { nrphysicalAllocLayoutEntry 12 }
		
	nrpaSizeUnit    OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of the allocated size unit within a physical device. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
	::= { nrphysicalAllocLayoutEntry 13 }

	nrpaFirstSector64 OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The first sector of the physical device which is allocated by the NAS resource."
	::= { nrphysicalAllocLayoutEntry 14 }

	nrpaLastSector64  OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The last sector of the physical device which is allocated by the NAS resource."
	::= { nrphysicalAllocLayoutEntry 15 }
		
	nrpaSize64    OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of the allocated size which is representing with megabyte unit within a physical device."
	::= { nrphysicalAllocLayoutEntry 16 }

	nrShareInfoTable    OBJECT-TYPE
		SYNTAX  SEQUENCE OF ShareInfo
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"A table containing share information of the NAS resource, which include Windows and NFS shares."
	::= { nasResourceEntry 13 }

	shareInfoEntry  OBJECT-TYPE
		SYNTAX  ShareInfo
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"Information about the configurations of the sharing NAS resource."
		INDEX { nrsiResourceID }
	::= { nrShareInfoTable 1 }

	ShareInfo ::= SEQUENCE {
		nrsiResourceID		INTEGER,
		nrsiResourceName	DisplayString,
		nrsiRealPath		DisplayString,
		nrsiFolderName		DisplayString,
		nrsiShareName		DisplayString,
		nrsiComment         DisplayString,
		nrsiUsedSpaceSize   INTEGER,
		nrsiMaxConn         INTEGER
--		nrsiMembersTable    OBJECT IDENTIFIER
	}

	nrsiResourceID  OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The NAS resource ID assigned by the IPStor server."
	::= { shareInfoEntry 1 }

	nrsiResourceName    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The NAS resource name created by the user."
	::= { shareInfoEntry 2 }

	nrsiRealPath    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The sharing full path."
	::= { shareInfoEntry 3 }

	nrsiFolderName OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The sharing folder name."
	::= { shareInfoEntry 4 }

	nrsiShareName   OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The share name of the NAS resource."
	::= { shareInfoEntry 5 }

	nrsiComment OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The comments setted by users of one share folder."
	::= { shareInfoEntry 6 }

	nrsiUsedSpaceSize OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The current used size which is representing with kilobyte unit of one share folder."
	::= { shareInfoEntry 7 }

	nrsiMaxConn OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The maximum connections of one share folder is allowed. If the value is 0, it means the unlimited connections"
	::= { shareInfoEntry 8 }

	nrsiMembersTable    OBJECT-TYPE
		SYNTAX  SEQUENCE OF MembersList
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"A table containing all members can access the share folder. If the authentication mode is share-mode, 
			 there is none clients listed due to all of them have the rights when the login password is correct."
	::= { shareInfoEntry 9 }

	membersListEntry    OBJECT-TYPE
		SYNTAX  MembersList
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"Information about the client types and sharing resources."
		INDEX { mlIndex }
	::= { nrsiMembersTable 1 }
	
	MembersList ::= SEQUENCE {
		mlIndex         INTEGER,
		mlResourceName  DisplayString,
		mlFolderName	DisplayString,
		mlClientName	DisplayString,
		mlType          DisplayString,
		mlAccessRight   DisplayString
	}

	mlIndex OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The sequential digit number as a index key of the member list table."
	::= { membersListEntry 1 }
	
	mlResourceName  OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The NAS resource name created by the user."
	::= { membersListEntry 2 }
	
	mlFolderName    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The sharing folder name."
	::= { membersListEntry 3 }
	
	mlClientName    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The client name that the folder is been assigned."
	::= { membersListEntry 4 }
	
	mlType  OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"Identify the client type(Windows user, Windows group, and NFS client) that the folder is been assigned."
	::= { membersListEntry 5 }

	mlAccessRight   OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"Identify the connecting and accessing status with a resource of the client."
	::= { membersListEntry 6 }	

    nrSnapShotTable OBJECT-TYPE
        SYNTAX  SEQUENCE OF NRSnapShotInfo
        ACCESS  not-accessible
        STATUS  mandatory
        DESCRIPTION
            "A table containing the snapshot resources created by the NAS resource."
    ::= { nasResourceEntry 14 }
    
    nrSnapShotInfoEntry OBJECT-TYPE
        SYNTAX  NRSnapShotInfo
        ACCESS  not-accessible
        STATUS  mandatory
        DESCRIPTION
            "Information about the policy and configuration of the snapshot function."
        INDEX { nrSnapShotResourceID }
    ::= { nrSnapShotTable 1 }

    NRSnapShotInfo ::= SEQUENCE {
        nrSnapShotResourceID    INTEGER,
        nrSnapShotResourceName  DisplayString,
        nrSnapShotOption        DisplayString,
        nrSnapShotSize          Counter32,
        nrSnapShotThreshold     INTEGER,
        nrSnapShotReachTH       DisplayString,
        nrSnapShotIncSize       DisplayString,
        nrSnapShotMaxSize       DisplayString,
        nrSnapShotResourceFull  DisplayString,
        nrSnapShotUsedSize      Counter32,
        nrSnapShotFreeSize      Counter32,
        nrSnapShotUsedPercent   INTEGER,
	nrSnapShotMicroscan             DisplayString,
        nrSnapShotSizeQuantity		Counter32,
        nrSnapShotSizeUnit		INTEGER,
        nrSnapShotUsedSizeQuantity	Counter32,
        nrSnapShotUsedSizeUnit		INTEGER,
        nrSnapShotFreeSizeQuantity	Counter32,
        nrSnapShotFreeSizeUnit		INTEGER,
        nrSnapShotIncSizeQuantity	Counter32,
        nrSnapShotIncSizeUnit		INTEGER,
        nrSnapShotMaxSizeQuantity	Counter32,
        nrSnapShotMaxSizeUnit		INTEGER,
        nrSnapShotOwnResourceID		INTEGER,
        nrSnapShotSize			Counter64,
        nrSnapShotIncSize		Counter64,
        nrSnapShotMaxSize		Counter64,
        nrSnapShotUsedSize		Counter64,
        nrSnapShotFreeSize		Counter64,
        nrSnapShotShrinkPolicy          DisplayString,
        nrSnapShotShrinkThreshold       DisplayString,
        nrSnapShotShrinkMinSize         DisplayString,
        nrSnapShotShrinkMinSizeQuantity Counter32,
        nrSnapShotShrinkMinSizeUnit     INTEGER,
        nrSnapShotShrinkMinSize64       Counter64,
        nrSnapShotResourceStatus	DisplayString
    }

    nrSnapShotResourceID    OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The NAS resource ID assigned by the IPStor server."
    ::= { nrSnapShotInfoEntry 1 }

    nrSnapShotResourceName  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The NAS resource name created by the user."
    ::= { nrSnapShotInfoEntry 2 }
    
    nrSnapShotOption    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the snapshot option is enable or disable of the NAS resource."
    ::= { nrSnapShotInfoEntry 3 }

    nrSnapShotSize  OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The allocated size when creating the NAS resource at first time."
    ::= { nrSnapShotInfoEntry 4 }
    
    nrSnapShotThreshold OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The value represents the threshold setting which is in percentage(%) format of the NAS resource."
    ::= { nrSnapShotInfoEntry 5 }

    nrSnapShotReachTH   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The policy is setting for expanding resource automatically or manually while reaching the threshold."
    ::= { nrSnapShotInfoEntry 6 }

    nrSnapShotIncSize   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The incremental size for each time when is running out the resource.  This is meaningful when expanding
             resource is automatically."
    ::= { nrSnapShotInfoEntry 7 }

    nrSnapShotMaxSize   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The maximum resource size which is represented in megabyte unit is allowed for allocating."
    ::= { nrSnapShotInfoEntry 8 }
    
    nrSnapShotResourceFull  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The policy sets to delete previous timemarks or stop to creating new timemarks when using the maximum resource size."
    ::= { nrSnapShotInfoEntry 9 }

    nrSnapShotUsedSize  OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The resource size which is representing in kilobyte unit have been used."
    ::= { nrSnapShotInfoEntry 10 }
    
    nrSnapShotFreeSize  OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The free resource size which is representing in megabyte unit before reaching the threshold."
    ::= { nrSnapShotInfoEntry 11 }

    nrSnapShotUsedPercent   OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The percentage of the used resource size."
    ::= { nrSnapShotInfoEntry 12 }
    
    nrSnapShotMicroscan    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the snapshot Microscan option is enable or disable of the NAS resource."
    ::= { nrSnapShotInfoEntry 13 }

    nrSnapShotSizeQuantity  OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The allocated size quantity when creating the NAS resource at first time."
    ::= { nrSnapShotInfoEntry 14 }

    nrSnapShotSizeUnit  OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The allocated size unit when creating the NAS resource at first time. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
    ::= { nrSnapShotInfoEntry 15 }

    nrSnapShotUsedSizeQuantity  OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The resource size quantity have been used."
    ::= { nrSnapShotInfoEntry 16 }

    nrSnapShotUsedSizeUnit  OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The resource size unit have been used. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
    ::= { nrSnapShotInfoEntry 17 }
    
    nrSnapShotFreeSizeQuantity  OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The free resource size quantity before reaching the threshold."
    ::= { nrSnapShotInfoEntry 18 }
    
    nrSnapShotFreeSizeUnit  OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The free resource size unit before reaching the threshold. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
    ::= { nrSnapShotInfoEntry 19 }
    
    nrSnapShotIncSizeQuantity  OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The incremental size quantity for each time when is running out the resource.  This is meaningful when expanding
             resource is automatically."
    ::= { nrSnapShotInfoEntry 20 }
    
    nrSnapShotIncSizeUnit  OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The incremental size unit for each time when is running out the resource.  This is meaningful when expanding resource is automatically. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
    ::= { nrSnapShotInfoEntry 21 }
    
    nrSnapShotMaxSizeQuantity  OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The maximum resource size quantity which is represented in megabyte unit is allowed for allocating."
    ::= { nrSnapShotInfoEntry 22 }
    
    nrSnapShotMaxSizeUnit  OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The maximum resource size unit which is represented in megabyte unit is allowed for allocating. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
    ::= { nrSnapShotInfoEntry 23 }

    nrSnapShotOwnResourceID    OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The SnapShot resource ID assigned by the IPStor server."
    ::= { nrSnapShotInfoEntry 24 }

    nrSnapShotSize64  OBJECT-TYPE
        SYNTAX  Counter64
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The allocated size when creating the NAS resource at first time."
    ::= { nrSnapShotInfoEntry 25 }

    nrSnapShotIncSize64   OBJECT-TYPE
        SYNTAX  Counter64
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The incremental size for each time when is running out the resource.  This is meaningful when expanding
             resource is automatically."
    ::= { nrSnapShotInfoEntry 26 }

    nrSnapShotMaxSize64   OBJECT-TYPE
        SYNTAX  Counter64
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The maximum resource size which is represented in megabyte unit is allowed for allocating."
    ::= { nrSnapShotInfoEntry 27 }

    nrSnapShotUsedSize64  OBJECT-TYPE
        SYNTAX  Counter64
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The resource size which is representing in kilobyte unit have been used."
    ::= { nrSnapShotInfoEntry 28 }
    
    nrSnapShotFreeSize64  OBJECT-TYPE
        SYNTAX  Counter64
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The free resource size which is representing in megabyte unit before reaching the threshold."
    ::= { nrSnapShotInfoEntry 29 }

    nrSnapShotShrinkPolicy    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the snapshot Shrink option is enabled or
disabled of the SAN resource."
    ::= { nrSnapShotInfoEntry 30 }

    nrSnapShotShrinkThreshold    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The minimum disk space to shrink the snapshot resource of the SAN
resource."
    ::= { nrSnapShotInfoEntry 31 }

    nrSnapShotShrinkMinSize    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The minimum size for the snapshot resource to shrink."
    ::= { nrSnapShotInfoEntry 32 }

    nrSnapShotShrinkMinSizeQuantity  OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The minimum size quantity for the snapshot resource to shrink."
    ::= { nrSnapShotInfoEntry 33 }

    nrSnapShotShrinkMinSizeUnit  OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The minimum size unit for the snapshot resource to shrink. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
    ::= { nrSnapShotInfoEntry 34 }

    nrSnapShotShrinkMinSize64    OBJECT-TYPE
        SYNTAX  Counter64
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The minimum size for the snapshot resource to shrink."
    ::= { nrSnapShotInfoEntry 35 }

    nrSnapShotResourceStatus   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The snapshot resource status of the NAS resouce."
    ::= { nrSnapShotInfoEntry 36 }

    nrTimeMarkTable OBJECT-TYPE
        SYNTAX  SEQUENCE OF NRTimeMarkInfo
        ACCESS  not-accessible
        STATUS  mandatory
        DESCRIPTION
            "A table containing the timamark resources created by the NAS resource."
    ::= { nasResourceEntry 15 }
    
    nrTimeMarkInfoEntry OBJECT-TYPE
        SYNTAX  NRTimeMarkInfo
        ACCESS  not-accessible
        STATUS  mandatory
        DESCRIPTION
            "Information about the policy and configuration of the timemark function."
        INDEX { nrTimeMarkResourceID }
    ::= { nrTimeMarkTable 1 }

    NRTimeMarkInfo ::= SEQUENCE {
        nrTimeMarkResourceID    INTEGER,
        nrTimeMarkResourceName  DisplayString,
        nrTimeMarkOption        DisplayString,
        nrTimeMarkCounts        INTEGER,
        nrTimeMarkSchedule      DisplayString,
        nrTimeMarkLastTimeStamp DisplayString,
        nrTimeMarkSnapshotImage DisplayString,
	nrTimeMarkSnapshotNotificationOption	DisplayString,
	nrTimeMarkReplicationOption		DisplayString
    }

    nrTimeMarkResourceID    OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The NAS resource ID assigned by the IPStor server."
    ::= { nrTimeMarkInfoEntry 1 }

    nrTimeMarkResourceName  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The NAS resource name created by the user."
    ::= { nrTimeMarkInfoEntry 2 }
    
    nrTimeMarkOption    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the timemark option is enable or disable of the NAS resource."
    ::= { nrTimeMarkInfoEntry 3 }

    nrTimeMarkCounts    OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The maximum timemarks that is allowed to create of the NAS resource."
    ::= { nrTimeMarkInfoEntry 4 }
    
    nrTimeMarkSchedule  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The time interval creates one new timemark."
    ::= { nrTimeMarkInfoEntry 5 }

    nrTimeMarkLastTimeStamp OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The lately timestamp creates timemark."
    ::= { nrTimeMarkInfoEntry 6 }

    nrTimeMarkSnapshotImage OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The time of each day creates snapshot-image automatically."
    ::= { nrTimeMarkInfoEntry 7 }

    nrTimeMarkSnapshotNotificationOption OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The option of triggering snapshot notification schedule."
    ::= { nrTimeMarkInfoEntry 8 }

    nrTimeMarkReplicationOption OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The replication option after the timemark is taken."
    ::= { nrTimeMarkInfoEntry 9 }

    nrBackupTable   OBJECT-TYPE
        SYNTAX  SEQUENCE OF NRBackupInfo
        ACCESS  not-accessible
        STATUS  mandatory
        DESCRIPTION
            "A table containing the backup resources created by the NAS resource."
    ::= { nasResourceEntry 16 }
    
    nrBackupInfoEntry   OBJECT-TYPE
        SYNTAX  NRBackupInfo
        ACCESS  not-accessible
        STATUS  mandatory
        DESCRIPTION
            "Information about the policy and configuration of the backup function."
        INDEX { nrBackupResourceID }
    ::= { nrBackupTable 1 }

    NRBackupInfo ::= SEQUENCE {
        nrBackupResourceID      INTEGER,
        nrBackupResourceName    DisplayString,
        nrBackupOption          DisplayString,
        nrBackupWindow          DisplayString,
        nrBackupSessionLen      DisplayString,
        nrBackupRelativeTime    DisplayString,
        nrBackupWaitTime        INTEGER,
        nrBackupSelectCriteria  DisplayString,
	nrBackupRawDeviceName	DisplayString
    }

    nrBackupResourceID  OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The NAS resource ID assigned by the IPStor server."
    ::= { nrBackupInfoEntry 1 }

    nrBackupResourceName    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The NAS resource name created by the user."
    ::= { nrBackupInfoEntry 2 }
    
    nrBackupOption  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the backup option is enable or disable of the NAS resource."
    ::= { nrBackupInfoEntry 3 }

    nrBackupWindow  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The daytime allows for opening one backup sesion."
    ::= { nrBackupInfoEntry 4 }
    
    nrBackupSessionLen  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The time interval allows for one backup session in each time."
    ::= { nrBackupInfoEntry 5 }

    nrBackupRelativeTime    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The time interval waits before closing the backup session which is in inactivity status."
    ::= { nrBackupInfoEntry 6 }
    
    nrBackupWaitTime    OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The time interval which is represnting in minute unit waits before closing the backup session after completion."
    ::= { nrBackupInfoEntry 7 }

    nrBackupSelectCriteria  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The snapshot image selection criteria that could be new or latest for the backup session.
             New represents that it always creates new snapshot image for backup, and 
             Latest represents that it uses the last created snapshot image for backup."
    ::= { nrBackupInfoEntry 8 }

    nrBackupRawDeviceName    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The NAS Backup Resource Raw Device Name created by the user."
    ::= { nrBackupInfoEntry 9 }
    
    nrReplicationTable  OBJECT-TYPE
        SYNTAX  SEQUENCE OF NRReplicationInfo
        ACCESS  not-accessible
        STATUS  mandatory
        DESCRIPTION
            "A table containing the replication resources created by the NAS resource."
    ::= { nasResourceEntry 17 }
    
    nrReplicaInfoEntry  OBJECT-TYPE
        SYNTAX  NRReplicationInfo
        ACCESS  not-accessible
        STATUS  mandatory
        DESCRIPTION
            "Information about the policy and configuration of the replication function."
        INDEX { nrReplicationResourceID }
    ::= { nrReplicationTable 1 }

    NRReplicationInfo ::= SEQUENCE {
        nrReplicationResourceID     INTEGER,
        nrReplicationResourceName   DisplayString,
        nrReplicationOption         DisplayString,
        nrReplicaServer             DisplayString,
        nrReplicaDeviceID           INTEGER,
        nrReplicaSchedule           DisplayString,
        nrReplicaWatermark          DisplayString,
        nrReplicaWatermarkRetry     INTEGER,
        nrReplicaTime               DisplayString,
        nrReplicaInterval           DisplayString,
        nrReplicationContinuousMode             DisplayString,
        nrReplicationCreatePrimaryTimeMark      DisplayString,
        nrReplicaSyncTimeMark                   DisplayString,
        nrReplicationProtocol                   DisplayString,
        nrReplicationCompression                DisplayString,
        nrReplicationEncryption                 DisplayString,
        nrReplicationMicroscan                  DisplayString,
        nrReplicationSyncPriority               DisplayString,
        nrReplicationStatus                     DisplayString,
        nrReplicationMode                       DisplayString,
        nrReplicationContinuousResourceID       INTEGER,
        nrReplicationContinuousResourceUsage    DisplayString,
        nrReplicationDeltaData                  DisplayString,
        nrReplicationUseExistTM                 DisplayString,
        nrReplicationPreserveTM                 DisplayString,
	nrReplicaLastSuccessfulSyncTime         DisplayString,
	nrReplicaAverageThroughput		Counter32,
	nrReplicaAverageThroughputQuantity	Counter32,
	nrReplicaAverageThroughputUnit		INTEGER
    }

    nrReplicationResourceID OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The NAS resource ID assigned by the IPStor server."
    ::= { nrReplicaInfoEntry 1 }

    nrReplicationResourceName   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The NAS resource name created by the user."
    ::= { nrReplicaInfoEntry 2 }
    
    nrReplicationOption OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the replication option is enable or disable of the NAS resource."
    ::= { nrReplicaInfoEntry 3 }

    nrReplicaServer OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The target replia server name."
    ::= { nrReplicaInfoEntry 4 }
    
    nrReplicaDeviceID   OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The target replica device ID."
    ::= { nrReplicaInfoEntry 5 }

    nrReplicaSchedule   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The state of the replication schedule, which is Suspended, On Schedule if existed replica server."
    ::= { nrReplicaInfoEntry 6 }
    
    nrReplicaWatermark  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The watermark sets to generate one new replication automatically."
    ::= { nrReplicaInfoEntry 7 }

    nrReplicaWatermarkRetry OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The retry interval which is representing in minute unit if the replication failed."
    ::= { nrReplicaInfoEntry 8 }
    
    nrReplicaTime   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The daytime of each day creates one new replication."
    ::= { nrReplicaInfoEntry 9 }
    
    nrReplicaInterval   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The time interval creates one new replication."
    ::= { nrReplicaInfoEntry 10 }

    nrReplicationContinuousMode   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the Continuous Mode of Replication is enable or disable."
    ::= { nrReplicaInfoEntry 11 }

    nrReplicationCreatePrimaryTimeMark    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "This option allows to create the primary TimeMark when a replica TimeMark is created."
    ::= { nrReplicaInfoEntry 12 }

    nrReplicaSyncTimeMark    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "This option allows to synchronize the replica TimeMark when a primary TimeMark is created."
    ::= { nrReplicaInfoEntry 13 }

    nrReplicationProtocol    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "It states the Protocol which Replication uses."
    ::= { nrReplicaInfoEntry 14 }

    nrReplicationCompression    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the Compression option is enable or disable of Replication."
    ::= { nrReplicaInfoEntry 15 }

    nrReplicationEncryption    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the Encryption option is enable or disable of Replication."
    ::= { nrReplicaInfoEntry 16 }

    nrReplicationMicroscan    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the Microscan option is enable or disable of Replication."
    ::= { nrReplicaInfoEntry 17 }

    nrReplicationSyncPriority    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The Priority setting when Replication Synchronize of the NAS resource."
    ::= { nrReplicaInfoEntry 18 }

    nrReplicationStatus    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The Replication status of the NAS resource."
    ::= { nrReplicaInfoEntry 19 }

    nrReplicationMode    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The Replication mode of the NAS resource."
    ::= { nrReplicaInfoEntry 20 }

    nrReplicationContinuousResourceID    OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The Continuous Replication Resource ID of the NAS resource."
    ::= { nrReplicaInfoEntry 21 }

    nrReplicationContinuousResourceUsage    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The Continuous Replication Resource Usage of the NAS resource."
    ::= { nrReplicaInfoEntry 22 }

    nrReplicationDeltaData    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The Accumulated Delta Data of replication of the NAS resource."
    ::= { nrReplicaInfoEntry 23 }

    nrReplicationUseExistTM    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "When Continuous Mode is disabled, the option about using existing TimeMark of the replication."
    ::= { nrReplicaInfoEntry 24 }

    nrReplicationPreserveTM    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "When Continuous Mode is disabled, the option about perserving TimeMark of the replication."
    ::= { nrReplicaInfoEntry 25 }

    nrReplicaLastSuccessfulSyncTime   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The last successful synchronize time of the replication."
    ::= { nrReplicaInfoEntry 26 }
    
    nrReplicaAverageThroughput   OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The average throughput (MB/s) of the replication."
    ::= { nrReplicaInfoEntry 27 }

    nrReplicaAverageThroughputQuantity  OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The average throughput quantity of the replication."
    ::= { nrReplicaInfoEntry 28 }

    nrReplicaAverageThroughputUnit  OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The average throughput unit of the replication. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
    ::= { nrReplicaInfoEntry 29 }

    nrCacheTable    OBJECT-TYPE
        SYNTAX  SEQUENCE OF NRCacheInfo
        ACCESS  not-accessible
        STATUS  mandatory
        DESCRIPTION
            "A table containing the cache resource created by the NAS device."
    ::= { nasResourceEntry 18 }
    
    nrCacheInfoEntry    OBJECT-TYPE
        SYNTAX  NRCacheInfo
        ACCESS  not-accessible
        STATUS  mandatory
        DESCRIPTION
            "Information about the configuration and usage of the cache resource."
        INDEX { nrCacheResourceID }
    ::= { nrCacheTable 1 }

    NRCacheInfo ::= SEQUENCE {
        nrCacheResourceID   INTEGER,
        nrCacheResourceName DisplayString,
        nrCacheOption       DisplayString,
        nrCacheSuspend      DisplayString,
        nrCacheTotalSize    Counter32,
        nrCacheFreeSize     Counter32,
        nrCacheUsage        INTEGER,
        nrCacheThreshold    INTEGER,
        nrCacheFlushTime    INTEGER,
        nrCacheFlushCommand		INTEGER,
        nrCacheSkipWriteCommands	DisplayString,
        nrCacheFlushSpeed		INTEGER,
        nrCacheTotalSizeQuantity	Counter32,
        nrCacheTotalSizeUnit		INTEGER,
        nrCacheFreeSizeQuantity		Counter32,
        nrCacheFreeSizeUnit		INTEGER,
        nrCacheOwnResourceID		INTEGER,
        nrCacheTotalSize64		Counter64,
        nrCacheFreeSize64		Counter64,
	nrCacheStatus			DisplayString
    }

    nrCacheResourceID   OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The NAS resource ID assigned by the IPStor server."
    ::= { nrCacheInfoEntry 1 }

    nrCacheResourceName OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The NAS resource name created by the user."
    ::= { nrCacheInfoEntry 2 }
    
    nrCacheOption   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the cache option is enable or disable of the NAS resource."
    ::= { nrCacheInfoEntry 3 }
    
    nrCacheSuspend  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The cache resource is currently suspended or not."
    ::= { nrCacheInfoEntry 4 }
    
    nrCacheTotalSize    OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The allocated size when creating the cache resource."
    ::= { nrCacheInfoEntry 5 }
    
    nrCacheFreeSize OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The free resource size which is representing in megabyte unit before reaching the maximum resource size."
    ::= { nrCacheInfoEntry 6 }

    nrCacheUsage    OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The percentage of the used resource size."
    ::= { nrCacheInfoEntry 7 }

    nrCacheThreshold    OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The data needs to be in the cache before beginning flushing the cache."
    ::= { nrCacheInfoEntry 8 }
    
    nrCacheFlushTime    OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The number of milliseconds before cache begins to flush when below the data threshold level."
    ::= { nrCacheInfoEntry 9 }
    
    nrCacheFlushCommand OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The outstanding commands will be sent at one time during the flush process."
    ::= { nrCacheInfoEntry 10 }
    
    nrCacheSkipWriteCommands    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "This option allows the system to skip multiple pending write commands targeted for the same block."
    ::= { nrCacheInfoEntry 11 }
    
    nrCacheFlushSpeed OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The flush speed will be sent at one time during the flush process."
    ::= { nrCacheInfoEntry 12 }
    
    nrCacheTotalSizeQuantity    OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The allocated size quantity when creating the cache resource."
    ::= { nrCacheInfoEntry 13 }
    
    nrCacheTotalSizeUnit    OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The allocated size unit when creating the cache resource. 0
presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
    ::= { nrCacheInfoEntry 14 }
    
    nrCacheFreeSizeQuantity OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The free resource size quantity before reaching the maximum resource size."
    ::= { nrCacheInfoEntry 15 }
    
    nrCacheFreeSizeUnit OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The free resource size unit before reaching the maximum resource size. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
    ::= { nrCacheInfoEntry 16 }

    nrCacheOwnResourceID   OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The Cache resource ID assigned by the IPStor server."
    ::= { nrCacheInfoEntry 17 }
    
    nrCacheTotalSize64    OBJECT-TYPE
        SYNTAX  Counter64
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The allocated size when creating the cache resource."
    ::= { nrCacheInfoEntry 18 }
    
    nrCacheFreeSize64 OBJECT-TYPE
        SYNTAX  Counter64
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The free resource size which is representing in megabyte unit before reaching the maximum resource size."
    ::= { nrCacheInfoEntry 19 }
    
    nrCacheStatus    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The current safecache device's status of the NAS resource."
    ::= { nrCacheInfoEntry 20 }
    
    nrWriteCacheProperty    OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The property represents the write cache is enabled or disabled of the NAS resource."
	::= { nasResourceEntry 19 }
	
    nrMirrorTable OBJECT IDENTIFIER ::= { nasResourceEntry 20 }

    nrMirrorInfoEntry    OBJECT-TYPE
        SYNTAX  NRMirrorInfo
