    snapshotgroupMemberTable    OBJECT-TYPE
        SYNTAX  SEQUENCE OF GroupMember
        ACCESS  not-accessible
        STATUS  mandatory
        DESCRIPTION
            "A table containing the members within snapshot groups."
    ::= { snapshotgroupResources 3 }

    snapshotgroupMemberTableEntry OBJECT-TYPE
        SYNTAX  GroupMember
        ACCESS  not-accessible
        STATUS  mandatory
        DESCRIPTION
            "Information about the virtual resource ID in one snapshot group."
        INDEX { snapshotgroupMemberTableIndex }
    ::= { snapshotgroupMemberTable 1 }

    GroupMember ::= SEQUENCE {
        snapshotgroupMemberTableGroupID  INTEGER,
        snapshotgroupMemberTableIndex    INTEGER,
        snapshotgroupMemberTableName     DisplayString
    }
    
    snapshotgroupMemberTableGroupID  OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The snapshot group resource ID assigned by the IPStor server."
