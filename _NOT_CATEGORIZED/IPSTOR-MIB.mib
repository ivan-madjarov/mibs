	srReplicaAverageThroughput		Counter32,
	srReplicaAverageThroughputQuantity	Counter32,
	srReplicaAverageThroughputUnit		INTEGER
    }

    srReplicationResourceID OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The SAN resource ID assigned by the IPStor server."
