--
-- Physical Resources
--
	physicalResources OBJECT IDENTIFIER ::= { ipstorserver 2 }

	numOfAdapters   OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The amount of physical adapters configured by the IPStor server."
	::= { physicalResources 1 }

	numOfDevices    OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The amount of physical devices configured by the IPStor server."
	::= { physicalResources 2 }

	scsiAdapterTable    OBJECT-TYPE
		SYNTAX  SEQUENCE OF ScsiAdapter
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"A table containing the information of all the installed SCSI adapters of the IPStor server."
	::= { physicalResources 3 }

	scsiAdapterEntry    OBJECT-TYPE
		SYNTAX ScsiAdapter
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"Information about the hardware and vendor specification."
		INDEX { adapterIndex }
	::= { scsiAdapterTable 1 }
	
	ScsiAdapter ::= SEQUENCE {
	    adapterIndex	INTEGER,
	    adapterNumber	INTEGER,
	    adapterInfo		DisplayString
	}

	adapterIndex    OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The sequential digit number as a index key of adapter table."
	::= { scsiAdapterEntry 1 }

	adapterNumber   OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI adapter number."
	::= { scsiAdapterEntry 2 }

	adapterInfo OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The model name of the SCSI adapter."
	::= { scsiAdapterEntry 3 }

	scsiDeviceTable OBJECT-TYPE
		SYNTAX  SEQUENCE OF ScsiDevice
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"A table containing all the SCSI devices of the IPStor server."
	::= { physicalResources 4 }

	scsiDeviceEntry OBJECT-TYPE
		SYNTAX	ScsiDevice
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"Information about the hardware specification and characteristic of the device."
		INDEX { deviceNo }
	::= { scsiDeviceTable 1 }
	
	ScsiDevice ::= SEQUENCE {
		deviceNo	    INTEGER,
		deviceType	    DisplayString,
		vendorID	    DisplayString,
		productID	    DisplayString,
		firmwareRev	    DisplayString,
		adapterNo	    INTEGER,
		channelNo	    INTEGER,
		scsiID		    INTEGER,
		lun		    INTEGER,
		totalSectors        Counter32,
		sectorSize          INTEGER,
		totalSize           Counter32,
		configStatus        DisplayString,
		totalSizeQuantity   Counter32,
		totalSizeUnit       INTEGER,
		totalSectors64	    Counter64,
		totalSize64	    Counter64
	}

	deviceNo    OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The sequential digit number as a index key of the device table."
	::= { scsiDeviceEntry 1 }

	deviceType  OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It represents the access type that the device attached to the IPStor server."
	::= { scsiDeviceEntry 2 }

	vendorID    OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The product vendor ID."
	::= { scsiDeviceEntry 3 }

	productID   OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The product model name."
	::= { scsiDeviceEntry 4 }

	firmwareRev OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The firmware version of the device."
	::= { scsiDeviceEntry 5 }

	adapterNo   OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The configured SCSI adapter number."
	::= { scsiDeviceEntry 6 }

	channelNo   OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The configured SCSI channel number."
	::= { scsiDeviceEntry 7 }

	scsiID  OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The configured SCSI ID."
	::= { scsiDeviceEntry 8 }

	lun OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The configured SCSI LUN number."
	::= { scsiDeviceEntry 9 }

	totalSectors    OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of sectors or blocks of the device."
	::= { scsiDeviceEntry 10 }

	sectorSize  OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The size of bytes for each sector or block."
	::= { scsiDeviceEntry 11 }

	totalSize   OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount size of the device which represents with megabyte unit."
	::= { scsiDeviceEntry 12 }

	configStatus    OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It represents the attaching status of the device."
	::= { scsiDeviceEntry 13 }

	totalSizeQuantity   OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The quantity size of the device."
	::= { scsiDeviceEntry 14 }

	totalSizeUnit   OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The size unit of the device. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
	::= { scsiDeviceEntry 15 }

	totalSectors64  OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of sectors or blocks of the device."
	::= { scsiDeviceEntry 16 }

	totalSize64     OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount size of the device which represents with megabyte unit."
	::= { scsiDeviceEntry 17 }

	StoragePoolTable    OBJECT-TYPE
		SYNTAX  SEQUENCE OF StoragePool
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"A table containing the information of Storage Pool of the IPStor server."
	::= { physicalResources 5 }

	StoragePoolEntry    OBJECT-TYPE
		SYNTAX	StoragePool
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"Information about Storage Pool settings."
		INDEX { PoolName }
	::= { StoragePoolTable 1 }
	
	StoragePool ::= SEQUENCE {
	    PoolName			DisplayString,
	    PoolID			INTEGER,
	    PoolType			DisplayString,
	    DeviceCount			INTEGER,
	    PoolCount			INTEGER,
	    PoolTotalSize		Counter32,
	    PoolUsedSize		Counter32,
	    PoolAvailableSize		Counter32,
	    PoolTotalSizeQuantity	Counter32,
	    PoolTotalSizeUnit		INTEGER,
	    PoolUsedSizeQuantity	Counter32,
	    PoolUsedSizeUnit		INTEGER,
	    PoolAvailableSizeQuantity	Counter32,
	    PoolAvailableSizeUnit	INTEGER,
	    PoolTotalSize64		Counter64,
	    PoolUsedSize64		Counter64,
	    PoolAvailableSize64		Counter64
	}

	PoolName    OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The Pool Name of the Storage Pool."
	::= { StoragePoolEntry 1 }

	PoolID    OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The Pool ID of the Storage Pool."
	::= { StoragePoolEntry 2 }

	PoolType    OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The Pool Type of the Storage Pool."
	::= { StoragePoolEntry 3 }

	DeviceCount    OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The device Count in the Storage Pool."
	::= { StoragePoolEntry 4 }

	PoolCount    OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The Storage Pool counts."
	::= { StoragePoolEntry 5 }

	PoolTotalSize    OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The total Size of the Storage Pool."
	::= { StoragePoolEntry 6 }

	PoolUsedSize    OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The used Size of the Storage Pool."
	::= { StoragePoolEntry 7 }

	PoolAvailableSize    OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The available Size of the Storage Pool."
	::= { StoragePoolEntry 8 }

	PoolTotalSizeQuantity    OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The total Size quantity of the Storage Pool."
	::= { StoragePoolEntry 9 }

	PoolTotalSizeUnit    OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The total Size unit of the Storage Pool. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
	::= { StoragePoolEntry 10 }

	PoolUsedSizeQuantity    OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The used Size quantity of the Storage Pool."
	::= { StoragePoolEntry 11 }

	PoolUsedSizeUnit    OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The used Size unit of the Storage Pool. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
	::= { StoragePoolEntry 12 }

	PoolAvailableSizeQuantity    OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The available Size quantity of the Storage Pool."
	::= { StoragePoolEntry 13 }

	PoolAvailableSizeUnit    OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The available Size unit of the Storage Pool. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
	::= { StoragePoolEntry 14 }

	PoolTotalSize64 OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The total Size of the Storage Pool."
	::= { StoragePoolEntry 15 }

	PoolUsedSize64  OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The used Size of the Storage Pool."
	::= { StoragePoolEntry 16 }

	PoolAvailableSize64    OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The available Size of the Storage Pool."
	::= { StoragePoolEntry 17 }
--
-- Logical Resources
--

	logicalResources OBJECT IDENTIFIER ::= { ipstorserver 3 }
	
	numOfLogicalResources   OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of logical resources which including the SAN, NAS, and Replica devices are available in the IPStor server."
	::= { logicalResources 1}

	snapshotReservedArea OBJECT IDENTIFIER ::= { logicalResources 2 }

	numOfSnapshotReserved   OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS  obsolete
		DESCRIPTION
			"The amount of the shareable snapshot reserved areas."
	::= { snapshotReservedArea 1 }

	snapshotReservedTable OBJECT-TYPE
		SYNTAX  SEQUENCE OF SnapShotReserved
		ACCESS	not-accessible
		STATUS	obsolete
		DESCRIPTION
			"A table containing the snapshot reserved areas information."
	::= { snapshotReservedArea 2 }

	snapShotReservedEntry OBJECT-TYPE
		SYNTAX	SnapShotReserved
		ACCESS	not-accessible
		STATUS	obsolete
		DESCRIPTION
			"Information about the allocated resource."
		INDEX { ssrIndex }
	::= { snapshotReservedTable 1 }
	
	SnapShotReserved ::= SEQUENCE {
	ssrIndex	    INTEGER,
        ssrName 	    DisplayString,
        ssrDeviceName	DisplayString,
        ssrSCSIAddress	DisplayString,
        ssrFirstSector	Counter32,
        ssrLastSector	Counter32,
	ssrTotalSectors Counter32,
	ssrSize		Counter32,
	ssrSizeQuantity Counter32,
	ssrSizeUnit	INTEGER,
        ssrFirstSector64	Counter64,
        ssrLastSector64		Counter64,
	ssrTotalSectors64	Counter64,
	ssrSize64		Counter64
	}

	ssrIndex    OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	obsolete
		DESCRIPTION
			"The sequential digit number as a index key of the snapshot reserved table."
	::= { snapShotReservedEntry 1 }

	ssrName OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	obsolete
		DESCRIPTION
			"The name of the snapshot reserved area."
	::= { snapShotReservedEntry 2 }

	ssrDeviceName   OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	obsolete
		DESCRIPTION
			"The physical device name of the snapshot reserved area."
	::= { snapShotReservedEntry 3 }

	ssrSCSIAddress  OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	obsolete
		DESCRIPTION
			"The SCSI address of the physical device which the snapshot reserved area created."
	::= { snapShotReservedEntry 4 }

	ssrFirstSector  OBJECT-TYPE
		SYNTAX	Counter32
		ACCESS	read-only
		STATUS	obsolete
		DESCRIPTION
			"The first sector of the snapshot reserved area."
	::= { snapShotReservedEntry 5 }
	
	ssrLastSector   OBJECT-TYPE
		SYNTAX	Counter32
		ACCESS	read-only
		STATUS	obsolete
		DESCRIPTION
			"The last sector of the snapshot reserved area."
	::= { snapShotReservedEntry 6 }

	ssrTotalSectors OBJECT-TYPE
		SYNTAX	Counter32
		ACCESS	read-only
		STATUS	obsolete
		DESCRIPTION
			"The amount of sectors that the snapshot reserved area created."
	::= { snapShotReservedEntry 7 }

	ssrSize OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	obsolete
		DESCRIPTION
			"The amount of resource size which is representing with megabyte unit of the snapshot reserved area."
	::= { snapShotReservedEntry 8 }

	ssrSizeQuantity OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	obsolete
		DESCRIPTION
			"The amount quantity of resource size of the snapshot reserved area."
	::= { snapShotReservedEntry 9 }

	ssrSizeUnit OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	obsolete
		DESCRIPTION
			"The resource size unit of the snapshot reserved area. The size unit of the device. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
	::= { snapShotReservedEntry 10 }

	ssrFirstSector64  OBJECT-TYPE
		SYNTAX	Counter64
		ACCESS	read-only
		STATUS	obsolete
		DESCRIPTION
			"The first sector of the snapshot reserved area."
	::= { snapShotReservedEntry 11 }
	
	ssrLastSector64   OBJECT-TYPE
		SYNTAX	Counter64
		ACCESS	read-only
		STATUS	obsolete
		DESCRIPTION
			"The last sector of the snapshot reserved area."
	::= { snapShotReservedEntry 12 }

	ssrTotalSectors64 OBJECT-TYPE
		SYNTAX	Counter64
		ACCESS	read-only
		STATUS	obsolete
		DESCRIPTION
			"The amount of sectors that the snapshot reserved area created."
	::= { snapShotReservedEntry 13 }

	ssrSize64 OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS	read-only
		STATUS	obsolete
		DESCRIPTION
			"The amount of resource size which is representing with megabyte unit of the snapshot reserved area."
	::= { snapShotReservedEntry 14 }

	sanResources OBJECT IDENTIFIER ::= { logicalResources 3 }

	numOfSANResources   OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The amount of SAN resources are available by the IPStor server."
	::= { sanResources 1 }

	sanResourceTable OBJECT-TYPE
		SYNTAX  SEQUENCE OF SANResource
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"A table containing the SAN resources information."
	::= { sanResources 2 }

	sanResourceEntry OBJECT-TYPE
		SYNTAX	SANResource
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"Information about the configurations and properties of the logical SAN resources."
		INDEX { sanResourceID }
	::= { sanResourceTable 1 }

	SANResource ::= SEQUENCE {
		sanResourceID			    INTEGER,
		sanResourceName 		DisplayString,
		srAllocationType		DisplayString,
		srTotalSectors			Counter32,
		srTotalSize			Counter32,
		srConfigStatus			DisplayString,
		srMirrorSyncStatus		DisplayString,
		srReplicaDevice		        DisplayString,
		srReplicatingSchedule		DisplayString,
		srSnapshotCopyStatus		DisplayString,
--		srClientInfoTable          	OBJECT IDENTIFIER,
--		srTimeMarkTable			OBJECT IDENTIFIER,
	        srWriteCacheProperty		DisplayString,
		srTotalSizeQuantity		Counter32,
		srTotalSizeUnit			INTEGER,
		srTotalSectors64		Counter64,
		srTotalSize64			Counter64
	}

	sanResourceID   OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SAN resource ID assigned by the IPStor server."
	::= { sanResourceEntry 1 }
	
	sanResourceName OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SAN resource name created by the user."
	::= { sanResourceEntry 2 }    

	srAllocationType    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It represents the resource type when user allocating the SAN device."
	::= { sanResourceEntry 3 }

	srTotalSectors  OBJECT-TYPE
		SYNTAX	Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of sectors allocated by the SAN resource."
	::= { sanResourceEntry 4 }
	
	srTotalSize OBJECT-TYPE
		SYNTAX	Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of device size which is representing with megabyte unit of the SAN resource."
	::= { sanResourceEntry 5 }

	srConfigStatus  OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It represents the attaching status of the SAN resource."
	::= { sanResourceEntry 6 }
	
	srMirrorSyncStatus  OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It represents the mirror synchronization status of the SAN resource."
	::= { sanResourceEntry 7 }

	srReplicaDevice OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It represents the target replica server and device as the format <hostname of target>:<virtual device id>,
			 if the replication option is enabled of the SAN resource."
	::= { sanResourceEntry 8 }
	
	srReplicatingSchedule   OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It represents the current status of the replicating schedule(On-schedule, Suspended, or N/A) set for the SAN resource."
	::= { sanResourceEntry 9 }
	
	srSnapshotCopyStatus    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The snapshot copy status of the SAN resource."
	::= { sanResourceEntry 10 }

	srPhysicalAllocLayoutTable OBJECT IDENTIFIER ::= { sanResourceEntry 11 }

	physicalAllocLayoutEntry    OBJECT-TYPE
		SYNTAX PhysicalAllocLayout
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"Information about the physical devices which are reserved and created by logical SAN resource."
		INDEX { physicalAllocLayoutIndex }
	::= { srPhysicalAllocLayoutTable 1 }

	PhysicalAllocLayout ::= SEQUENCE {
		physicalAllocLayoutIndex    		INTEGER,
		srpaSANResourceName 			DisplayString,
		srpaSANResourceID   			INTEGER,
		srpaName			        DisplayString,
		srpaType  			        DisplayString,
		srpaAdapterNo			    	INTEGER,
		srpaChannelNo			    	INTEGER,
		srpaScsiID			        INTEGER,
		srpaLun				        INTEGER,
		srpaFirstSector			    	Counter32,
		srpaLastSector			    	Counter32,
		srpaSize			        Counter32,
		srpaSizeQuantity		        Counter32,
		srpaSizeUnit			        INTEGER,
		srpaFirstSector64			Counter64,
		srpaLastSector64			Counter64,
		srpaSize64				Counter64
	}

	physicalAllocLayoutIndex    OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The sequential digit number as a index key of the physical allocation layout table."
	::= { physicalAllocLayoutEntry 1 }

	srpaSANResourceName OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SAN resource name created by the user."
	::= { physicalAllocLayoutEntry 2 }

	srpaSANResourceID   OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SAN resource ID assigned by the IPStor server."
	::= { physicalAllocLayoutEntry 3 }

	srpaName    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The physical device name."
	::= { physicalAllocLayoutEntry 4 }
	
	srpaType OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It represents the type(Primary, or Mirror) of the physical layout."
	::= { physicalAllocLayoutEntry 5 }

	srpaAdapterNo OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI adapter number of the physical device."
	::= { physicalAllocLayoutEntry 6 }

	srpaChannelNo OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI channel number of the physical device."
	::= { physicalAllocLayoutEntry 7 }

	srpaScsiID OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI ID of the physical device."
	::= { physicalAllocLayoutEntry 8 }

	srpaLun OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI LUN number of the physical device."
	::= { physicalAllocLayoutEntry 9 }

	srpaFirstSector OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The first sector of the physical device which is allocated by the SAN resource."
	::= { physicalAllocLayoutEntry 10 }

	srpaLastSector  OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The last sector of the physical device which is allocated by the SAN resource."
	::= { physicalAllocLayoutEntry 11 }
		
	srpaSize    OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of the allocated size which is representing with megabyte unit within a physical device."
	::= { physicalAllocLayoutEntry 12 }
		
	srpaSizeQuantity    OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of the allocated size quantity within a physical device."
	::= { physicalAllocLayoutEntry 13 }
		
	srpaSizeUnit    OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of the allocated size unit within a physical device. The size unit of the device. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
	::= { physicalAllocLayoutEntry 14 }

	srpaFirstSector64 OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The first sector of the physical device which is allocated by the SAN resource."
	::= { physicalAllocLayoutEntry 15 }

	srpaLastSector64  OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The last sector of the physical device which is allocated by the SAN resource."
	::= { physicalAllocLayoutEntry 16 }
		
	srpaSize64    OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of the allocated size which is representing with megabyte unit within a physical device."
	::= { physicalAllocLayoutEntry 17 }

	srClientInfoTable   OBJECT-TYPE
		SYNTAX SEQUENCE OF SRClientInfo
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"A table containing the SAN clients information."
	::= { sanResourceEntry 12 }

	srClientInfoEntry   OBJECT-TYPE
		SYNTAX  SRClientInfo
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"Information about the SAN clients if the SAN resources have been assigned."
		INDEX { srClientNo }
	::= { srClientInfoTable 1 }

	SRClientInfo ::= SEQUENCE {
		srClientNo          INTEGER,
		srcName			    DisplayString,
		srcSANResourceID	INTEGER,
		srcSANResourceName	DisplayString,
		srcAdapterNo		INTEGER,
		srcChannelNo		INTEGER,
		srcScsiID		    INTEGER,
		srcLun			    INTEGER,
		srcAccess		    DisplayString,
		srcConnAccess		DisplayString
	}

	srClientNo  OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SAN client ID assigned by the IPStor server."
	::= { srClientInfoEntry 1 }

	srcName OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SAN client name assigned by the IPStor server."
	::= { srClientInfoEntry 2 }

	srcSANResourceID    OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SAN resource ID assigned by the IPStor server."
	::= { srClientInfoEntry 3 }

	srcSANResourceName  OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SAN resource name created by the user."
	::= { srClientInfoEntry 4 }

	srcAdapterNo    OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The adapter number of the SAN client."
	::= { srClientInfoEntry 5 }

	srcChannelNo    OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The channel number of the SAN client."
	::= { srClientInfoEntry 6 }

	srcScsiID   OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI ID of the SAN client."
	::= { srClientInfoEntry 7 }

	srcLun  OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI LUN number of the SAN client."
	::= { srClientInfoEntry 8 }

	srcAccess   OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SAN resource accessing mode assigned to the SAN client."
	::= { srClientInfoEntry 9 }

	srcConnAccess   OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"Identify the connecting and accessing status with a resource of the SAN client."
	::= { srClientInfoEntry 10 }

    srFCClientInfoTable OBJECT IDENTIFIER ::= { sanResourceEntry 13 }

    srFCClientInfoEntry OBJECT-TYPE
        SYNTAX  SRFCClientInfo
        ACCESS  not-accessible
        STATUS  mandatory
        DESCRIPTION
            "Information about the Fibre Channel clients if the SAN resources have been assigned."
        INDEX { srFCClientNo }
    ::= { srFCClientInfoTable 1 }

    SRFCClientInfo ::= SEQUENCE {
        srFCClientNo        INTEGER,
        srFCName            DisplayString,
        srFCSANResourceID   INTEGER,
        srFCSANResourceName DisplayString,
        srFCInitatorWWPN    DisplayString,
        srFCTargetWWPN      DisplayString,
        srFCLun             INTEGER,
        srFCAccess          DisplayString,
        srFCConnAccess      DisplayString
    }

    srFCClientNo OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The Fibre Channel client ID assigned by the IPStor server."
    ::= { srFCClientInfoEntry 1 }

    srFCName    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The Fibre Channel client name assigned by the IPStor server."
    ::= { srFCClientInfoEntry 2 }

    srFCSANResourceID   OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The SAN resource ID assigned by the IPStor server."
    ::= { srFCClientInfoEntry 3 }

    srFCSANResourceName OBJECT-TYPE 
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The SAN resource name created by the user."
    ::= { srFCClientInfoEntry 4 }

    srFCInitatorWWPN    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The world wide port name(WWPN) of the Fibre Channel client's initator HBA."
    ::= { srFCClientInfoEntry 5 }
    
    srFCTargetWWPN  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The world wide port name(WWPN) of the Fibre Channel client's target HBA."
    ::= { srFCClientInfoEntry 6 }
    
    srFCLun OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The SCSI LUN number of the Fibre Channel client."
    ::= { srFCClientInfoEntry 7 }
    
    srFCAccess OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The SAN resource accessing mode assigned to the Fibre Channel client."
    ::= { srFCClientInfoEntry 8 }
   
    srFCConnAccess OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "Identify the connecting and accessing status with a resource of the Fibre Channel client."
    ::= { srFCClientInfoEntry 9 } 

    srSnapShotTable OBJECT IDENTIFIER ::= { sanResourceEntry 14 }
    
    srSnapShotInfoEntry OBJECT-TYPE
        SYNTAX  SRSnapShotInfo
        ACCESS  not-accessible
        STATUS  mandatory
        DESCRIPTION
            "Information about the policy and configuration of the snapshot function."
        INDEX { srSnapShotResourceID }
    ::= { srSnapShotTable 1 }

    SRSnapShotInfo ::= SEQUENCE {
        srSnapShotResourceID		INTEGER,
        srSnapShotResourceName		DisplayString,
        srSnapShotOption		DisplayString,
        srSnapShotSize			Counter32,
        srSnapShotThreshold		INTEGER,
        srSnapShotReachTH		DisplayString,
        srSnapShotIncSize		DisplayString,
        srSnapShotMaxSize		DisplayString,
        srSnapShotResourceFull		DisplayString,
        srSnapShotUsedSize		Counter32,
        srSnapShotFreeSize		Counter32,
        srSnapShotUsedPercent		INTEGER,
        srSnapShotMicroscan		DisplayString,
        srSnapShotSizeQuantity		Counter32,
        srSnapShotSizeUnit		INTEGER,
        srSnapShotUsedSizeQuantity	Counter32,
        srSnapShotUsedSizeUnit		INTEGER,
        srSnapShotFreeSizeQuantity	Counter32,
        srSnapShotFreeSizeUnit		INTEGER,
        srSnapShotIncSizeQuantity	Counter32,
        srSnapShotIncSizeUnit		INTEGER,
        srSnapShotMaxSizeQuantity	Counter32,
        srSnapShotMaxSizeUnit		INTEGER,
        srSnapShotOwnResourceID		INTEGER,
        srSnapShotSize64		Counter64,
        srSnapShotIncSize64		Counter64,
        srSnapShotMaxSize64		Counter64,
        srSnapShotUsedSize64		Counter64,
        srSnapShotFreeSize64		Counter64,
        srSnapShotReclaimPolicy		DisplayString,
        srSnapShotReclaimTime		DisplayString,
        srSnapShotReclaimInterval	DisplayString,
        srSnapShotReclaimWaterMark	DisplayString,
        srSnapShotReclaimMaxTime	DisplayString,
        srSnapShotShrinkPolicy		DisplayString,
        srSnapShotShrinkThreshold	DisplayString,
        srSnapShotShrinkMinSize		DisplayString,
        srSnapShotShrinkMinSizeQuantity	Counter32,
        srSnapShotShrinkMinSizeUnit	INTEGER,
        srSnapShotShrinkMinSize64	Counter64,
        srSnapShotResourceStatus	DisplayString
    }

    srSnapShotResourceID    OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The SAN resource ID assigned by the IPStor server."
    ::= { srSnapShotInfoEntry 1 }

    srSnapShotResourceName  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The SAN resource name created by the user."
    ::= { srSnapShotInfoEntry 2 }
    
    srSnapShotOption    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the snapshot option is enable or disable of the SAN resource."
    ::= { srSnapShotInfoEntry 3 }

    srSnapShotSize  OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The allocated size when creating the SAN resource at first time."
    ::= { srSnapShotInfoEntry 4 }
    
    srSnapShotThreshold OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The value represents the threshold setting which is in percentage(%) format of the SAN resource."
    ::= { srSnapShotInfoEntry 5 }

    srSnapShotReachTH   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The policy is setting for expanding resource automatically or manually while reaching the threshold."
    ::= { srSnapShotInfoEntry 6 }

    srSnapShotIncSize   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The incremental size for each time when is running out the resource.  This is meaningful when expanding
             resource is automatically."
    ::= { srSnapShotInfoEntry 7 }

    srSnapShotMaxSize   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The maximum resource size which is represented in megabyte unit is allowed for allocating."
    ::= { srSnapShotInfoEntry 8 }
    
    srSnapShotResourceFull  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The policy sets to delete previous timemarks or stop to creating new timemarks when using the maximum resource size."
    ::= { srSnapShotInfoEntry 9 }

    srSnapShotUsedSize  OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The resource size which is representing in kilobyte unit have been used."
    ::= { srSnapShotInfoEntry 10 }
    
    srSnapShotFreeSize  OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The free resource size which is representing in megabyte unit before reaching the threshold."
    ::= { srSnapShotInfoEntry 11 }

    srSnapShotUsedPercent   OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The percentage of the used resource size."
    ::= { srSnapShotInfoEntry 12 }
    
    srSnapShotMicroscan    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the snapshot Microscan option is enabled or disabled of the SAN resource."
    ::= { srSnapShotInfoEntry 13 }

    srSnapShotSizeQuantity  OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The allocated size quantity when creating the SAN resource at first time."
    ::= { srSnapShotInfoEntry 14 }

    srSnapShotSizeUnit  OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The allocated size unit when creating the SAN resource at first time. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
    ::= { srSnapShotInfoEntry 15 }

    srSnapShotUsedSizeQuantity  OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The resource size quantity which have been used."
    ::= { srSnapShotInfoEntry 16 }

    srSnapShotUsedSizeUnit  OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The resource size unit which have been used. 0 presents KB. 1
presents MB. 2 presents GB. 3 presents TB."
    ::= { srSnapShotInfoEntry 17 }
    
    srSnapShotFreeSizeQuantity  OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The free resource size quantity before reaching the threshold."
    ::= { srSnapShotInfoEntry 18 }
    
    srSnapShotFreeSizeUnit  OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The free resource size unit before reaching the threshold. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
    ::= { srSnapShotInfoEntry 19 }

    srSnapShotIncSizeQuantity  OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The incremental size quantity which has been used for each time when is running out the resource"
    ::= { srSnapShotInfoEntry 20 }

    srSnapShotIncSizeUnit  OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The incremental size unit which has been used for each time when is running out the resource. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
    ::= { srSnapShotInfoEntry 21 }

    srSnapShotMaxSizeQuantity  OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The maximum resource size quantity which have been used."
    ::= { srSnapShotInfoEntry 22 }

    srSnapShotMaxSizeUnit  OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The maximum resource size unit which have been used. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
    ::= { srSnapShotInfoEntry 23 }

    srSnapShotOwnResourceID    OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The SnapShot resource ID assigned by the IPStor server."
    ::= { srSnapShotInfoEntry 24 }

    srSnapShotSize64  OBJECT-TYPE
        SYNTAX  Counter64
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The allocated size when creating the SAN resource at first time."
    ::= { srSnapShotInfoEntry 25 }

    srSnapShotIncSize64   OBJECT-TYPE
        SYNTAX  Counter64
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The incremental size for each time when is running out the resource.  This is meaningful when expanding
             resource is automatically."
    ::= { srSnapShotInfoEntry 26 }

    srSnapShotMaxSize64   OBJECT-TYPE
        SYNTAX  Counter64
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The maximum resource size which is represented in megabyte unit is allowed for allocating."
    ::= { srSnapShotInfoEntry 27 }

    srSnapShotUsedSize64  OBJECT-TYPE
        SYNTAX  Counter64
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The resource size which is representing in kilobyte unit have been used."
    ::= { srSnapShotInfoEntry 28 }
    
    srSnapShotFreeSize64  OBJECT-TYPE
        SYNTAX  Counter64
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The free resource size which is representing in megabyte unit before reaching the threshold."
    ::= { srSnapShotInfoEntry 29 }
    
    srSnapShotReclaimPolicy    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the snapshot Reclaim option is enabled or disabled of the SAN resource."
    ::= { srSnapShotInfoEntry 30 }
    
    srSnapShotReclaimTime    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The initial time when the snapshot Reclaim option is enabled of the SAN resource."
    ::= { srSnapShotInfoEntry 31 }
    
    srSnapShotReclaimInterval    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The schedule interval to start the snapshot Reclaim of the SAN resource."
    ::= { srSnapShotInfoEntry 32 }
    
    srSnapShotReclaimWaterMark    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The threshold for the minimum amount of space that can be reclaimed per TimeMark of the SAN resource."
    ::= { srSnapShotInfoEntry 33 }
    
    srSnapShotReclaimMaxTime    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The maximum time for the reclaim process of the SAN resource."
    ::= { srSnapShotInfoEntry 34 }
    
    srSnapShotShrinkPolicy    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the snapshot Shrink option is enabled or disabled of the SAN resource."
    ::= { srSnapShotInfoEntry 35 }
    
    srSnapShotShrinkThreshold    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The minimum disk space to shrink the snapshot resource of the SAN resource."
    ::= { srSnapShotInfoEntry 36 }
    
    srSnapShotShrinkMinSize    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The minimum size for the snapshot resource to shrink."
