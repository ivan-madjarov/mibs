        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The average throughput (MB/s) of the replication."
    ::= { srReplicaInfoEntry 27 }

    srReplicaAverageThroughputQuantity  OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The average throughput quantity of the replication."
