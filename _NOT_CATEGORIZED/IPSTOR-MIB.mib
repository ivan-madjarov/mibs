	wcConnections OBJECT IDENTIFIER ::= { windowsClients 13 }

	numOfConnections OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"Total number of connections."
	::= { wcConnections 1 }
		
	wcConnectionsTable OBJECT-TYPE
		SYNTAX  SEQUENCE OF WCConnections
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			" A list all connection(s) of windows clients.
			  The data is the real-time status.  "
	::= { wcConnections 2 }

	wcConnectionsEntry OBJECT-TYPE
		SYNTAX  WCConnections
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			" List all connection(s). "
		INDEX { wcConnIndex }
	::= { wcConnectionsTable 1 }

	WCConnections ::= SEQUENCE {
		wcConnIndex	INTEGER,
		wcConnUser	DisplayString,
		wcConnClient	DisplayString,
		wcConnDate	DisplayString
	}

	wcConnIndex OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			" The index. "
	::= { wcConnectionsEntry 1 }

	wcConnUser OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			" List the connection user."
	::= { wcConnectionsEntry 2 }

	wcConnClient OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			" List which client is connectting. "
	::= { wcConnectionsEntry 3 }

	wcConnDate OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			" List the connection date. "
	::= { wcConnectionsEntry 4 }

	wcShares OBJECT IDENTIFIER ::= { windowsClients 14 }

	numOfShares OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"Total number of shares."
	::= { wcShares 1 }
	
	wcSharesTable OBJECT-TYPE
		SYNTAX SEQUENCE OF WCShares
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			" A list all share(s) of windows clients.
			  The share(s) status is the real-time status. "
	::= { wcShares 2 }

	wcSharesEntry OBJECT-TYPE
		SYNTAX WCShares
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			" List all share(s). "
		INDEX { wcShareIndex }
	::= { wcSharesTable 1 }

	WCShares ::= SEQUENCE {
		wcShareIndex	INTEGER,
		wcShareName	DisplayString,
		wcShareUser	DisplayString,
		wcShareGroup	DisplayString,
		wcShareClient	DisplayString,
		wcShareDate	DisplayString
	}

	wcShareIndex OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			" The index. "
	::= { wcSharesEntry 1 }

	wcShareName OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			" List the share folder name. "
	::= { wcSharesEntry 2 }

	wcShareUser OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			" List which user is using the share folder right now. "
	::= { wcSharesEntry 3 }

	wcShareGroup OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			" List which group of the user. "
	::= { wcSharesEntry 4 }

	wcShareClient OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			" List which client is connected to this share folder. "
	::= { wcSharesEntry 5 }

	wcShareDate OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			" List the client connected date. "
	::= { wcSharesEntry 6 }

	wcActivityLogMaxSize OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"Maximum activity data file size (MB)."
	::= { windowsClients 15 }

	wcActivityLogKeepDays OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"Number of days of activities to keep."
	::= { windowsClients 16 }

	wcLockedFiles OBJECT IDENTIFIER ::= { windowsClients 17 }

	numOfLockedFiles OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"Total number of locked files."
	::= { wcLockedFiles 1 }
	
	wcLockedFilesTable OBJECT-TYPE
		SYNTAX SEQUENCE OF WCLockedFiles
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			" A list all open file(s) of windows clients.
			  The open file(s) is the real-time status. "
	::= { wcLockedFiles 2 }

	wcLockedFilesEntry OBJECT-TYPE
		SYNTAX WCLockedFiles
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			" List all open file(s). "
		INDEX { wclIndex }
	::= { wcLockedFilesTable 1 }

	WCLockedFiles ::= SEQUENCE {
		wclIndex	INTEGER,
		wclUser		DisplayString,
		wclClientHost	DisplayString,
		wclFile		DisplayString,
		wclDate		DisplayString
	}
	
	wclIndex OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			" The index. "
	::= { wcLockedFilesEntry 1 }

	wclUser OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"."
	::= { wcLockedFilesEntry 2 }

	wclClientHost OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			""
	::= { wcLockedFilesEntry 3 }

	wclFile OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"List which file is locked."
	::= { wcLockedFilesEntry 4 }

	wclDate OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"List date."
	::= { wcLockedFilesEntry 5 }

	wcDomainPollDataInterval OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"Domain controller poll interval (minute(s))"
	::= { windowsClients 18 }

	nfsClients OBJECT IDENTIFIER ::= { nasClients 2 }
	
	numOfNFSClients OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of NFS clients assigned by the IPStor server."
	::= { nfsClients 1 }

	numOfNFSShares  OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of NFS shares created by the IPStor server."
	::= { nfsClients 2 }
	
	ncNFSClientTable    OBJECT-TYPE
		SYNTAX  SEQUENCE OF NCNFSClient
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"A table containing NFS clients which share the resource."
	::= { nfsClients 3 }

	ncNFSClientEntry    OBJECT-TYPE
		SYNTAX  NCNFSClient
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"Information about the assigned NFS client."
		INDEX { ncIndex }
	::= { ncNFSClientTable 1 }

	NCNFSClient ::= SEQUENCE {
		ncIndex		INTEGER,
		ncLabel		DisplayString,
		ncMachine	DisplayString,
		ncComment	DisplayString
	}

	ncIndex OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The sequential digit number as a index key of the NFS client table."
	::= { ncNFSClientEntry 1 }

	ncLabel OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The displaying name of the assigned NFS client."
	::= { ncNFSClientEntry 2 }

	ncMachine   OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The host name of the assigned NFS client."
	::= { ncNFSClientEntry 3 }

	ncComment   OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The comment of the NFS client."
	::= { ncNFSClientEntry 4 }

	ncNFSShareTable OBJECT-TYPE
		SYNTAX  SEQUENCE OF NCNFSShare
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"A table containing shared resource that assigned to NFS client."
	::= { nfsClients 4 }

	ncNFSShareEntry OBJECT-TYPE
		SYNTAX  NCNFSShare
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"Information about the shared resource."
		INDEX { ncsIndex }
	::= { ncNFSShareTable 1 }

	NCNFSShare ::= SEQUENCE {
		ncsIndex        INTEGER,
		ncsDiaplayName  DisplayString,
		ncsMachine      DisplayString,
		ncsShareName    DisplayString,
		ncsComment      DisplayString,
		ncsAccessRight  DisplayString,
		ncsFolderName   DisplayString,
		ncsRealPath     DisplayString
	}

	ncsIndex    OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The sequential digit number as a index key of the NFS client share table."
	::= { ncNFSShareEntry 1 }

	ncsDiaplayName  OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The displaying name of the assigned NFS client."
	::= { ncNFSShareEntry 2 }

	ncsMachine OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The host name of the assigned NFS client."
	::= { ncNFSShareEntry 3 }

	ncsShareName    OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The share name of the shared resource."
	::= { ncNFSShareEntry 4 }

	ncsComment  OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The comments setted by users of one share folder."
	::= { ncNFSShareEntry 5 }

	ncsAccessRight  OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The access rights setted for the shared folder to the NFS clients."
	::= { ncNFSShareEntry 6 }

	ncsFolderName   OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The sharing folder name."
	::= { ncNFSShareEntry 7 }

	ncsRealPath OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The sharing full path."
	::= { ncNFSShareEntry 8 }
		
--
-- Virtual Resource States Information
--

	virtualResourceStates OBJECT IDENTIFIER ::= { ipstorserver 6 }

	vrsNumOfVirResources    OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of logical resources which including the SAN, NAS, and Replica devices are available in the IPStor server."
	::= { virtualResourceStates 1 }

	vrsVirResourcesTable    OBJECT-TYPE
		SYNTAX  SEQUENCE OF VRSVirResource
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"A table containing usage and SCSI command statistics of virtual resources."
	::= { virtualResourceStates 2 }

	vrsVirResourceEntry OBJECT-TYPE
		SYNTAX  VRSVirResource
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"Information about resource usage and SCSI commands have been read/write of virtual resource."
		INDEX { vrsVirResourceID }
	::= { vrsVirResourcesTable 1 }

	VRSVirResource ::= SEQUENCE {
		vrsVirResourceID    INTEGER,
		vrsVirResourceName	DisplayString,
		vrsInquiry          DisplayString,
		vrsCmdPending		INTEGER,
		vrsSize             	Counter32,
		vrsBlockSize		INTEGER,
		vrsKBRead    	        INTEGER,
		vrsKBWritten		INTEGER,
		vrsSCSIReadCmd		INTEGER,
		vrsSCSIWriteCmd		INTEGER,
		vrsOtherSCSICmd		INTEGER,
		vrsReadError		INTEGER,
		vrsWriteError		INTEGER,
--		vrsRealDevTable		OBJECT IDENTIFIER,
--		vrsClientTable		OBJECT IDENTIFIER,
		vrsSizeQuantity         Counter32,
		vrsSizeUnit             INTEGER,
		vrsSize64		Counter64,
		vrsKBRead64    	        Counter64,
		vrsKBWritten64		Counter64
	}

	vrsVirResourceID    OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The virtual resource ID assigned by the IPStor server."
	::= { vrsVirResourceEntry 1 }

	vrsVirResourceName  OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The virtual resource name created by the user."
	::= { vrsVirResourceEntry 2 }

	vrsInquiry  OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The inquiry string of virtual resource."
	::= { vrsVirResourceEntry 3 }

	vrsCmdPending   OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of outstanding SCSI commands of virtual resource."
	::= { vrsVirResourceEntry 4 }

	vrsSize OBJECT-TYPE
		SYNTAX	Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of device size which is representing with megabyte unit of the virtual resource."
	::= { vrsVirResourceEntry 5 }

	vrsBlockSize    OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The size of bytes for each sector or block."
	::= { vrsVirResourceEntry 6 }

	vrsKBRead   OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of kilobytes have been read from the virtual resource."
	::= { vrsVirResourceEntry 7 }

	vrsKBWritten    OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of kilobytes have been written to the virtual resource."
	::= { vrsVirResourceEntry 8 }

	vrsSCSIReadCmd  OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of read SCSI commands have been sent to the virtual resource."
	::= { vrsVirResourceEntry 9 }

	vrsSCSIWriteCmd OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of write SCSI commands have been sent to the virtual resource."
	::= { vrsVirResourceEntry 10 }

	vrsOtherSCSICmd OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of not read or write SCSI commands have been sent to the virtual resource."
	::= { vrsVirResourceEntry 11 }

	vrsReadError    OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of SCSI commands that occur read error of the virtual resource."
	::= { vrsVirResourceEntry 12 }

	vrsWriteError   OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of SCSI commands that occur write error of the virtual resource."
	::= { vrsVirResourceEntry 13 }

	vrsRealDevTable OBJECT-TYPE
		SYNTAX  SEQUENCE OF VRSRealDev
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"A table containing usage and SCSI command statistics of physical devices that used by virtual resources."
	::= { vrsVirResourceEntry 14 }

	vrsRealDevEntry OBJECT-TYPE
		SYNTAX  VRSRealDev
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"Information about resource usage and SCSI commands have been read/write of physical resource."
		INDEX { vrsrdVirResourceID }
	::= { vrsRealDevTable 1 }

	VRSRealDev ::= SEQUENCE {
		vrsrdVirResourceID	INTEGER,
		vrsrdType	        DisplayString,
		vrsrdAdapterNo		INTEGER,
		vrsrdChannelNo		INTEGER,
		vrsrdScsiID		INTEGER,
		vrsrdLun		INTEGER,
		vrsrdFirstSector	Counter32,
		vrsrdLastSector		Counter32,
		vrsrdKBRead		INTEGER,
		vrsrdKBWritten		INTEGER,
		vrsrdSCSIReadCmd	INTEGER,
		vrsrdSCSIWriteCmd	INTEGER,
		vrsrdOtherSCSICmd	INTEGER,
		vrsrdReadError		INTEGER,
		vrsrdWriteError		INTEGER,
		vrsrdFirstSector64	Counter64,
		vrsrdLastSector64	Counter64,
		vrsrdKBRead64		Counter64,
		vrsrdKBWritten64	Counter64
	}

	vrsrdVirResourceID  OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The virtual resource ID assigned by the IPStor server."
	::= { vrsRealDevEntry 1 }

	vrsrdType   OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It represents the type(Primary, or Mirror) of the physical layout."
	::= { vrsRealDevEntry 2 }

	vrsrdAdapterNo  OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI adapter number of the physical device."
	::= { vrsRealDevEntry 3 }

	vrsrdChannelNo  OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI channel number of the physical device."
	::= { vrsRealDevEntry 4 }

	vrsrdScsiID OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI ID of the physical device."
	::= { vrsRealDevEntry 5 }

	vrsrdLun    OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI LUN number of the physical device."
	::= { vrsRealDevEntry 6 }

	vrsrdFirstSector    OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The first sector of the physical device which is allocated by the virtual resource."
	::= { vrsRealDevEntry 7 }

	vrsrdLastSector OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The last sector of the physical device which is allocated by the virtual resource."
	::= { vrsRealDevEntry 8 }
		
	vrsrdKBRead OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of kilobytes have been read from the physical resource."
	::= { vrsRealDevEntry 9 }

	vrsrdKBWritten  OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of kilobytes have been written to the physical resource."
	::= { vrsRealDevEntry 10 }

	vrsrdSCSIReadCmd OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of read SCSI commands have been sent to the physical resource."
	::= { vrsRealDevEntry 11 }

	vrsrdSCSIWriteCmd OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of write SCSI commands have been sent to the physical resource."
	::= { vrsRealDevEntry 12 }

	vrsrdOtherSCSICmd OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of not read or write SCSI commands have been sent to the physical resource."
	::= { vrsRealDevEntry 13 }

	vrsrdReadError OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of SCSI commands that occur read error of the physical resource."
	::= { vrsRealDevEntry 14 }

	vrsrdWriteError OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of SCSI commands that occur write error of the physical resource."
	::= { vrsRealDevEntry 15 }

	vrsClientTable  OBJECT-TYPE
		SYNTAX  SEQUENCE OF VRSClient
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"A table containing usage and SCSI command statistics of clients that assigned to virtual resources."
	::= { vrsVirResourceEntry 15 }

	vrsrdFirstSector64    OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The first sector of the physical device which is allocated by the virtual resource."
	::= { vrsRealDevEntry 16 }

	vrsrdLastSector64 OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The last sector of the physical device which is allocated by the virtual resource."
	::= { vrsRealDevEntry 17 }
		
	vrsrdKBRead64 OBJECT-TYPE
		SYNTAX	Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of kilobytes have been read from the physical resource."
	::= { vrsRealDevEntry 18 }

	vrsrdKBWritten64  OBJECT-TYPE
		SYNTAX	Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of kilobytes have been written to the physical resource."
	::= { vrsRealDevEntry 19 }

	vrsClientEntry  OBJECT-TYPE
		SYNTAX  VRSClient
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"Information about SCSI commands have been read/write of the clients."
		INDEX { vrsclClientName }
	::= { vrsClientTable 1 }

	VRSClient ::= SEQUENCE {
		vrsclClientName         DisplayString,
		vrsclClientID           INTEGER,
		vrsclVirResourceName    DisplayString,
		vrsclVirResourceID      INTEGER,
		vrsclAccess             DisplayString,
		vrsclConnAccess         DisplayString,
		vrsclConnected          DisplayString,
		vrsclKBRead             INTEGER,
		vrsclKBWritten          INTEGER,
		vrsclSCSIReadCmd        INTEGER,
		vrsclSCSIWriteCmd       INTEGER,
		vrsclOtherSCSICmd       INTEGER,
		vrsclReadError          INTEGER,
		vrsclWriteError         INTEGER,
		vrsclKBRead64           Counter64,
		vrsclKBWritten64        Counter64
	}

	vrsclClientName OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The client name assigned by the IPStor server."
	::= { vrsClientEntry 1 }

	vrsclClientID   OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The client ID assigned by the IPStor server."
	::= { vrsClientEntry 2 }

	vrsclVirResourceName    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The virtual resource name created by the user."
	::= { vrsClientEntry 3 }

	vrsclVirResourceID  OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The virtual resource ID assigned by the IPStor server."
	::= { vrsClientEntry 4 }

	vrsclAccess OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The virtual resource accessing mode assigned to the client."
	::= { vrsClientEntry 5 }

	vrsclConnAccess OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"Identify the accessing status with a virtual resource of the client."
	::= { vrsClientEntry 6 }

	vrsclConnected  OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"Identify the connecting status(on-line, or off-line) with a virtual resource of the client."
	::= { vrsClientEntry 7 }

	vrsclKBRead OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of kilobytes have been read by the client."
	::= { vrsClientEntry 8 }

	vrsclKBWritten  OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of kilobytes have been written by the client."
	::= { vrsClientEntry 9 }

	vrsclSCSIReadCmd    OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of read SCSI commands have been sent by the client."
	::= { vrsClientEntry 10 }

	vrsclSCSIWriteCmd   OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of write SCSI commands have been sent by the client."
	::= { vrsClientEntry 11 }

	vrsclOtherSCSICmd   OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of not read or write SCSI commands have been sent by the client."
	::= { vrsClientEntry 12 }

	vrsclReadError  OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of SCSI commands that occur read error sent by the client."
	::= { vrsClientEntry 13 }

	vrsclWriteError OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of SCSI commands that occur write error sent by the client."
	::= { vrsClientEntry 14 }

	vrsclKBRead64 OBJECT-TYPE
		SYNTAX	Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of kilobytes have been read by the client."
	::= { vrsClientEntry 15 }

	vrsclKBWritten64  OBJECT-TYPE
		SYNTAX	Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of kilobytes have been written by the client."
	::= { vrsClientEntry 16 }

	vrsSizeQuantity OBJECT-TYPE
		SYNTAX	Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of device size quantity of the virtual resource."
	::= { vrsVirResourceEntry 16 }

	vrsSizeUnit OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of device size unit of the virtual resource. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
	::= { vrsVirResourceEntry 17 }

	vrsSize64 OBJECT-TYPE
		SYNTAX	Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of device size which is representing with megabyte unit of the virtual resource."
	::= { vrsVirResourceEntry 18 }

	vrsKBRead64   OBJECT-TYPE
		SYNTAX	Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of kilobytes have been read from the virtual resource."
	::= { vrsVirResourceEntry 19 }

	vrsKBWritten64    OBJECT-TYPE
		SYNTAX	Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of kilobytes have been written to the virtual resource."
	::= { vrsVirResourceEntry 20 }

--
-- SNMP Trap Registration Group 
--

   	trapReg OBJECT IDENTIFIER ::= { ipstorserver 7 }

	trapAuthtrapenable  OBJECT-TYPE
        SYNTAX  INTEGER {
        	enable (1),
        	disable(2)
        }
        ACCESS  read-write
        STATUS  mandatory
        DESCRIPTION
            "The switch to generate the authentication failure trap if the community string is wrong. 
             The default value is 2 (disable)."
        ::= { trapReg 1 }
            
	trapCommunity   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-write
        STATUS  mandatory
        DESCRIPTION
            "It defines the default community string while sending traps."
        ::= { trapReg 2 }
            
	trapSinkSettingTable    OBJECT-TYPE
        SYNTAX  SEQUENCE OF TrapSinkSettingList
        ACCESS  not-accessible 
        STATUS  mandatory
        DESCRIPTION
            "A table containing all the management systems that would like to receive traps from IPStor server."
        ::= { trapReg 3 }
	 
	trapSinkSettingEntry    OBJECT-TYPE
        SYNTAX  TrapSinkSettingList
        ACCESS  not-accessible 
        STATUS  mandatory
        DESCRIPTION
            "Information about the community string and hosts that configured to receive traps.  The 5 is the maximum management systems allowed."
        INDEX { trIndex }
        ::= { trapSinkSettingTable 1 }

	TrapSinkSettingList ::= SEQUENCE {
	    trIndex     INTEGER,
	    trHost      DisplayString,
	    trCommunity DisplayString
	}
	    
	trIndex OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The sequential digit number as a index key of the trap sink table."
        ::= { trapSinkSettingEntry 1 }
	 
	trHost  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-write
        STATUS  mandatory
        DESCRIPTION
            "Identify the host name which is configured to receive traps from IPStor server." 
        ::= { trapSinkSettingEntry 2 }

	trCommunity OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-write
        STATUS  mandatory
        DESCRIPTION
            "Identify the community string to be used with the management system if it's not an empty string.
             If the empty string is set, the string configured by oid (.trapCommunity) will be used instead."
        ::= { trapSinkSettingEntry 3 }
                          
--
-- The Alarm Group (requires the implementation of the event group)
--

	alarmTable  OBJECT-TYPE
	    SYNTAX  SEQUENCE OF AlarmEntry
	    ACCESS  not-accessible
	    STATUS  mandatory
	    DESCRIPTION
		    "A table containing the alarm configurations of the IPStor server.  All these configurations that can be
		     modified is in the configuration file IPStorSNMPD.conf."
	    ::= { ipstorserver 8 }

	alarmEntry  OBJECT-TYPE
	    SYNTAX  AlarmEntry
	    ACCESS  not-accessible
	    STATUS  mandatory
	    DESCRIPTION
		    "Information about the the thresholds, monitor interval, and active status of the alarm table."
	    INDEX { alarmIndex }
	    ::= { alarmTable 1 }

	AlarmEntry ::= SEQUENCE {
	    alarmIndex              INTEGER,
	    alarmName			    DisplayString,
	    alarmVariable           DisplayString,
	    alarmMonitor		    INTEGER,
	    alarmInterval           INTEGER,
	    alarmValue              INTEGER,
	    alarmRisingThreshold    INTEGER,
	    alarmFallingThreshold   INTEGER,
	    alarmStatus             INTEGER
	}

	alarmIndex  OBJECT-TYPE
	    SYNTAX  INTEGER (1..65535)
	    ACCESS  read-only
	    STATUS  mandatory
	    DESCRIPTION
		    "The sequential digit number as a index key of the alarm table."
	    ::= { alarmEntry 1 }

	alarmName   OBJECT-TYPE
	    SYNTAX  DisplayString
	    ACCESS  read-only
	    STATUS  mandatory
	    DESCRIPTION
		    "Identify the type(process, module, or object identifier(OID)) is been monitored."
	    ::= { alarmEntry 2 }

	alarmVariable   OBJECT-TYPE
	    SYNTAX  DisplayString
	    ACCESS  read-only
	    STATUS  mandatory
	    DESCRIPTION
    		"Identify the process/module name, or the object identifier specified to be monitored."
	    ::= { alarmEntry 3 }

	alarmMonitor    OBJECT-TYPE
	    SYNTAX  INTEGER
	    ACCESS  read-write
	    STATUS  mandatory
	    DESCRIPTION
    		"It's time interval in second unit to check the monitored object if the value has over the rising threshold."
	    ::= { alarmEntry 4 }

	alarmInterval   OBJECT-TYPE
	    SYNTAX  INTEGER
	    ACCESS  read-write
	    STATUS  mandatory
	    DESCRIPTION
    		"It's time interval in second unit to check the monitored object if againt the thresholds."
	    ::= { alarmEntry 5 }

	alarmValue  OBJECT-TYPE
	    SYNTAX  INTEGER
	    ACCESS  read-only
	    STATUS  mandatory
	    DESCRIPTION
    		"The statistic value of the monitored object last sampled.
    		 If the the monitor entry is process or module, 0 stands for process down and 1 for process alive."
	    ::= { alarmEntry 6 }

	alarmRisingThreshold    OBJECT-TYPE
	    SYNTAX  INTEGER
	    ACCESS  read-write
	    STATUS  mandatory
	    DESCRIPTION
    		"A threshold sets for the upper-bound of the monitored object.  The event generated when the sampled
    		 value is greater than or equal to the threshold.  Once the event is generated, another such kind of 
    		 events will be ignored. 
    		 This object may not be modified if the associated alarmStatus object is enabled."
	    ::= { alarmEntry 7 }

	alarmFallingThreshold   OBJECT-TYPE
	    SYNTAX  INTEGER
	    ACCESS  read-write
	    STATUS  mandatory
	    DESCRIPTION
    		"A threshold sets for the lower-bound of the monitored object.  The event generated when the sampled
    		 value is less than or equal to the threshold.  Once the event is generated, another such kind of 
    		 events will be ignored.
    		 This object may not be modified if the associated alarmStatus object is enabled."
	    ::= { alarmEntry 8 }

	alarmStatus OBJECT-TYPE
	    SYNTAX  INTEGER {
			disable(0),
			enable (1)
		}
	    ACCESS  read-write
	    STATUS  mandatory
	    DESCRIPTION
		    "The active status of the alarm entry."
	    ::= { alarmEntry 9 }

-- ***************************************************************
-- IPStor Client group
-- ***************************************************************

	clientInfo OBJECT IDENTIFIER ::= { ipstorclient 1 }

	ipstorClientVersion	OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The version number of IPStor client."
	::= { clientInfo 1 }

	sanServers OBJECT IDENTIFIER ::= { ipstorclient 2 }

	numOfSANServers OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of IPStor servers that the client are connecting."
	::= { sanServers 1 }

	sanServerTable  OBJECT-TYPE
		SYNTAX  SEQUENCE OF SANServer
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"A table containing the IPStor servers which the client connected."
	::= { sanServers 2 }

	sanServerEntry  OBJECT-TYPE
		SYNTAX  SANServer
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"Information about the running environment, hardware compoments of IPStor server and statistic of read/write SCSI commands."
		INDEX { clsName }
	::= { sanServerTable 1 }

	SANServer ::= SEQUENCE {
		clsName			    DisplayString,
		clsIPAddress		DisplayString,
		clsType			    DisplayString,
		clsOS			    DisplayString,
		clsTypeOfCPU		DisplayString,
		clsNumOfCPU		    INTEGER,
		clsSpeedOfCPU		DisplayString,
		clsFlags		    DisplayString,
		clsDataPort		    INTEGER,
		clsManagePort		INTEGER,
		clsNumOfAdapters	INTEGER,
		clsNumOfDevices		INTEGER,
		clsVersion		    DisplayString,
		clsBuild		    DisplayString,
		clsReleaseDate		DisplayString,
		clsConnErrors		INTEGER,
		clsConn			    DisplayString,
		clsActivity		    DisplayString,
		clsSCSIReadCmds		INTEGER,
		clsSCSIWriteCmds	INTEGER,
		clsOtherSCSICmds	INTEGER,
		clsErrors		    INTEGER,
		clsDataRead		    DisplayString,
		clsDataWritten		DisplayString
--		clsAdapterList		OBJECT IDENTIFIER		
	}

	clsName OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The hostname of the IPStor server that the client connected."
	::= { sanServerEntry 1 }

	clsIPAddress    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The IP address of the IPStor server that the client connected."
	::= { sanServerEntry 2 }

	clsType OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The server type which the client connected."
	::= { sanServerEntry 3 }

	clsOS   OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The operation system version of the IPStor server is running."
	::= { sanServerEntry 4 }

	clsTypeOfCPU    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The models of CPU the the IPStor server owned."
	::= { sanServerEntry 5 }

	clsNumOfCPU OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of CPUs that the IPStor server owned."
	::= { sanServerEntry 6 }

	clsSpeedOfCPU   OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The power of CPU that the IPStor server owned."
	::= { sanServerEntry 7 }


	clsFlags    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"Identify the special property(UTF-8 encoding, IPv6/IPv4) of the IPStor server." 
	::= { sanServerEntry 8 }

	clsDataPort OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The UDP port number that used to send/receive data between IPStor server and client."
	::= { sanServerEntry 9 }

	clsManagePort   OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The UDP port number that used to send/receive managed data between IPStor server and client."
	::= { sanServerEntry 10 }

	clsNumOfAdapters    OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of SCSI adapters of the IPStor server."
	::= { sanServerEntry 11 }

	clsNumOfDevices OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of logical devices of the IPStor server."
	::= { sanServerEntry 12 }

	clsVersion  OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The version of the IPStor server."
	::= { sanServerEntry 13 }

	clsBuild    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The build number of the IPStor server."
	::= { sanServerEntry 14 }

	clsReleaseDate  OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The release date of the IPStor server version."
	::= { sanServerEntry 15 }

	clsConnErrors   OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of connection error with the IPStor server and client."
	::= { sanServerEntry 16 }

	clsConn OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The mandatory states which include Attached, Connected, Mounted, Registered, 
			 Skipped, or Disabled of the connection with IPStor server."
	::= { sanServerEntry 17 }

	clsActivity OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The activities which include Read, Write, Misc, Error, or Reconnect of the sorage server."
	::= { sanServerEntry 18 }

	clsSCSIReadCmds OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of read SCSI commands have been sent to the IPStor server."
	::= { sanServerEntry 19 }

	clsSCSIWriteCmds    OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of write SCSI commands have been sent to the IPStor server."
	::= { sanServerEntry 20 }

	clsOtherSCSICmds    OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of not read or write SCSI commands have been sent to the IPStor server."
	::= { sanServerEntry 21 }

	clsErrors   OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of SCSI commands that occur read/write error sent to the IPStor server."
	::= { sanServerEntry 22 }

	clsDataRead OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of bytes have been read from the IPStor server."
	::= { sanServerEntry 23 }

	clsDataWritten  OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of bytes have been write to the IPStor server."
	::= { sanServerEntry 24 }

	clsAdapterTable OBJECT-TYPE
		SYNTAX  SEQUENCE OF ClsAdapter
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"A table containing the adapters configured of the IPStor server."
	::= { sanServerEntry 25 }

	clsAdapterEntry OBJECT-TYPE
		SYNTAX  ClsAdapter
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"Information about the hardware configurations of the adapter."
		INDEX { clsaName }
	::= { clsAdapterTable 1 }

	ClsAdapter ::= SEQUENCE {
		clsaName                DisplayString,
		clsaAdapterNum          INTEGER,
		clsaChannels            INTEGER,
		clsaSCSIAddress         DisplayString,
		clsaLocalSCSIAddress    DisplayString
--		clsaDeviceList          OBJECT IDENTIFIER		
	}

	clsaName    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The hostname of the IPStor server that the client connected."
	::= { clsAdapterEntry 1 }

	clsaAdapterNum  OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI adapter number."
	::= { clsAdapterEntry 2 }

	clsaChannels    OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI channel number."
	::= { clsAdapterEntry 3 }

	clsaSCSIAddress OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI address with <Adapter:Channel:SCSI:LUN> format assigned by the IPStor server."
	::= { clsAdapterEntry 4 }

	clsaLocalSCSIAddress    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI address with <Adapter:Channel:SCSI:LUN> format assigned by the local client."
	::= { clsAdapterEntry 5 }

	clsaDeviceTable OBJECT-TYPE
		SYNTAX  SEQUENCE OF ClsaDevice
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"A table containing devices that attached to the adapter."
	::= { clsAdapterEntry 6 }

	clsaDeviceEntry OBJECT-TYPE
		SYNTAX  ClsaDevice
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"Information about the hardware configurations and read/write statistic of the device."
		INDEX { clsadName }
	::= { clsaDeviceTable 1 }

	ClsaDevice ::= SEQUENCE {
		clsadName               DisplayString,
		clsadAdapterNum         INTEGER,
		clsadDeviceName         DisplayString,
		clsadType               DisplayString,
		clsadAttachMode         DisplayString,
		clsadSCSIAddress        DisplayString,
		clsadLocalSCSIAddress   DisplayString,
		clsadLogicalDevice      DisplayString,
		clsadConnection         DisplayString,
		clsadActivity           DisplayString,
		clsadSCSIReadCmds       INTEGER,
		clsadSCSIWriteCmds      INTEGER,
		clsadOtherSCSICmds      INTEGER,
		clsadErrors             INTEGER,
		clsadDataRead           DisplayString,
		clsadDataWritten        DisplayString
--		clsadVolumeList         OBJECT IDENTIFIER		
	}

	clsadName   OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The hostname of the IPStor server that the client connected."
	::= { clsaDeviceEntry 1 }

	clsadAdapterNum OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI adapter number."
	::= { clsaDeviceEntry 2 }

	clsadDeviceName OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The resource name created by the user."
	::= { clsaDeviceEntry 3 }

	clsadType   OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It represents the resource type when user allocating the resource."
	::= { clsaDeviceEntry 4 }

	clsadAttachMode OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The resource accessing mode assigned by the user."
	::= { clsaDeviceEntry 5 }

	clsadSCSIAddress    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI address with <Adapter:Channel:SCSI:LUN> format assigned by the IPStor server."
	::= { clsaDeviceEntry 6 }

	clsadLocalSCSIAddress   OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI address with <Adapter:Channel:SCSI:LUN> format assigned by the local client."
	::= { clsaDeviceEntry 7}

	clsadLogicalDevice  OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The resource name created by the user."
	::= { clsaDeviceEntry 8}

	clsadConnection OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The current connected states which includes Attached, Connected, Mounted, Registered, Skipped, 
			 or Disable of the device."
	::= { clsaDeviceEntry 9}

	clsadActivity   OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"Current activities which includes Read, Write, Misc, Error, Reconnect or None of the device."
	::= { clsaDeviceEntry 10}

	clsadSCSIReadCmds   OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of read SCSI commands have been sent to the device."
	::= { clsaDeviceEntry 11 }

	clsadSCSIWriteCmds  OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of write SCSI commands have been sent to the device."
	::= { clsaDeviceEntry 12 }

	clsadOtherSCSICmds  OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of not read or write SCSI commands have been sent to the device."
	::= { clsaDeviceEntry 13 }

	clsadErrors OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of SCSI commands that occur read/write error sent to the device."
	::= { clsaDeviceEntry 14 }

	clsadDataRead   OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of bytes have been read from the device."
	::= { clsaDeviceEntry 15 }

	clsadDataWritten    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of bytes have been writen to the device."
	::= { clsaDeviceEntry 16 }

	clsadVolumeTable    OBJECT-TYPE
		SYNTAX  SEQUENCE OF ClsadVolume
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"A table containing volume created of the device."
	::= { clsaDeviceEntry 17 }

	clsadVolumeEntry    OBJECT-TYPE
		SYNTAX  ClsadVolume
		ACCESS  not-accessible
		STATUS	mandatory
		DESCRIPTION
			"Information about the hardware property and file system of one volume."
		INDEX { clsadvName }
	::= { clsadVolumeTable 1 }

	ClsadVolume ::= SEQUENCE {
		clsadvName              DisplayString,
		clsadvAdapterNum        INTEGER,
		clsadvDeviceName        DisplayString,
		clsadvLogicalVolumeName DisplayString,
		clsadvFS                DisplayString,
		clsadvLogical           DisplayString,
		clsadvTotalSize         DisplayString,
		clsadvAvailSize         DisplayString		
	}

	clsadvName  OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The hostname of the IPStor server that the client connected."
	::= { clsadVolumeEntry 1 }

	clsadvAdapterNum    OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI adapter number."
	::= { clsadVolumeEntry 2 }

	clsadvDeviceName    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The resource name created by the user."
	::= { clsadVolumeEntry 3 }

	clsadvLogicalVolumeName OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The volume name created by the user."
	::= { clsadVolumeEntry 4 }

	clsadvFS    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"Inentify the type of file system on the volume."
	::= { clsadVolumeEntry 5 }

	clsadvLogical   OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"Identify the drive letter if it's available."
	::= { clsadVolumeEntry 6 }

	clsadvTotalSize OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of the allocated size which is representing with byte unit."
	::= { clsadVolumeEntry 7 }

	clsadvAvailSize OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of the available size which is representing with byte unit."
	::= { clsadVolumeEntry 8 }
	
-- ***************************************************************
-- IPStor OEM type.
-- ***************************************************************
--
-- These are the returned values of the OEM type.
-- returned to:  .iso.org.dod.internet.mgmt.mib-2.system.sysObjectID.0
--

	companyName	OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"Identify the company name of the OEM product."
	::= { ipstoroeminfo 1 }

	productName	OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"Identify the OEM product name."
	::= { ipstoroeminfo 2 }

-- ***************************************************************
-- FalconStor Appliance Info.
-- ***************************************************************

      modelName   OBJECT-TYPE
            SYNTAX  DisplayString
            ACCESS  read-only
            STATUS  mandatory
            DESCRIPTION
                  "Identify the FalconStor appliance model."
      ::= { falconstorapplianceinfo 1 }

      serialNumber      OBJECT-TYPE
            SYNTAX  DisplayString
            ACCESS  read-only
            STATUS  mandatory
            DESCRIPTION
                  "Identify the FalconStor appliance serial number."
      ::= { falconstorapplianceinfo 2 }


-- ***************************************************************
-- IPStor SNMP Agent type.
-- ***************************************************************
--
-- These are the returned values of the agent type.
-- returned to:  .iso.org.dod.internet.mgmt.mib-2.system.sysObjectID.0
--
--	hpux9             OBJECT IDENTIFIER ::= { ipstorsnmpagent 1 }
--	hpux10            OBJECT IDENTIFIER ::= { ipstorsnmpagent 6 }
--	sunos4            OBJECT IDENTIFIER ::= { ipstorsnmpagent 2 }
--	solaris           OBJECT IDENTIFIER ::= { ipstorsnmpagent 3 }
--	osf               OBJECT IDENTIFIER ::= { ipstorsnmpagent 4 }
--	ultrix            OBJECT IDENTIFIER ::= { ipstorsnmpagent 5 }
--	netbsd1           OBJECT IDENTIFIER ::= { ipstorsnmpagent 7 }
--	freebsd           OBJECT IDENTIFIER ::= { ipstorsnmpagent 8 }
--	irix              OBJECT IDENTIFIER ::= { ipstorsnmpagent 9 }
--	linux             OBJECT IDENTIFIER ::= { ipstorsnmpagent 10 }
--	bsdi              OBJECT IDENTIFIER ::= { ipstorsnmpagent 11 }
--	openbsd           OBJECT IDENTIFIER ::= { ipstorsnmpagent 12 }

-- ***************************************************************
-- Related traps 
-- ***************************************************************

    statisticTrap   TRAP-TYPE
        ENTERPRISE  ipstor
        VARIABLES   { alarmValue, alarmRisingThreshold, alarmFallingThreshold }
        DESCRIPTION
            "When the sampled value of monitered object is greater than the threshold of upper-bound or 
	         less than the lower-bound, the snmp daemon of IPStor server will send out such kind of trap."
        ::= 1

    diskFullTrap    TRAP-TYPE
        ENTERPRISE  ipstor
        VARIABLES   { alarmValue, alarmRisingThreshold }
        DESCRIPTION
            "When the usage of virtual resource is greater than the threshold of upper-bound, the snmp daemon 
             of IPStor server will send out such kind of trap."
        ::= 2
        
    processDownTrap TRAP-TYPE
        ENTERPRISE  ipstor
        VARIABLES   { alarmName }
        DESCRIPTION 
            "When the monitored process or module is stop to service, the snmp daemon of IPStor server will send out such kind of trap."
        ::= 3
        
    failOverStartTrap   TRAP-TYPE
        ENTERPRISE  ipstor
        DESCRIPTION 
            "When the failover module start to take over the dead one, the snmp daemon of IPStor server will send out such kind of trap."
        ::= 4

    failOverRecoveredTrap   TRAP-TYPE
        ENTERPRISE  ipstor
        DESCRIPTION 
            "When the failover module start to recover from another one, the snmp daemon of IPStor server will send out such kind of trap."
        ::= 5

    criticalLogMessage  TRAP-TYPE
        ENTERPRISE  ipstor
        DESCRIPTION 
            "The IPStor console will receive all log messages of critical degree if the property is set via IPStor console."
        ::= 6

    errorLogMessage TRAP-TYPE
        ENTERPRISE  ipstor
        DESCRIPTION 
            "The IPStor console will receive all log messages of error degree if the property is set via IPStor console."
        ::= 7

    warningLogMessage   TRAP-TYPE
        ENTERPRISE  ipstor
        DESCRIPTION 
            "The IPStor console will receive all log messages of warning degree if the property is set via IPStor console."
        ::= 8
        
    informationalLogMessage TRAP-TYPE
        ENTERPRISE  ipstor
        DESCRIPTION 
            "The IPStor console will receive all log messages of informational degree if the property is set via IPStor console."
        ::= 9
END
