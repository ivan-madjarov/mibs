	sciscsiAcessRight	OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The target access rights of the iSCSI client."
	::= { scISCSIResourceEntry 16 }

	sciscsiTotalsize   OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of device size which is representing with megabyte unit of the resource."
