    ::= { srReplicaInfoEntry 6 }
    
    srReplicaWatermark  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The watermark sets to generate one new replication automatically."
