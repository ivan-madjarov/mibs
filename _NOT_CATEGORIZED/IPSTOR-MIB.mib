--
--  IPSTOR MIB
--			     
--
--  Last edit date: Mar. 29, 2011
--
--

IPSTOR-MIB DEFINITIONS ::= BEGIN

IMPORTS
	mgmt, enterprises, IpAddress,
	OBJECT-TYPE, private,
	Integer32, Counter32, IpAddress,
	mib-2, Unsigned32, Counter64
		FROM SNMPv2-SMI
	DisplayString
		FROM RFC1213-MIB
	TRAP-TYPE
		FROM RFC-1215;
        
--      ipstor MODULE-IDENTITY
--      LAST-UPDATED "110329000Z"
--      ORGANIZATION "FalconStor Software, Inc."
--      CONTACT-INFO    
--      Primary Author: FalconStor Software, Inc.
--
--      US: 
--      postal:  2 Huntington Quadrangle
--		 Suite 2S01
--               Melville, NY 11747
--      phone:   631 777-3332
--
--      Asia:
--      postal:  6F-1,No.512, Section 1, 
--               Wunsin Road, 
--               Taichung, 
--               Taiwan, 403, R.O.C. 
--      phone:   +886-4-2258-6118
--
--      email:   support@falconstor.com"
--
--	DESCRIPTION
--	"This file defines the private IPStor MIB extensions."
--	::= { enterprises 7368 }
    
    ipstor OBJECT IDENTIFIER ::= { enterprises 7368 }

--------------------------------------------------------------------

	revisionNumber  OBJECT-TYPE
		SYNTAX  DisplayString (SIZE (4))
		ACCESS  read-only 
		STATUS  mandatory 
		DESCRIPTION
			"This is the revision number for this MIB. The format of the revision value is as follows
				(0) = high order major revision number
				(1) = low order major revision number
				(2) = high order minor revision number
				(3) = low order minor revision number
			The value will be stored as an ASCII value. The	following is the mandatory value of this object.
				(0) = '0'
				(1) = '1'
				(2) = '0'
				(3) = '0'
			This defines a revision of 01.00"
	::= { ipstor 1 }
        
	isServerOrClient	OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It indicates the current running system is server or client version."
	::= { ipstor 2 }

	ipstorserver       OBJECT IDENTIFIER ::= { ipstor 3 }
	ipstorclient       OBJECT IDENTIFIER ::= { ipstor 4 }
--	ipstorsnmpagent    OBJECT IDENTIFIER ::= { ipstor 5 }
	ipstoroeminfo      OBJECT IDENTIFIER ::= { ipstor 10 }
	falconstorapplianceinfo	OBJECT IDENTIFIER ::= { ipstor 11 }

-- ***************************************************************
-- IPStor Server Group
-- ***************************************************************

--
-- Server Info
--
	serverInfo OBJECT IDENTIFIER ::= { ipstorserver 1 }

	serverName  OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The hostname which the IPStor server is running."
	::= { serverInfo 1 }
	
	loginMachineName    OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"Identify which IPStor server you are login."
	::= { serverInfo 2 }

	serverVersion   OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The IPStor server version and build number."
	::= { serverInfo 3 }

	osVersion   OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The operation system version of the host the IPStor server is running."
	::= { serverInfo 4 }

	kernelVersion   OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The kernel version of the host the IPStor server is running."
	::= { serverInfo 5 }

	processorTable  OBJECT-TYPE
		SYNTAX  SEQUENCE OF ProcessorEntry
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"A table containing the information of all processors in the host which the IPStor server is running."
	::= { serverInfo 6 }

	processorEntry  OBJECT-TYPE
		SYNTAX  ProcessorEntry
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"Information the specification of processor."
		INDEX { processorNo }
	::= { processorTable 1 }

	ProcessorEntry ::= SEQUENCE {
		processorNo	    INTEGER,
		processorInfo	DisplayString
	}

	processorNo OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The sequential digit number as a index key of the processor table."
	::= { processorEntry 1 }

	processorInfo   OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The specification of a processor type and power."
	::= { processorEntry 2 }

	memory  OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The amount of memory which the IPStor server is running."
	::= { serverInfo 7 }

	swap    OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The swap space of the host which the sIPStor erver is running."
	::= { serverInfo 8 }

	netInterfaceTable   OBJECT-TYPE
		SYNTAX  SEQUENCE OF NetInterface
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"A table containing the information of all network interfaces in the host which the IPStor server is running."
	::= { serverInfo 9 }

	netInterfaceEntry   OBJECT-TYPE
		SYNTAX  NetInterface
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"Information the specification of network interface."
		INDEX { netInterfaceNo }
	::= { netInterfaceTable 1 }

	NetInterface ::= SEQUENCE {
		netInterfaceNo		INTEGER,
		netInterfaceInfo	DisplayString
	}

	netInterfaceNo  OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The sequential digit number as a index key of network interface table."
	::= { netInterfaceEntry 1 }	

	netInterfaceInfo    OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The specification containing MAC, IP address and MTU of a network interface."
	::= { netInterfaceEntry 2 }	
	
	failoverInformationTable    OBJECT-TYPE
		SYNTAX  SEQUENCE OF FailoverInformation
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"A table containing the failover information which is currently configured of the IPStor server."
	::= { serverInfo 10 }

	failoverInformationEntry    OBJECT-TYPE
		SYNTAX  FailoverInformation
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"Information for the configured failover mode and state."
		INDEX { foIndex }
	::= { failoverInformationTable 1 }

	FailoverInformation ::= SEQUENCE {
		foIndex				INTEGER,
		foName				DisplayString,
		foValue				DisplayString,
		foConfType			DisplayString,
		foPartner			DisplayString,
		foPrimaryIPResource		DisplayString,
		foSecondaryIPResource		DisplayString,
		foCheckInterval			DisplayString,
--		foMemDumpMonitorIP		DisplayString,
		foHeartbeatInterval		DisplayString,
		foRecoverySetting		DisplayString,
		foState				DisplayString,
		foPrimaryStorageClusterInterlinkIP		DisplayString,
		foSecondaryStorageClusterInterlinkIP		DisplayString,
		foSuspended			DisplayString,
		foPowerControl			DisplayString,
		fofcWWPN			DisplayString
	}

	foIndex OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The sequential digit number as a index key of failover table."
	::= { failoverInformationEntry 1 }	

	foName  OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The property of a failover configuration."
	::= { failoverInformationEntry 2 }	

	foValue OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The setting value of a failover configuration."
	::= { failoverInformationEntry 3 }

	foConfType OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The Configuration Type of a failover configuration."
	::= { failoverInformationEntry 4 }

	foPartner OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The Failover Partner of a failover configuration."
	::= { failoverInformationEntry 5 }

	foPrimaryIPResource OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The IPStor Primary Server IP Resource of a failover configuration."
	::= { failoverInformationEntry 6 }

	foSecondaryIPResource OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The IPStor Secondary Server IP Resource of a failover configuration."
	::= { failoverInformationEntry 7 }

	foCheckInterval OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The Self Check Interval of a failover configuration."
	::= { failoverInformationEntry 8 }

--	foMemDumpMonitorIP OBJECT-TYPE
--		SYNTAX  DisplayString
--		ACCESS  read-only
--		STATUS  mandatory
--		DESCRIPTION
--			"The Memory Dump Monitoring IP Address of a failover configuration."
--	::= { failoverInformationEntry 9 }

	foHeartbeatInterval OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The Heartbeat Interval of a failover configuration."
	::= { failoverInformationEntry 9 }

	foRecoverySetting OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The Recovery Setting of a failover configuration."
	::= { failoverInformationEntry 10 }

	foState OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The Failover State of a failover configuration."
	::= { failoverInformationEntry 11 }

	foPrimaryStorageClusterInterlinkIP OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The primary internal link between two servers to mirror snapshot and SafeCache metadata between high-availability(HA) pairs."
	::= { failoverInformationEntry 12 }

	foSecondaryStorageClusterInterlinkIP OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The secondary internal link between two servers to mirror snapshot and SafeCache metadata between high-availability(HA) pairs."
	::= { failoverInformationEntry 13 }

	foSuspended OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The Suspended status of a failover configuration."
	::= { failoverInformationEntry 14 }

	foPowerControl OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The Power Control of a failover configuration."
	::= { failoverInformationEntry 15 }

	fofcWWPN OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The Fibre Channel  WWPN of a failover configuration."
	::= { failoverInformationEntry 16 }
	
	fcInfoTable OBJECT-TYPE
		SYNTAX  SEQUENCE OF FcInfoList
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"A table containing the information of all Fibre Channel HBAs of the IPStor server."
	::= { serverInfo 11 }

	fcInfoEntry OBJECT-TYPE
		SYNTAX  FcInfoList
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"Information the hardware specification and configured access mode."
		INDEX { fcIndex }
	::= { fcInfoTable 1 }

	FcInfoList ::= SEQUENCE {
		fcIndex	INTEGER,
		fcWWPN	DisplayString,
		fcMode	DisplayString,
		fcTargetWWPN	DisplayString
	}

	fcIndex OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The sequential digit number as a index key of the fibre channel table."
	::= { fcInfoEntry 1 }

	fcWWPN  OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"This will display the WWPN (World Wide Port Name) information of a Fibre Channel HBA. 
			 This WWPN is a unique vendor assigned 64bit identifier which is assigned to each port within a FC HBA."
	::= { fcInfoEntry 2 }

	fcMode  OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"It indicates if the HBA is configured to an Initiator or Target mode of the IPStor server."
	::= { fcInfoEntry 3 }

	fcTargetWWPN  OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"This will display the Taget WWPN (World Wide Port Name) information of a Fibre Channel HBA when enables the HBA runs with dual mode.
			 This WWPN is a unique vendor assigned 64bit identifier which is assigned to each port within a FC HBA."
	::= { fcInfoEntry 4 }

	serverOption OBJECT IDENTIFIER ::= { serverInfo 12 }

	nasOption   OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"It indicates the status of NAS option is enable or disable of the IPStor server."
	::= { serverOption 1 }
	
	fibreChannelOption  OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"It indicates the status of Fibre Channel option is enable or disable of the IPStor server."
	::= { serverOption 2 }
	
	replicationOption  OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"It indicates the status of Replication option is enable or disable of the IPStor server."
	::= { serverOption 3 }

	syncMirroringOption   OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"It indicates the status of synchronized Mirroring option is enable or disable of the IPStor server."
	::= { serverOption 4 }
	
    timemarkOption  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "It indicates the status of Timemark option is enable or disable of the IPStor server."
    ::= { serverOption 6 }
    
    zeroimpactOption    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "It indicates the status of Zero Impact Backup option is enable or disable of the IPStor server."
    ::= { serverOption 7 }
	
	MTCPVersion  OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The MTCP Version which the IPStor server uses."
	::= { serverInfo 13 }

	performanceTable  OBJECT-TYPE
		SYNTAX  SEQUENCE OF PerformanceEntry
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"A table containing the information of the performance in the host which the IPStor server is running."
	::= { serverInfo 14 }

	performanceEntry  OBJECT-TYPE
		SYNTAX  PerformanceEntry
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"Information the specification of performance."
		INDEX { performanceMirrorSyncTH }
	::= { performanceTable 1 }

	PerformanceEntry ::= SEQUENCE {
		performanceMirrorSyncTH		INTEGER,
		performanceSyncMirrorInterval	DisplayString,
		performanceSyncMirrorRetry	INTEGER,
		performanceSyncMirrorUpnum	Counter32,
		performanceInitialMirrorSync	DisplayString,
		performanceIncludeReplicaMirror DisplayString,
		performanceReplicationMicroscan	DisplayString
	}

	performanceMirrorSyncTH OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The Mirror Synchronization Throttle of the performance table."
	::= { performanceEntry 1 }


	performanceSyncMirrorInterval OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The Synchronize out-of-sync mirrors Interval of the performance table."
	::= { performanceEntry 2 }

	performanceSyncMirrorRetry OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The Synchronize out-of-sync mirrors retry times of the performance table."
	::= { performanceEntry 3 }

	performanceSyncMirrorUpnum OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The Synchronize out-of-sync mirrors up numbers at each interval of the performance table."
	::= { performanceEntry 4 }

	performanceInitialMirrorSync OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The option of starting initial synchronize when mirror is added of the performance table."
	::= { performanceEntry 5 }

	performanceIncludeReplicaMirror OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The option of including replica mirror in the automatic synchronize process of the performance table."
	::= { performanceEntry 6 }

	performanceReplicationMicroscan   OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"It indicates the Microscan option of Replication is enable or disable of the IPStor server."
	::= { performanceEntry 7 }

	serverRole   OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The IPStor server Role."
	::= { serverInfo 15 }

	smisoption   OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The IPStor server SMI-S option."
	::= { serverInfo 16 }

	ServerIPaliasTable  OBJECT-TYPE
		SYNTAX  SEQUENCE OF ServerIPaliasEntry
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"A table containing the information of the IP alias in the host which the IPStor server is running."
	::= { serverInfo 17 }

	ServerIPaliasEntry  OBJECT-TYPE
		SYNTAX  ServerIPAliasEntry
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"Information the specification of server IP alias."
		INDEX { ServerIPaliasIP }
	::= { ServerIPaliasTable 1 }

	ServerIPAliasEntry ::= SEQUENCE {
		ServerIPaliasIP		DisplayString
	}

	ServerIPaliasIP   OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The IPStor server IP Alias."
	::= { ServerIPaliasEntry 1 }

	iSCSIportal   OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The IPStor server iSCSI default portal."
	::= { serverInfo 18 }

	DHCPTable  OBJECT-TYPE
		SYNTAX  SEQUENCE OF DHCPEntry
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"A table containing the information of the DHCP setting in the host which the IPStor server is running."
	::= { serverInfo 19 }

	DHCPEntry  OBJECT-TYPE
		SYNTAX  DHCPInfoEntry
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"Information the specification of DHCP."
		INDEX { DHCPOption }
	::= { DHCPTable 1 }

	DHCPInfoEntry ::= SEQUENCE {
		DHCPOption		DisplayString,
		DHCPNameServer		DisplayString,
		DHCPNetmask		DisplayString,
		DHCPGateway		DisplayString,
		DHCPIPrangeBegin	DisplayString,
		DHCPIPrangeEnd		DisplayString
	}

	DHCPOption OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The option of the DHCP table."
	::= { DHCPEntry 1 }

	DHCPNameServer OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The name server of the DHCP table."
	::= { DHCPEntry 2 }

	DHCPNetmask OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The netmask of the DHCP table."
	::= { DHCPEntry 3 }

	DHCPGateway OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The gateway of the DHCP table."
	::= { DHCPEntry 4 }

	DHCPIPrangeBegin OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The begin IP range of the DHCP table."
	::= { DHCPEntry 5 }

	DHCPIPrangeEnd OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The end IP range of the DHCP table."
	::= { DHCPEntry 6 }

	ActivityDBMaintenanceTable  OBJECT-TYPE
		SYNTAX  SEQUENCE OF ActivityDBMaintenanceEntry
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"A table containing the information of the Activity Database maintenanace of the IPStor server."
	::= { serverInfo 20 }

	ActivityDBMaintenanceEntry  OBJECT-TYPE
		SYNTAX  ActivityDBMaintenanceInfoEntry
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"Information the specification of activity database maintenance."
		INDEX { MAXActDBSize }
	::= { ActivityDBMaintenanceTable 1 }

	ActivityDBMaintenanceInfoEntry ::= SEQUENCE {
		MAXActDBSize		Counter32,
		NumofDaystoKeep		Counter32
	}

	MAXActDBSize OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The Maximum activity data file size(MB) of the Activity Database Maintenance table."
	::= { ActivityDBMaintenanceEntry 1 }

	NumofDaystoKeep OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The Number of days of activities to keep of the Activity Database Maintenance table."
	::= { ActivityDBMaintenanceEntry 2 }

	StatisticsLogsTable  OBJECT-TYPE
		SYNTAX  SEQUENCE OF StatisticsLogsEntry
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"A table containing the information of the Statistics Logs Option in the host which the IPStor server is running."
	::= { serverInfo 21 }

	StatisticsLogsEntry  OBJECT-TYPE
		SYNTAX  StatisticsLogsInfoEntry
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"Information the specification of Statistics Log option."
		INDEX { StatisticsLogsOption }
	::= { StatisticsLogsTable 1 }

	StatisticsLogsInfoEntry ::= SEQUENCE {
		StatisticsLogsOption		DisplayString,
		StatisticsLogsLogOption		DisplayString,
		StatisticsLogsStartTime		DisplayString,
		StatisticsLogsInterval		DisplayString,
		StatisticsLogsPurgeTime		DisplayString
	}

	StatisticsLogsOption OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The option of the statistics logs table."
	::= { StatisticsLogsEntry 1 }

	StatisticsLogsLogOption OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The log option of the statistics logs table."
	::= { StatisticsLogsEntry 2 }

	StatisticsLogsStartTime OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The start time of the statistics logs table."
	::= { StatisticsLogsEntry 3 }

	StatisticsLogsInterval OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The interval of the statistics logs table."
	::= { StatisticsLogsEntry 4 }

	StatisticsLogsPurgeTime OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The purge time of the statistics logs table."
	::= { StatisticsLogsEntry 5 }

	AutoSaveConfigTable  OBJECT-TYPE
		SYNTAX  SEQUENCE OF AutoSaveConfigEntry
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"A table containing the information of the auto save configuration in the host which the IPStor server is running."
	::= { serverInfo 22 }

	AutoSaveConfigEntry  OBJECT-TYPE
		SYNTAX  AutoSaveConfigInfoEntry
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"Information the specification of auto save configuration."
		INDEX { AutoSaveConfigOption }
	::= { AutoSaveConfigTable 1 }

	AutoSaveConfigInfoEntry ::= SEQUENCE {
		AutoSaveConfigOption		DisplayString,
		AutoSaveConfigFtpServerName	DisplayString,
		AutoSaveConfigFtpPort		Counter32,
		AutoSaveConfigTargetDirectory	DisplayString,
		AutoSaveConfigInterval		DisplayString,
		AutoSaveConfigCopiesNumber	Counter32
	}

	AutoSaveConfigOption OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The option of the auto save configuration table."
	::= { AutoSaveConfigEntry 1 }

	AutoSaveConfigFtpServerName OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The ftp server name of the auto save configuration table."
	::= { AutoSaveConfigEntry 2 }

	AutoSaveConfigFtpPort OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The ftp port of the auto save configuration table."
	::= { AutoSaveConfigEntry 3 }

	AutoSaveConfigTargetDirectory OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The target directory of the auto save configuration table."
	::= { AutoSaveConfigEntry 4 }

	AutoSaveConfigInterval OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The interval of the auto save configuration table."
	::= { AutoSaveConfigEntry 5 }

	AutoSaveConfigCopiesNumber OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The number of copies of the auto save configuration table."
	::= { AutoSaveConfigEntry 6 }

	CDPPerformanceTable  OBJECT-TYPE
		SYNTAX  SEQUENCE OF CDPPerformanceEntry
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"A table containing the information of the auto save configuration in the host which the IPStor server is running."
	::= { serverInfo 23 }

	CDPPerformanceEntry  OBJECT-TYPE
		SYNTAX  CDPPerformanceInfoEntry
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"Information the specification of auto save configuration."
		INDEX { CDPPerformanceAggressiveThreshold }
	::= { CDPPerformanceTable 1 }

	CDPPerformanceInfoEntry ::= SEQUENCE {
		CDPPerformanceAggressiveThreshold		Counter32,
		CDPPerformanceAggressiveDataFlushSpeed		Counter32,
		CDPPerformanceAggressiveInactDataFlsuhSpeed	Counter32,
		CDPPerformanceModerateThreshold			Counter32,
		CDPPerformanceModerateDataFlushSpeed		Counter32,
		CDPPerformanceModerateInactDataFlsuhSpeed	Counter32
	}

	CDPPerformanceAggressiveThreshold OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The aggressive threshold of the CDP performance table."
	::= { CDPPerformanceEntry 1 }

	CDPPerformanceAggressiveDataFlushSpeed OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The aggressive data flush speed of the CDP performance table."
	::= { CDPPerformanceEntry 2 }

	CDPPerformanceAggressiveInactDataFlsuhSpeed OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The aggressive data flush speed during inactivity of the CDP performance table."
	::= { CDPPerformanceEntry 3 }

	CDPPerformanceModerateThreshold OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The moderate threshold of the CDP performance table."
	::= { CDPPerformanceEntry 4 }

	CDPPerformanceModerateDataFlushSpeed OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The moderate data flush speed of the CDP performance table."
	::= { CDPPerformanceEntry 5 }

	CDPPerformanceModerateInactDataFlsuhSpeed OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The moderate data flush speed during inactivity of the CDP performance table."
	::= { CDPPerformanceEntry 6 }

	StatisticsNASTable  OBJECT-TYPE
		SYNTAX  SEQUENCE OF StatisticsNASEntry
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"A table containing the information of the Statistics gathering for NAS of the IPStor server."
	::= { serverInfo 24 }

	StatisticsNASEntry  OBJECT-TYPE
		SYNTAX  StatisticsNASInfoEntry
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"Information the specification of statistics gathering for NAS."
		INDEX { StatisticsNASOption }
	::= { StatisticsNASTable 1 }

	StatisticsNASInfoEntry ::= SEQUENCE {
		StatisticsNASOption		DisplayString,
		StatisticsNASInterval		Counter32
	}

	StatisticsNASOption OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The option of the statistics gathering for NAS table."
	::= { StatisticsNASEntry 1 }

	StatisticsNASInterval OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The interval of the statistics gathering for NAS table."
	::= { StatisticsNASEntry 2 }

	SNMPMaintenanceTable  OBJECT-TYPE
		SYNTAX  SEQUENCE OF SNMPMaintenanceEntry
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"A table containing the information of the SNMP maintenance in the host which the IPStor server is running."
	::= { serverInfo 25 }

	SNMPMaintenanceEntry  OBJECT-TYPE
		SYNTAX  SNMPMaintenanceInfoEntry
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"Information the specification of SNMP maintenance."
		INDEX { SNMPMaintenanceTrapLevel }
	::= { SNMPMaintenanceTable 1 }

	SNMPMaintenanceInfoEntry ::= SEQUENCE {
		SNMPMaintenanceTrapLevel		DisplayString,
		SNMPMaintenanceServer			DisplayString,
		SNMPMaintenanceCommunity		DisplayString
	}

	SNMPMaintenanceTrapLevel OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The trap level of the SNMP maintenance table."
	::= { SNMPMaintenanceEntry 1 }

	SNMPMaintenanceServer OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The trap receive server of the SNMP maintenance table."
	::= { SNMPMaintenanceEntry 2 }

	SNMPMaintenanceCommunity OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The trap send community of the SNMP maintenance table."
	::= { SNMPMaintenanceEntry 3 }

	TimeMarkMaintenanceTable  OBJECT-TYPE
		SYNTAX  SEQUENCE OF TimeMarkMaintenanceEntry
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"A table containing the information of the TimeMark maintenance in the host which the IPStor server is running."
	::= { serverInfo 26 }

	TimeMarkMaintenanceEntry  OBJECT-TYPE
		SYNTAX  TimeMarkMaintenanceInfoEntry
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"Information the specification of TimeMark maintenance."
		INDEX { TimeMarkMaintenanceSchedule }
	::= { TimeMarkMaintenanceTable 1 }

	TimeMarkMaintenanceInfoEntry ::= SEQUENCE {
		TimeMarkMaintenanceSchedule			DisplayString,
		TimeMarkMaintenanceReclamOption			DisplayString,
		TimeMarkMaintenanceReclamThreshold		DisplayString,
		TimeMarkMaintenanceReclamStartTime		DisplayString,
		TimeMarkMaintenanceReclamRepeatTime		DisplayString,
		TimeMarkMaintenanceReclamMaxProcessingTime	DisplayString
	}

	TimeMarkMaintenanceSchedule OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The schedule to start timemark maintenance."
	::= { TimeMarkMaintenanceEntry 1 }

	TimeMarkMaintenanceReclamOption OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The option of reclamation in TimeMark maintenance."
	::= { TimeMarkMaintenanceEntry 2 }

	TimeMarkMaintenanceReclamThreshold OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The threshold for minimum amount of space that can be reclamed per TimeMark."
	::= { TimeMarkMaintenanceEntry 3 }

	TimeMarkMaintenanceReclamStartTime OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The start schedule time of reclamation in TimeMark maintenance."
	::= { TimeMarkMaintenanceEntry 4 }

	TimeMarkMaintenanceReclamRepeatTime OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The repeat schedule interval of reclamation in TimeMark maintenance."
	::= { TimeMarkMaintenanceEntry 5 }

	TimeMarkMaintenanceReclamMaxProcessingTime OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The maximum time for the reclamation process in TimeMark maintenance."
	::= { TimeMarkMaintenanceEntry 6 }

	LocationTable  OBJECT-TYPE
		SYNTAX  SEQUENCE OF LocationEntry
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"A table containing the information of the location setting in the host which the IPStor server is running."
	::= { serverInfo 27 }

	LocationEntry  OBJECT-TYPE
		SYNTAX  LocationInfoEntry
		ACCESS	not-accessible
		STATUS  mandatory
		DESCRIPTION
			"Information the specification of Location."
		INDEX { LCLocation }
	::= { LocationTable 1 }

	LocationInfoEntry ::= SEQUENCE {
		LCLocation	DisplayString,
		LCRoom		DisplayString,
		LCFloor		DisplayString,
		LCBuilding	DisplayString,
		LCAddress	DisplayString,
		LCCity		DisplayString,
		LCState		DisplayString,
		LCZipCode	DisplayString,
		LCCountry	DisplayString,
		LCOwner		DisplayString,
		LCOwnersPhone	DisplayString,
		LCOwnersEmail	DisplayString,
		LCOwnersIM	DisplayString,
		LCDescription	DisplayString,
		LCImagepath	DisplayString
	}

	LCLocation OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The location field of location setting table."
	::= { LocationEntry 1 }

	LCRoom OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The room field of location setting table."
	::= { LocationEntry 2 }

	LCFloor OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The floor field of location setting table."
	::= { LocationEntry 3 }

	LCBuilding OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The building field of location setting table."
	::= { LocationEntry 4 }

	LCAddress OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The address field of location setting table."
	::= { LocationEntry 5 }

	LCCity OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The city field of location setting table."
	::= { LocationEntry 6 }

	LCState OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The state field of location setting table."
	::= { LocationEntry 7 }

	LCZipCode OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The zip code field of location setting table."
	::= { LocationEntry 8 }

	LCCountry OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The country field of location setting table."
	::= { LocationEntry 9 }

	LCOwner OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The owner field of location setting table."
	::= { LocationEntry 10 }

	LCOwnersPhone OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The owner's phone field of location setting table."
	::= { LocationEntry 11 }

	LCOwnersEmail OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS	mandatory
		DESCRIPTION
			"The owner's e-mail field of location setting table."
