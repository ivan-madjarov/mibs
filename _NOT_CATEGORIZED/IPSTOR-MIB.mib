    snapshotgroupSafeCacheInfoTable OBJECT IDENTIFIER ::= {snapshotgroupResourcesInfoEntry 8 }
    
    snapshotgroupSafeCacheInfoTableEntry    OBJECT-TYPE
        SYNTAX  SSGCacheInfo
        ACCESS  not-accessible
        STATUS  mandatory
        DESCRIPTION
            "Information about the policy and configuration of the safecache function."
        INDEX { snapshotgroupCacheInfoGroupID }
    ::= { snapshotgroupSafeCacheInfoTable 1 }

    SSGCacheInfo ::= SEQUENCE {
        snapshotgroupCacheInfoGroupID			INTEGER,
        snapshotgroupCacheInfoOption			DisplayString,
        snapshotgroupCacheInfoSuspend			DisplayString,
        snapshotgroupCacheInfoTotalSize			Counter32,
        snapshotgroupCacheInfoFreeSize			Counter32,
        snapshotgroupCacheInfoUsage			INTEGER,
	snapshotgroupCacheInfoThreshold			INTEGER,
        snapshotgroupCacheInfoFlushTime			INTEGER,
        snapshotgroupCacheInfoSkipWriteCommands		DisplayString,
        snapshotgroupCacheInfoFlushSpeed		INTEGER,
        snapshotgroupCacheInfoTotalSizeQuantity		Counter32,
        snapshotgroupCacheInfoTotalSizeUnit		INTEGER,
        snapshotgroupCacheInfoFreeSizeQuantity		Counter32,
        snapshotgroupCacheInfoFreeSizeUnit		INTEGER,
        snapshotgroupCacheInfoResourceID		INTEGER,
        snapshotgroupCacheInfoTotalSize64		Counter64,
        snapshotgroupCacheInfoFreeSize64		Counter64,
        snapshotgroupCacheInfoStatus			DisplayString
    }

    snapshotgroupCacheInfoGroupID   OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The snapshot group resource ID assigned by the IPStor server."
    ::= { snapshotgroupSafeCacheInfoTableEntry 1 }
    
    snapshotgroupCacheInfoOption   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the snapshot group safecache option is enable or disable of the IPStor server."
    ::= { snapshotgroupSafeCacheInfoTableEntry 2 }
    
    snapshotgroupCacheInfoSuspend  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The group safecache resource is currently suspended or not."
    ::= { snapshotgroupSafeCacheInfoTableEntry 3 }
    
    snapshotgroupCacheInfoTotalSize    OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The allocated size when creating the cache resource."
    ::= { snapshotgroupSafeCacheInfoTableEntry 4 }
    
    snapshotgroupCacheInfoFreeSize OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The free resource size which is representing in megabyte unit before reaching the maximum resource size."
    ::= { snapshotgroupSafeCacheInfoTableEntry 5 }

    snapshotgroupCacheInfoUsage    OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The percentage of the used resource size."
    ::= { snapshotgroupSafeCacheInfoTableEntry 6 }
    
    snapshotgroupCacheInfoThreshold    OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The data needs to be in the cache before beginning flushing the cache."
    ::= { snapshotgroupSafeCacheInfoTableEntry 7 }
    
    snapshotgroupCacheInfoFlushTime    OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The number of milliseconds before cache begins to flush when below the data threshold level."
    ::= { snapshotgroupSafeCacheInfoTableEntry 8 }
    
    snapshotgroupCacheInfoSkipWriteCommands    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "This option allows the system to skip multiple pending write commands targeted for the same block."
    ::= { snapshotgroupSafeCacheInfoTableEntry 9 }

    snapshotgroupCacheInfoFlushSpeed OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The flush speed will be sent at one time during the flush process."
    ::= { snapshotgroupSafeCacheInfoTableEntry 10 }
    
    snapshotgroupCacheInfoTotalSizeQuantity    OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The allocated size quantity when creating the cache resource."
    ::= { snapshotgroupSafeCacheInfoTableEntry 11 }
    
    snapshotgroupCacheInfoTotalSizeUnit    OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The allocated size unit when creating the cache resource. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
    ::= { snapshotgroupSafeCacheInfoTableEntry 12 }
    
    snapshotgroupCacheInfoFreeSizeQuantity OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The free resource size quantity before reaching the maximum resource size."
    ::= { snapshotgroupSafeCacheInfoTableEntry 13 }
    
    snapshotgroupCacheInfoFreeSizeUnit OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The free resource size unit before reaching the maximum resource size. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
    ::= { snapshotgroupSafeCacheInfoTableEntry 14 }

    snapshotgroupCacheInfoResourceID   OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The Cache resource ID assigned by the IPStor server."
    ::= { snapshotgroupSafeCacheInfoTableEntry 15 }
    
    snapshotgroupCacheInfoTotalSize64    OBJECT-TYPE
        SYNTAX  Counter64
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The allocated size when creating the cache resource."
    ::= { snapshotgroupSafeCacheInfoTableEntry 16 }
    
    snapshotgroupCacheInfoFreeSize64 OBJECT-TYPE
        SYNTAX  Counter64
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The free resource size which is representing in megabyte unit before reaching the maximum resource size."
    ::= { snapshotgroupSafeCacheInfoTableEntry 17 }
    
    snapshotgroupCacheInfoStatus  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status of the snapshot group safecache of the IPStor server."
    ::= { snapshotgroupSafeCacheInfoTableEntry 18 }
		
