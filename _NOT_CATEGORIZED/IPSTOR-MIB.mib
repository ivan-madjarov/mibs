--        DESCRIPTION
--            "Amount quantity to allocate when expansion is triggered of the CDP Journal Storage."
--    ::= { nrCDPJournalInfoEntry 17 }

--    nrCDPJournalExpansionAllocMBUnit    OBJECT-TYPE
--        SYNTAX  INTEGER
--        ACCESS  read-only
--        STATUS  mandatory
--        DESCRIPTION
--            "Amount unit to allocate when expansion is triggered of the CDP Journal Storage. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
--    ::= { nrCDPJournalInfoEntry 18 }

    nrCDPJournalTotalSize64    OBJECT-TYPE
        SYNTAX  Counter64
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The CDP Journal Total size of the NAS resource."
    ::= { nrCDPJournalInfoEntry 19 }

--    nrCDPJournalMaxSize64    OBJECT-TYPE
--        SYNTAX  Counter64
--        ACCESS  read-only
--        STATUS  mandatory
--        DESCRIPTION
--            "The CDP Journal Storage Maximum size of the NAS resource."
--    ::= { nrCDPJournalInfoEntry 20 }

--    nrCDPJournalExpansionAllocMB64    OBJECT-TYPE
--        SYNTAX  Counter64
--        ACCESS  read-only
--        STATUS  mandatory
--        DESCRIPTION
--            "Amount to allocate when expansion is triggered of the CDP Journal Storage."
--    ::= { nrCDPJournalInfoEntry 21 }

    nrCDPJournalAvailableTimerange    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The CDP Journal available time range of the NAS resource."
    ::= { nrCDPJournalInfoEntry 22 }

    nrCDPJournalUsageSize    OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The CDP Journal usage size(MB) of the NAS resource."
    ::= { nrCDPJournalInfoEntry 23 }

    nrCDPJournalUsagePercentage    OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The CDP Journal usage percentage of the NAS resource."
    ::= { nrCDPJournalInfoEntry 24 }

    nrCDPJournalUsageSizeQuantity    OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The CDP Journal Usage size quantity of the NAS resource."
    ::= { nrCDPJournalInfoEntry 25 }

    nrCDPJournalUsageSizeUnit    OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The CDP Journal Usage size unit of the NAS resource. The size unit of the device. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
    ::= { nrCDPJournalInfoEntry 26 }

    nrCDPJournalUsageSize64    OBJECT-TYPE
        SYNTAX  Counter64
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The CDP Journal Usage size of the NAS resource."
    ::= { nrCDPJournalInfoEntry 27 }

    nrCDPJournalNASResourceName    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The CDP Journal NAS resource Name assigned by the IPStor server."
    ::= { nrCDPJournalInfoEntry 28 }

    nrNearLineMirrorTable OBJECT IDENTIFIER ::= { nasResourceEntry 23 }

    nrNearLineMirrorInfoEntry    OBJECT-TYPE
        SYNTAX  NRNearLineMirrorInfo
        ACCESS  not-accessible
        STATUS  mandatory
        DESCRIPTION
            "Information about the configuration of the Near-Line Mirror resource."
        INDEX { nrNearLineMirrorRemoteServerName }
    ::= { nrNearLineMirrorTable 1 }

    NRNearLineMirrorInfo ::= SEQUENCE {
        nrNearLineMirrorRemoteServerName        DisplayString,
        nrNearLineMirrorRemoteServerAlias       DisplayString,
        nrNearLineMirrorRemoteID                INTEGER,
        nrNearLineMirrorRemoteGUID              DisplayString,
        nrNearLineMirrorRemoteSN                DisplayString,
        nrNearLineMirrorNASResourceID		INTEGER,
        nrNearLineMirrorNASResourceName		DisplayString
    }

    nrNearLineMirrorRemoteServerName   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The remote server name of Near-Line mirror resource sets on the IPStor server."
    ::= { nrNearLineMirrorInfoEntry 1 }

    nrNearLineMirrorRemoteServerAlias   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The remote server Alias of Near-Line mirror resource sets on the IPStor server."
    ::= { nrNearLineMirrorInfoEntry 2 }

    nrNearLineMirrorRemoteID   OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The remote resource ID of Near-Line mirror resource sets on the IPStor server."
    ::= { nrNearLineMirrorInfoEntry 3 }

    nrNearLineMirrorRemoteGUID   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The remote resource GUID of Near-Line mirror resource sets on the IPStor server."
    ::= { nrNearLineMirrorInfoEntry 4 }

    nrNearLineMirrorRemoteSN   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The remote resource serial number of Near-Line mirror resource sets on the IPStor server."
    ::= { nrNearLineMirrorInfoEntry 5 }

    nrNearLineMirrorNASResourceID    OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
