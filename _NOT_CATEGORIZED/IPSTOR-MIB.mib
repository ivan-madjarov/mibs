	wcUsers OBJECT IDENTIFIER ::= { windowsClients 11 }

	numOfUsers OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"Total number of users."
	::= { wcUsers 1 }
	
	wcUsersTable OBJECT-TYPE
		SYNTAX  SEQUENCE OF UUsers
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"A list of users of windows clients."
