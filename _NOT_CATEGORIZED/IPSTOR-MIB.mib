    ::= { srReplicaInfoEntry 19 }

    srReplicationMode    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The Replication mode of the SAN resource."
    ::= { srReplicaInfoEntry 20 }

    srReplicationContinuousResourceID    OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The Continuous Replication Resource ID of the SAN resource."
    ::= { srReplicaInfoEntry 21 }

    srReplicationContinuousResourceUsage    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The Continuous Replication Resource Usage of the SAN resource."
    ::= { srReplicaInfoEntry 22 }

    srReplicationDeltaData    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
