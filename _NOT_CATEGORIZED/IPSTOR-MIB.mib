--
-- SAN Clients
--
	sanClients OBJECT IDENTIFIER ::= { ipstorserver 4 }

	numOfSANClients OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of SAN clients authenticated by IPStor server."
	::= { sanClients 1 }

	sanClientTable  OBJECT-TYPE
		SYNTAX  SEQUENCE OF SANClient
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"A table containing client ID, name, and virtual resources assigned to SAN clients."
	::= { sanClients 2 }

	sanClientEntry  OBJECT-TYPE
		SYNTAX  SANClient
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"Information about resources assigned to SAN client."
		INDEX { sanClientID }
	::= { sanClientTable 1 }

	SANClient ::= SEQUENCE {
		sanClientID     INTEGER,
		sanClientName	DisplayString,
--		scResourceTable OBJECT IDENTIFIER	
		sanClientType		DisplayString
	}

	sanClientID OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SAN client ID assigned by the IPStor server."
	::= { sanClientEntry 1 }

	sanClientName   OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SAN client name assigned by the IPStor server."
	::= { sanClientEntry 2 }

	scResourceTable OBJECT-TYPE
		SYNTAX  SEQUENCE OF SCResource
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"A table containing SAN resources that assigned to client using SAN/IP protocol."
	::= { sanClientEntry 3 }

	scResourceEntry OBJECT-TYPE
		SYNTAX SCResource
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"Information about the SAN resources that have been assigned to SAN client."
		INDEX { scResourceID }
	::= { scResourceTable 1 }

	SCResource ::= SEQUENCE {
		scResourceID            INTEGER,
		scResourceName          DisplayString,
		scClientID              INTEGER,
		scClientName            DisplayString,
		scResourceAllocType     DisplayString,
		scResourceAdapterNo     INTEGER,
		scResourceChannelNo     INTEGER,
		scResourceScsiID        INTEGER,
		scResourceLun           INTEGER,
		scResourceSize          INTEGER,
		scResourceTotalSectors  INTEGER,
		scResourceSectorSize    INTEGER,
		scResourceAccess        DisplayString
	}

	scResourceID    OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SAN resource ID assigned by the IPStor server."
	::= { scResourceEntry 1 }

	scResourceName  OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SAN resource name created by the user."
	::= { scResourceEntry 2 }

	scClientID  OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SAN client ID assigned by the IPStor server."
	::= { scResourceEntry 3 }

	scClientName    OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SAN client name assigned by the IPStor server."
	::= { scResourceEntry 4 }

	scResourceAllocType OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It represents the resource type when user allocating the SAN device."
	::= { scResourceEntry 5 }

	scResourceAdapterNo OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The adapter number of the SAN resource."
	::= { scResourceEntry 6 }

	scResourceChannelNo OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The channel number of the SAN resource."
	::= { scResourceEntry 7 }

	scResourceScsiID    OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI ID of the SAN resource."
	::= { scResourceEntry 8 }

	scResourceLun   OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI LUN number of the SAN resource."
	::= { scResourceEntry 9 }

	scResourceSize  OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of device size which is representing with megabyte unit of the SAN resource."
	::= { scResourceEntry 10 }

	scResourceTotalSectors  OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of sectors allocated by the SAN resource."
	::= { scResourceEntry 11 }

	scResourceSectorSize    OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The size of bytes for each sector or block."
	::= { scResourceEntry 12 }

	scResourceAccess    OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SAN resource accessing mode assigned to the SAN client."
	::= { scResourceEntry 13 }

	scFCResourceTable   OBJECT-TYPE
		SYNTAX  SEQUENCE OF SCFCResource
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"A table containing client ID, name, and virtual resources assigned to Fibre Channel clients."
	::= { sanClientEntry 4 }

	scFCResourceEntry   OBJECT-TYPE
		SYNTAX SCFCResource
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"Information about the SAN resources that have been assigned to Fibre Channel client."
		INDEX { scfcResourceID }
	::= { scFCResourceTable 1 }

	SCFCResource ::= SEQUENCE {
		scfcResourceID			INTEGER,
		scfcResourceName		DisplayString,
		scfcClientID			INTEGER,
		scfcClientName			DisplayString,
		scfcResourceAllocType		DisplayString,
		scfcLUN				INTEGER,
		scfcInitatorWWPN		DisplayString,
		scfcTargetWWPN			DisplayString,
		scfcAccess			DisplayString,
		scfcTotalsize			Counter32,
		scfcTotalSectors		Counter32,
		scfcSectorSize			INTEGER,
		scfcTotalsize64			Counter64,
		scfcTotalSectors64		Counter64,
		scfcTotalsizeQuantity		Counter32,
		scfcTotalsizeUnit		INTEGER
	}

	scfcResourceID OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The unique resource ID that assigned by IPStor server."
	::= { scFCResourceEntry 1 }

	scfcResourceName    OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The resource name that created by user."
	::= { scFCResourceEntry 2 }

	scfcClientID    OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The unique client ID that assigned by IPStor server."
	::= { scFCResourceEntry 3 }

	scfcClientName  OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The client name that created by user."
	::= { scFCResourceEntry 4 }

	scfcResourceAllocType   OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It represents the resource type when user allocating the SAN device."
	::= { scFCResourceEntry 5 }

	scfcLUN OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI LUN number that assigned to the resource."
	::= { scFCResourceEntry 6 }

	scfcInitatorWWPN    OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The initiator world wide port name(WWPN) of the resource."
	::= { scFCResourceEntry 7 }

	scfcTargetWWPN  OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The target world wide port name(WWPN) of the resource."
	::= { scFCResourceEntry 8 }

	scfcAccess  OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The access rights of the resource."
	::= { scFCResourceEntry 9 }

	scfcTotalsize   OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of device size which is representing with megabyte unit of the resource."
	::= { scFCResourceEntry 10 }

	scfcTotalSectors    OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"Total sectors allocated of the resource."
	::= { scFCResourceEntry 11 }

	scfcSectorSize  OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The size of bytes per sector or block."
	::= { scFCResourceEntry 12 }

	scfcTotalsize64   OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of device size which is representing with megabyte unit of the resource."
	::= { scFCResourceEntry 13 }

	scfcTotalSectors64    OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"Total sectors allocated of the resource."
	::= { scFCResourceEntry 14 }

	scfcTotalsizeQuantity  OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
            "The amount of device size quantity of the resource."
	::= { scFCResourceEntry 15 }

	scfcTotalsizeUnit  OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
            "The amount of device size unit of the resource. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
	::= { scFCResourceEntry 16 }

	scBootIPTable   OBJECT-TYPE
		SYNTAX  SEQUENCE OF SCBootIPClient
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"A table containing IP Address, MAC address , and Default Boot clients which enable the BootIP option."
	::= { sanClientEntry 6 }

	scBootIPEntry   OBJECT-TYPE
		SYNTAX SCBootIPClient
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"Information about the SAN client that enable the BootIP option."
		INDEX { scbootipIPAddress }
	::= { scBootIPTable 1 }

	SCBootIPClient ::= SEQUENCE {
		scbootipIPAddress		DisplayString,
		scbootipMAC			DisplayString,
		scbootipDefaultBoot		DisplayString
	}

	scbootipIPAddress OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The IP address setting of BootIP option."
	::= { scBootIPEntry 1 }

	scbootipMAC OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The MAC address setting of BootIP option."
	::= { scBootIPEntry 2 }

	scbootipDefaultBoot OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The default boot setting of BootIP option."
	::= { scBootIPEntry 3 }

	sanClientType    OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SAN Client Type set to the IPStor server."
	::= { sanClientEntry 7 }

	sanClientPersistentReserv    OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SAN Client Persistent Reservation option to the IPStor server."
	::= { sanClientEntry 8 }

	sanClientIsClusted    OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SAN Client is clusted set to the IPStor server."
	::= { sanClientEntry 9 }

	scISCSIResourceTable   OBJECT-TYPE
		SYNTAX  SEQUENCE OF SCISCSIResource
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"A table containing client ID, name, and virtual resources assigned to iSCSI clients."
	::= { sanClientEntry 10 }

	scISCSIResourceEntry   OBJECT-TYPE
		SYNTAX  SCISCSIResource
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"Information about the SAN resources that have been assigned to iSCSI client."
		INDEX { sciscsiResourceID }
	::= { scISCSIResourceTable 1 }

	SCISCSIResource ::= SEQUENCE {
		sciscsiResourceID			INTEGER,
		sciscsiResourceName			DisplayString,
		sciscsiClientID				INTEGER,
		sciscsiClientName			DisplayString,
		sciscsiResourceAllocType		DisplayString,
		sciscsiLUN				INTEGER,
		sciscsiAuthentication			DisplayString,
		sciscsiAuthDefaultUser			DisplayString,
		sciscsiAuthAdditionalUser		DisplayString,
		sciscsiMutualCHAPSecret			DisplayString,
		sciscsiInitiatorName			DisplayString,
		sciscsiInitiatorAccessType		DisplayString,
		sciscsiTargetID				INTEGER,
		sciscsiTargetName			DisplayString,
		sciscsiTargetIP				DisplayString,
		sciscsiAcessRight			DisplayString,
		sciscsiTotalsize			Counter32,
		sciscsiTotalSectors			Counter32,
		sciscsiSectorSize			INTEGER,
		sciscsiTotalsize64			Counter64,
		sciscsiTotalSectors64			Counter64,
		sciscsiTotalsizeQuantity		Counter32,
		sciscsiTotalsizeUnit			INTEGER
	}

	sciscsiResourceID OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The unique resource ID that assigned by IPStor server."
	::= { scISCSIResourceEntry 1 }

	sciscsiResourceName    OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The resource name that created by user."
	::= { scISCSIResourceEntry 2 }

	sciscsiClientID    OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The unique client ID that assigned by IPStor server."
	::= { scISCSIResourceEntry 3 }

	sciscsiClientName  OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The client name that created by user."
	::= { scISCSIResourceEntry 4 }

	sciscsiResourceAllocType   OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It represents the resource type when user allocating the SAN device."
	::= { scISCSIResourceEntry 5 }

	sciscsiLUN	OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI LUN number that assigned to the resource."
	::= { scISCSIResourceEntry 6 }

	sciscsiAuthentication	OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The authentication of the iSCSI client."
	::= { scISCSIResourceEntry 7 }

	sciscsiAuthDefaultUser	OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The default user when authentication enabled of the iSCSI client."
	::= { scISCSIResourceEntry 8 }

	sciscsiAuthAdditionalUser	OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The additional user when authentication enabled of the iSCSI client."
