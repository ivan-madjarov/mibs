        INDEX { srBackupResourceID }
    ::= { srBackupTable 1 }

    SRBackupInfo ::= SEQUENCE {
        srBackupResourceID      INTEGER,
        srBackupResourceName    DisplayString,
        srBackupOption          DisplayString,
        srBackupWindow          DisplayString,
        srBackupSessionLen      DisplayString,
        srBackupRelativeTime    DisplayString,
        srBackupWaitTime        INTEGER,
        srBackupSelectCriteria  DisplayString,
        srBackupRawDeviceName   DisplayString
    }

    srBackupResourceID  OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The SAN resource ID assigned by the IPStor server."
    ::= { srBackupInfoEntry 1 }

    srBackupResourceName    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The SAN resource name created by the user."
    ::= { srBackupInfoEntry 2 }
    
    srBackupOption  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the backup option is enable or disable of the SAN resource."
    ::= { srBackupInfoEntry 3 }

    srBackupWindow  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The daytime allows for opening one backup sesion."
    ::= { srBackupInfoEntry 4 }
    
    srBackupSessionLen  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The time interval allows for one backup session in each time."
    ::= { srBackupInfoEntry 5 }

    srBackupRelativeTime    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The time interval waits before closing the backup session which is in inactivity status."
    ::= { srBackupInfoEntry 6 }
    
    srBackupWaitTime    OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The time interval which is represnting in minute unit waits before closing the backup session after completion."
    ::= { srBackupInfoEntry 7 }

    srBackupSelectCriteria  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The snapshot image selection criteria that could be new or latest for the backup session.
             New represents that it always creates new snapshot image for backup, and 
             Latest represents that it uses the last created snapshot image for backup."
    ::= { srBackupInfoEntry 8 }

    srBackupRawDeviceName    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The SAN Backup Resource Raw Device Name created by the user."
    ::= { srBackupInfoEntry 9 }

    srReplicationTable OBJECT IDENTIFIER ::= { sanResourceEntry 17 }
    
    srReplicaInfoEntry OBJECT-TYPE
        SYNTAX  SRReplicationInfo
