    srReplicaTime   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The daytime of each day creates one new replication."
    ::= { srReplicaInfoEntry 9 }
    
    srReplicaInterval   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
