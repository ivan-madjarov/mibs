    nrMirrorSyncRetryActivity   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The mirror synchronization retry when I/O activity is below or at."
    ::= { nrMirrorInfoEntry 13 }

    nrMirrorSyncRetryTimes   OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The maximum mirror synchronization retry times."
