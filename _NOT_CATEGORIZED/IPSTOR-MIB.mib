		DESCRIPTION
			"The size of bytes per sector or block."
	::= { scISCSIResourceEntry 19 }

	sciscsiTotalsize64   OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of device size which is representing with megabyte unit of the resource."
