		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"Windows user index."
	::= { wcUsersEntry 1 }
	
	wcUserName OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"User name of this windows client."
	::= { wcUsersEntry 2 }

	wcUserDescription OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"Description of this user."
	::= { wcUsersEntry 3 }

