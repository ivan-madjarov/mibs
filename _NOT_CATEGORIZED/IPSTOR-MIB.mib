    nrNearLineMirrorNASResourceName    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The NAS resource Name which assigned by the IPStor server enables the Near-Line mirror function."
    ::= { nrNearLineMirrorInfoEntry 7 }
	
	nrTotalSizeQuantity OBJECT-TYPE
		SYNTAX	Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of device size quantity of the NAS resource."
	::= { nasResourceEntry 24 }
	
	nrTotalSizeUnit OBJECT-TYPE
		SYNTAX	INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of device size unit of the NAS resource. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
	::= { nasResourceEntry 25 }

	nrTotalSectors64  OBJECT-TYPE
		SYNTAX	Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of sectors allocated by the NAS resource."
	::= { nasResourceEntry 26 }
	
	nrTotalSize64 OBJECT-TYPE
		SYNTAX	Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of device size which is representing with megabyte unit of the NAS resource."
	::= { nasResourceEntry 27 }

	nrPhysicalTotalAllocLayoutTable OBJECT IDENTIFIER ::= { nasResourceEntry 28 }

	nrPhysicalTotalAllocLayoutEntry    OBJECT-TYPE
		SYNTAX	NRPhysicalTotalAllocLayout
		ACCESS	not-accessible
		STATUS	mandatory
		DESCRIPTION
			"Information about the physical devices which are reserved and created by logical NAS resource."
		INDEX { nrpaAllocNASResourceName }
	::= { nrPhysicalTotalAllocLayoutTable 1 }

	NRPhysicalTotalAllocLayout ::= SEQUENCE {
		nrpaAllocNASResourceName		DisplayString,
		nrpaAllocName			        DisplayString,
		nrpaAllocType  			        DisplayString,
		nrpaAllocAdapterNo		    	INTEGER,
		nrpaAllocChannelNo		    	INTEGER,
		nrpaAllocScsiID			        INTEGER,
		nrpaAllocLun			        INTEGER,
		nrpaAllocFirstSector		    	Counter32,
		nrpaAllocLastSector			Counter32,
		nrpaAllocFirstSector64			Counter64,
		nrpaAllocLastSector64			Counter64,
		nrpaAllocSize			        Counter32,
		nrpaAllocSizeQuantity		        Counter32,
		nrpaAllocSizeUnit			INTEGER,
		nrpaAllocSize64				Counter64
	}

	nrpaAllocNASResourceName    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The NAS resource name created by the user."
	::= { nrPhysicalTotalAllocLayoutEntry 1 }

	nrpaAllocName    OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The physical device name."
	::= { nrPhysicalTotalAllocLayoutEntry 2 }
	
	nrpaAllocType OBJECT-TYPE
		SYNTAX	DisplayString
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"It represents the type(Primary, or Mirror) of the physical layout."
	::= { nrPhysicalTotalAllocLayoutEntry 3 }

	nrpaAllocAdapterNo OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI adapter number of the physical device."
	::= { nrPhysicalTotalAllocLayoutEntry 4 }

	nrpaAllocChannelNo OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI channel number of the physical device."
	::= { nrPhysicalTotalAllocLayoutEntry 5 }

	nrpaAllocScsiID OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI ID of the physical device."
	::= { nrPhysicalTotalAllocLayoutEntry 6 }

	nrpaAllocLun OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The SCSI LUN number of the physical device."
	::= { nrPhysicalTotalAllocLayoutEntry 7 }

	nrpaAllocFirstSector OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The first sector of the physical device which is allocated by the NAS resource."
	::= { nrPhysicalTotalAllocLayoutEntry 8 }

	nrpaAllocLastSector  OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The last sector of the physical device which is allocated by the NAS resource."
	::= { nrPhysicalTotalAllocLayoutEntry 9 }

	nrpaAllocFirstSector64 OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The first sector of the physical device which is allocated by the NAS resource."
	::= { nrPhysicalTotalAllocLayoutEntry 10 }

	nrpaAllocLastSector64  OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The last sector of the physical device which is allocated by the NAS resource."
	::= { nrPhysicalTotalAllocLayoutEntry 11 }
		
	nrpaAllocSize    OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of the allocated size which is representing with megabyte unit within a physical device."
	::= { nrPhysicalTotalAllocLayoutEntry 12 }
		
	nrpaAllocSizeQuantity    OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of the allocated size quantity within a physical device."
	::= { nrPhysicalTotalAllocLayoutEntry 13 }
		
	nrpaAllocSizeUnit    OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of the allocated size unit within a physical device. The size unit of the device. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
	::= { nrPhysicalTotalAllocLayoutEntry 14 }
		
	nrpaAllocSize64    OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS	read-only
		STATUS	mandatory
		DESCRIPTION
			"The amount of the allocated size which is representing with megabyte unit within a physical device."
	::= { nrPhysicalTotalAllocLayoutEntry 15 }

	nrHotZonePrefetchInfoTable OBJECT IDENTIFIER ::= { nasResourceEntry 29 }

	nrHotZonePrefetchInfoEntry OBJECT-TYPE
		SYNTAX  NRHotZonePrefetchInfo
		ACCESS  not-accessible
		STATUS  mandatory
		DESCRIPTION
			"Information about the HotZone Prefetch if the NAS resources have enabled."
		INDEX { nrHotZonePrefetchNASResourceID }
	::= { nrHotZonePrefetchInfoTable 1 }

	NRHotZonePrefetchInfo ::= SEQUENCE {
		nrHotZonePrefetchNASResourceID		INTEGER,
		nrHotZonePrefetchMaximumChains		INTEGER,
		nrHotZonePrefetchMaximumReadAhead	INTEGER,
		nrHotZonePrefetchReadAhead		INTEGER,
		nrHotZonePrefetchChainTimeout		DisplayString,
		nrHotZonePrefetchNASResourceName	DisplayString
	}

	nrHotZonePrefetchNASResourceID OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The NAS Resource ID that assigned by IPStor server."
	::= { nrHotZonePrefetchInfoEntry 1 }

	nrHotZonePrefetchMaximumChains OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The maximum number of sequential read chains to detect."
	::= { nrHotZonePrefetchInfoEntry 2 }

	nrHotZonePrefetchMaximumReadAhead OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The maximum size to read ahead representing with KB."
	::= { nrHotZonePrefetchInfoEntry 3 }

	nrHotZonePrefetchReadAhead OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The size of read the read command issued when reading ahead representing with KB."
	::= { nrHotZonePrefetchInfoEntry 4 }

	nrHotZonePrefetchChainTimeout OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The time before the chain is removed and the readahead buffers are freed."
	::= { nrHotZonePrefetchInfoEntry 5 }

	nrHotZonePrefetchNASResourceName OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The NAS Resource Name that assigned by IPStor server."
	::= { nrHotZonePrefetchInfoEntry 6 }

	nrHotZoneReadCacheInfoTable OBJECT IDENTIFIER ::= { nasResourceEntry 30 }

	nrHotZoneReadCacheInfoEntry OBJECT-TYPE
		SYNTAX  NRHotZoneReadCacheInfo
		ACCESS  not-accessible
		STATUS  mandatory
		DESCRIPTION
			"Information about the HotZone Read Cache if the NAS resources have enabled."
		INDEX { nrHotZoneReadCacheResourceID }
	::= { nrHotZoneReadCacheInfoTable 1 }

	NRHotZoneReadCacheInfo ::= SEQUENCE {
		nrHotZoneReadCacheResourceID		INTEGER,
		nrHotZoneReadCacheNASResourceID		INTEGER,
		nrHotZoneReadCacheTotalSize		Counter32,
		nrHotZoneReadCacheStatus		DisplayString,
		nrHotZoneReadCacheSuspended		DisplayString,
		nrHotZoneReadCacheAccessType		DisplayString,
		nrHotZoneReadCacheAccessIntensity	DisplayString,
		nrHotZoneReadCacheMinimumStayTime	DisplayString,
		nrHotZoneReadCacheEachZoneSize		DisplayString,
		nrHotZoneReadCacheTotalZones		Counter32,
		nrHotZoneReadCacheUsedZones		Counter32,
		nrHotZoneReadCacheHitRatio		DisplayString,
		nrHotZoneReadCacheTotalSizeQuantity	Counter32,
		nrHotZoneReadCacheTotalSizeUnit		INTEGER,
		nrHotZoneReadCacheTotalSize64		Counter64,
		nrHotZoneReadCacheNASResourceName	DisplayString
	}

	nrHotZoneReadCacheResourceID OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The Resource ID that assigned by IPStor server."
	::= { nrHotZoneReadCacheInfoEntry 1 }

	nrHotZoneReadCacheNASResourceID OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The NASResource ID that assigned by IPStor server."
	::= { nrHotZoneReadCacheInfoEntry 2 }

	nrHotZoneReadCacheTotalSize OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The amount of device size which is representing with megabyte unit of the HotZone read cache resource."
	::= { nrHotZoneReadCacheInfoEntry 3 }

	nrHotZoneReadCacheStatus OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The status represents current HotZone read cache of the NAS resource."
	::= { nrHotZoneReadCacheInfoEntry 4 }

	nrHotZoneReadCacheSuspended OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The Suspended status represents current HotZone read cache of the NAS resource."
	::= { nrHotZoneReadCacheInfoEntry 5 }

	nrHotZoneReadCacheAccessType OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The zone's access type policy of the NAS resource."
	::= { nrHotZoneReadCacheInfoEntry 6 }

	nrHotZoneReadCacheAccessIntensity OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The access intensity to determine how the zone is accessed."
	::= { nrHotZoneReadCacheInfoEntry 7 }

	nrHotZoneReadCacheMinimumStayTime OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The minimum time that how long a zone can stay at least in the HotZone before it is swapped out."
	::= { nrHotZoneReadCacheInfoEntry 8 }

	nrHotZoneReadCacheEachZoneSize OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The size of each zone setting."
	::= { nrHotZoneReadCacheInfoEntry 9 }

	nrHotZoneReadCacheTotalZones OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The total zones that is allocated of the NAS resource."
	::= { nrHotZoneReadCacheInfoEntry 10 }

	nrHotZoneReadCacheUsedZones OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The current used zones of the NAS resource."
	::= { nrHotZoneReadCacheInfoEntry 11 }

	nrHotZoneReadCacheHitRatio OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The hit ratio represents current HotZone read cache of the NAS resource."
	::= { nrHotZoneReadCacheInfoEntry 12 }

	nrHotZoneReadCacheTotalSizeQuantity OBJECT-TYPE
		SYNTAX  Counter32
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The amount of device size quantity which is representing with megabyte unit of the HotZone read cache resource."
	::= { nrHotZoneReadCacheInfoEntry 13 }

	nrHotZoneReadCacheTotalSizeUnit OBJECT-TYPE
		SYNTAX  INTEGER
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The amount of device size unit of the HotZone read cache resource. The size unit of the device. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
	::= { nrHotZoneReadCacheInfoEntry 14 }

	nrHotZoneReadCacheTotalSize64 OBJECT-TYPE
		SYNTAX  Counter64
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The amount of device size which is representing with megabyte unit of the HotZone read cache resource."
	::= { nrHotZoneReadCacheInfoEntry 15 }

	nrHotZoneReadCacheNASResourceName OBJECT-TYPE
		SYNTAX  DisplayString
		ACCESS  read-only
		STATUS  mandatory
		DESCRIPTION
			"The NASResource Name that assigned by IPStor server."
	::= { nrHotZoneReadCacheInfoEntry 16 }




