    nrMirrorHealthMonitoringOption   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the mirror health monitoring option is enable or disable."
    ::= { nrMirrorInfoEntry 6 }

    nrMirrorHealthCheckInterval   OBJECT-TYPE
        SYNTAX  INTEGER
