    srReplicationMicroscan    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the Microscan option is enable or disable of Replication."
    ::= { srReplicaInfoEntry 17 }

    srReplicationSyncPriority    OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
