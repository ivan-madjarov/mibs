    nrMirrorMaxLagTime   OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The Maximum acceptable lagging time for the mirror I/O's."
    ::= { nrMirrorInfoEntry 8 }

    nrMirrorSuspendThPercent   OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "Suspended mirroring when the threshold of failure reaches the percentage of the failure conditions."
    ::= { nrMirrorInfoEntry 9 }

    nrMirrorSuspendThIOnum   OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "Suspended mirroring when the outstanding IOs is greater than or equals to."
    ::= { nrMirrorInfoEntry 10 }

    nrMirrorSyncRetryPolicy   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the mirror synchronization retry policy is enable or not."
    ::= { nrMirrorInfoEntry 11 }

    nrMirrorSyncRetryInterval   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The mirror synchronization retry at specified interval."
