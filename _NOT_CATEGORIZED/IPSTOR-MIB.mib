    snapshotgroupMemberTableIndex    OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The virtual resource ID assigned by the IPStor server."
    ::= { snapshotgroupMemberTableEntry 2 }

    snapshotgroupMemberTableName OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The virtual resource name created by the user."
    ::= { snapshotgroupMemberTableEntry 3 }

    GlobalSafeCache OBJECT IDENTIFIER ::= { logicalResources 8 }

    GSCsanResourceInfoTable  OBJECT-TYPE
        SYNTAX  SEQUENCE OF GSCsanResourceInfo
        ACCESS  not-accessible
        STATUS  mandatory
        DESCRIPTION
            "A table containing the SAN resources enable the global safe cache option."
    ::= { GlobalSafeCache 1 }
    
    GSCsanResourceNumber  OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The total SAN resource numbers enable the global safe cache."
