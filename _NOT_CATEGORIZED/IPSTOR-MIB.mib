    srReplicationResourceName   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The SAN resource name created by the user."
    ::= { srReplicaInfoEntry 2 }
    
    srReplicationOption OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the replication option is enable or disable of the SAN resource."
    ::= { srReplicaInfoEntry 3 }

    srReplicaServer OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
