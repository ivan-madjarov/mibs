    ::= { srCacheTable 1 }

    SRCacheInfo ::= SEQUENCE {
        srCacheResourceID		INTEGER,
        srCacheResourceName		DisplayString,
        srCacheOption			DisplayString,
        srCacheSuspend			DisplayString,
        srCacheTotalSize		Counter32,
        srCacheFreeSize			Counter32,
        srCacheUsage			INTEGER,
        srCacheThreshold		INTEGER,
        srCacheFlushTime		INTEGER,
        srCacheFlushCommand		INTEGER,
        srCacheSkipWriteCommands	DisplayString,
        srCacheFlushSpeed		INTEGER,
        srCacheTotalSizeQuantity	Counter32,
        srCacheTotalSizeUnit		INTEGER,
        srCacheFreeSizeQuantity		Counter32,
        srCacheFreeSizeUnit		INTEGER,
        srCacheOwnResourceID		INTEGER,
        srCacheTotalSize64		Counter64,
        srCacheFreeSize64		Counter64,
	srCacheStatus			DisplayString
    }

    srCacheResourceID   OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The SAN resource ID assigned by the IPStor server."
    ::= { srCacheInfoEntry 1 }

    srCacheResourceName OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The SAN resource name created by the user."
    ::= { srCacheInfoEntry 2 }
    
    srCacheOption   OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The status represents the cache option is enable or disable of the SAN resource."
    ::= { srCacheInfoEntry 3 }
    
    srCacheSuspend  OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The cache resource is currently suspended or not."
    ::= { srCacheInfoEntry 4 }
    
    srCacheTotalSize    OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The allocated size when creating the cache resource."
    ::= { srCacheInfoEntry 5 }
    
    srCacheFreeSize OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The free resource size which is representing in megabyte unit before reaching the maximum resource size."
    ::= { srCacheInfoEntry 6 }

    srCacheUsage    OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The percentage of the used resource size."
    ::= { srCacheInfoEntry 7 }
    
    srCacheThreshold    OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The data needs to be in the cache before beginning flushing the cache."
    ::= { srCacheInfoEntry 8 }
    
    srCacheFlushTime    OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The number of milliseconds before cache begins to flush when below the data threshold level."
    ::= { srCacheInfoEntry 9 }
    
    srCacheFlushCommand OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The outstanding commands will be sent at one time during the flush process."
    ::= { srCacheInfoEntry 10 }
    
    srCacheSkipWriteCommands    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "This option allows the system to skip multiple pending write commands targeted for the same block."
    ::= { srCacheInfoEntry 11 }

    srCacheFlushSpeed OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The flush speed will be sent at one time during the flush process."
    ::= { srCacheInfoEntry 12 }
    
    srCacheTotalSizeQuantity    OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The allocated size quantity when creating the cache resource."
    ::= { srCacheInfoEntry 13 }
    
    srCacheTotalSizeUnit    OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The allocated size unit when creating the cache resource. 0
presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
    ::= { srCacheInfoEntry 14 }
    
    srCacheFreeSizeQuantity OBJECT-TYPE
        SYNTAX  Counter32
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The free resource size quantity before reaching the maximum resource size."
    ::= { srCacheInfoEntry 15 }
    
    srCacheFreeSizeUnit OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The free resource size unit before reaching the maximum resource size. 0 presents KB. 1 presents MB. 2 presents GB. 3 presents TB."
    ::= { srCacheInfoEntry 16 }

    srCacheOwnResourceID   OBJECT-TYPE
        SYNTAX  INTEGER
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The Cache resource ID assigned by the IPStor server."
    ::= { srCacheInfoEntry 17 }
    
    srCacheTotalSize64    OBJECT-TYPE
        SYNTAX  Counter64
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The allocated size when creating the cache resource."
    ::= { srCacheInfoEntry 18 }
    
    srCacheFreeSize64 OBJECT-TYPE
        SYNTAX  Counter64
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
            "The free resource size which is representing in megabyte unit before reaching the maximum resource size."
    ::= { srCacheInfoEntry 19 }
    
    srCacheStatus    OBJECT-TYPE
        SYNTAX  DisplayString
        ACCESS  read-only
        STATUS  mandatory
        DESCRIPTION
