DTT DEFINITIONS ::= BEGIN

IMPORTS
    OBJECT-TYPE, NOTIFICATION-TYPE, MODULE-IDENTITY,
    Integer32, Opaque, TimeTicks,enterprises
        FROM SNMPv2-SMI

    TEXTUAL-CONVENTION, DisplayString, TruthValue
	FROM SNMPv2-TC;

datatrack MODULE-IDENTITY
    LAST-UPDATED "20100315"
    ORGANIZATION "Data Track Technology PLC"
    CONTACT-INFO "email: support@dtrack.com"
    DESCRIPTION	 "This file defines the private DTT SNMP MIB extensions.
		  This file is for import into managing entities only."
    REVISION	 "20100315"
    DESCRIPTION	 "The DTT MIB"
    ::= { enterprises 11459 }


dttHardware		OBJECT IDENTIFIER ::= { datatrack   	1  }

dttT2700		OBJECT IDENTIFIER ::= { dttHardware	1  }

dttT2700Traps		OBJECT IDENTIFIER ::= { dttT2700  	1  }

dttSoftware		OBJECT IDENTIFIER ::= { datatrack	2  }

dttT2700Sw		OBJECT IDENTIFIER ::= { dttSoftware	1  }

dttT2700SwTraps		OBJECT IDENTIFIER ::= { dttT2700Sw	1  }

dttTLegacySw		OBJECT IDENTIFIER ::= { dttSoftware	2  }

dttTLegacySwTraps	OBJECT IDENTIFIER ::= { dttTLegacySw	1  }

dttCMSSw		OBJECT IDENTIFIER ::= { dttSoftware	3  }

dttCMSSwTraps		OBJECT IDENTIFIER ::= { dttCMSSw	1  }

dttAMSSw		OBJECT IDENTIFIER ::= { dttSoftware 4 }

dttAMSSwAlarms		OBJECT IDENTIFIER ::= { dttAMSSw 1}

dttSAMSSw		OBJECT IDENTIFIER ::= { dttSoftware 5 }

dttSAMSSwTraps	OBJECT IDENTIFIER ::= { dttSAMSSw 1 }



--
-- T2700 Hardware alert trap
--
    

dttT2700SerialNo OBJECT-TYPE
    SYNTAX	DisplayString ( SIZE (1..12) )
    ACCESS	not-accessible
    STATUS	mandatory
    DESCRIPTION "The serial number of the sending tracker2700"
    ::= { dttT2700Traps  1 }

dttT2700StationId OBJECT-TYPE
    SYNTAX	DisplayString ( SIZE (1..16) )
    ACCESS	not-accessible
    STATUS	mandatory
    DESCRIPTION "The station ident string of the sending tracker2700"
    ::= { dttT2700Traps  2 }

dttT2700AlertType OBJECT-TYPE
    SYNTAX	INTEGER
    ACCESS	not-accessible
    STATUS	mandatory
    DESCRIPTION "The type of Alert"
    ::= { dttT2700Traps  3 }

dttT2700AlertSubType OBJECT-TYPE
    SYNTAX	Integer32 
    ACCESS	not-accessible
    STATUS	mandatory
    DESCRIPTION "The sub-type of Alert"
    ::= { dttT2700Traps  4 }

dttT2700AlertTime OBJECT-TYPE
    SYNTAX	TimeTicks 
    ACCESS	not-accessible
    STATUS	mandatory
    DESCRIPTION "The occurrence time  of the Alert in Unix seconds"
    ::= { dttT2700Traps  5 }

dttT2700AlertDesc OBJECT-TYPE
    SYNTAX	DisplayString ( SIZE (0..32) )
    ACCESS	not-accessible
    STATUS	mandatory
    DESCRIPTION "The description of the Alert"
    ::= { dttT2700Traps  6 }

dttT2700AlertData OBJECT-TYPE
    SYNTAX	OCTET STRING ( SIZE (1..1024) )
    ACCESS	not-accessible
    STATUS	mandatory
    DESCRIPTION "The data associated with the Alert (if any) "
    ::= { dttT2700Traps  7 }

dttT2700Alert TRAP-TYPE
    ENTERPRISE  datatrack
    VARIABLES
    {
	dttT2700SerialNo,
	dttT2700StationId,
	dttT2700AlertType,
        dttT2700AlertSubType,
	dttT2700AlertTime,
	dttT2700AlertDesc,
	dttT2700AlertData
    }
    DESCRIPTION "Tracker 2700 Alert"  
    ::=  1
    
    
--
-- T2700 software alert trap
--


dttT2700SwSerialNo OBJECT-TYPE
    SYNTAX	DisplayString ( SIZE (1..12) )
    ACCESS	not-accessible
    STATUS	mandatory
    DESCRIPTION "The serial number of the sending tracker2700"
    ::= { dttT2700SwTraps  1 }

dttT2700SwStationId OBJECT-TYPE
    SYNTAX	DisplayString ( SIZE (1..16) )
    ACCESS	not-accessible
    STATUS	mandatory
    DESCRIPTION "The station ident string of the sending tracker2700"
    ::= { dttT2700SwTraps  2 }

dttT2700SwAlertType OBJECT-TYPE
    SYNTAX	INTEGER
    ACCESS	not-accessible
    STATUS	mandatory
    DESCRIPTION "The type of Alert"
    ::= { dttT2700SwTraps  3 }

dttT2700SwAlertSubType OBJECT-TYPE
    SYNTAX	Integer32 
    ACCESS	not-accessible
    STATUS	mandatory
    DESCRIPTION "The sub-type of Alert"
    ::= { dttT2700SwTraps  4 }

dttT2700SwAlertTime OBJECT-TYPE
    SYNTAX	TimeTicks 
    ACCESS	not-accessible
    STATUS	mandatory
    DESCRIPTION "The occurrence time  of the Alert in Unix seconds"
    ::= { dttT2700SwTraps  5 }

dttT2700SwAlertDesc OBJECT-TYPE
    SYNTAX	DisplayString ( SIZE (0..32) )
    ACCESS	not-accessible
    STATUS	mandatory
    DESCRIPTION "The description of the Alert"
    ::= { dttT2700SwTraps  6 }

dttT2700SwAlertData OBJECT-TYPE
    SYNTAX	OCTET STRING ( SIZE (1..1024) )
    ACCESS	not-accessible
    STATUS	mandatory
    DESCRIPTION "The data associated with the Alert (if any) "
    ::= { dttT2700SwTraps  7 }

    
dttT2700SwAlert TRAP-TYPE
    ENTERPRISE  datatrack
    VARIABLES
    {
	dttT2700SwSerialNo,
	dttT2700SwStationId,
	dttT2700SwAlertType,
        dttT2700SwAlertSubType,
	dttT2700SwAlertTime,
	dttT2700SwAlertDesc,
	dttT2700SwAlertData
    }
    DESCRIPTION "Tracker 2700 Software Alert"  
    ::=  2


--
-- TLegacy software alert trap
--
    

dttTLegacySwStationId OBJECT-TYPE
    SYNTAX	DisplayString ( SIZE (1..16) )
    ACCESS	not-accessible
    STATUS	mandatory
    DESCRIPTION "The station ident string of the sending trackerLegacy"
    ::= { dttTLegacySwTraps  1 }

dttTLegacySwAlertType OBJECT-TYPE
    SYNTAX	DisplayString ( SIZE (1..7) )
    ACCESS	not-accessible
    STATUS	mandatory
    DESCRIPTION "The type of Alert"
    ::= { dttTLegacySwTraps  2 }

dttTLegacySwAlertTime OBJECT-TYPE
    SYNTAX	TimeTicks 
    ACCESS	not-accessible
    STATUS	mandatory
    DESCRIPTION "The occurrence time  of the Alert in Unix seconds"
    ::= { dttTLegacySwTraps  3 }

dttTLegacySwAlertDesc OBJECT-TYPE
    SYNTAX	DisplayString ( SIZE (0..32) )
    ACCESS	not-accessible
    STATUS	mandatory
    DESCRIPTION "The description of the Alert"
    ::= { dttTLegacySwTraps  4 }

dttTLegacySwAlertData OBJECT-TYPE
    SYNTAX	OCTET STRING ( SIZE (1..1024) )
    ACCESS	not-accessible
    STATUS	mandatory
    DESCRIPTION "The data associated with the Alert (if any) "
    ::= { dttTLegacySwTraps  5 }

dttTLegacySwAlert TRAP-TYPE
